@inherits LayoutComponentBase
@inject IJSRuntime JS
@implements IAsyncDisposable

<MudThemeProvider IsDarkMode="_isDarkMode" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar Elevation="1" Color="Color.Primary">
        <MudText Typo="Typo.h6" Class="flex-grow-1">My Todo List</MudText>
        <MudIconButton
            Icon="@(_isDarkMode ? Icons.Material.Filled.LightMode : Icons.Material.Filled.DarkMode)"
            Color="Color.Inherit"
            OnClick="ToggleDarkMode"
            title="@(_isDarkMode ? "Switch to light mode" : "Switch to dark mode")"
            Class="dark-mode-toggle" />
    </MudAppBar>
    <MudMainContent>
        <MudContainer MaxWidth="MaxWidth.Small" Class="mt-8">
            @Body
        </MudContainer>
    </MudMainContent>
</MudLayout>

@code {
    private bool _isDarkMode;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _isDarkMode = await JS.InvokeAsync<bool>("todoApp.getDarkModePreference");
            StateHasChanged();
        }
    }

    private async Task ToggleDarkMode()
    {
        _isDarkMode = !_isDarkMode;
        await JS.InvokeVoidAsync("todoApp.saveDarkModePreference", _isDarkMode);
    }

    public ValueTask DisposeAsync() => ValueTask.CompletedTask;
}
