    private static string FormatCompletedAt(DateTime completedAt)
    {
        var local = completedAt.ToLocalTime();
        var diff = (DateTime.Today - local.Date).Days;
        return diff switch
        {
            0    => $"Completed today at {local:h:mm tt}",
            1    => "Completed yesterday",
            <= 7 => $"Completed {diff} days ago",
            _    => $"Completed {local:MMM d, yyyy}"
        };
    }

    private static string FormatDeletedAt(DateTime deletedAt)
    {
        var local = deletedAt.ToLocalTime();
        var diff = (DateTime.Today - local.Date).Days;
        return diff switch
        {
            0    => $"Deleted today at {local:h:mm tt}",
            1    => "Deleted yesterday",
            <= 7 => $"Deleted {diff} days ago",
            _    => $"Deleted {local:MMM d, yyyy}"
        };
    }

    private static int PurgeDaysRemaining(DateTime deletedAt)
    {
        var elapsedDays = (DateTime.UtcNow.Date - deletedAt.ToUniversalTime().Date).Days;
        return Math.Max(0, PurgeExpiredTrashHandler.RetentionDays - elapsedDays);
    }

    private static string FormatPurgeCountdown(DateTime deletedAt)
    {
        var daysRemaining = PurgeDaysRemaining(deletedAt);
        return daysRemaining switch
        {
            0 => "Purges today",
            1 => "Purges in 1 day",
            _ => $"Purges in {daysRemaining} days"
        };
    }

    private static string FormatDueDateDisplay(DateTime dueDate)
    {
        var diff = (dueDate.Date - DateTime.Today).Days;
        return diff switch
        {
            0    => "Due today",
            1    => "Due tomorrow",
            > 1 and <= 7 => $"Due in {diff} days",
            < 0 and >= -1 => "Overdue by 1 day",
            < -1 => $"Overdue by {-diff} days",
            _    => $"Due {dueDate:MMM d, yyyy}"
        };
    }

    private static DueDateStatus GetDueDateStatus(TodoSummary todo)
    {
        if (!todo.DueDate.HasValue || todo.IsCompleted)
            return DueDateStatus.Future;

        var today = DateTime.Today;
        var dueDate = todo.DueDate.Value.Date;

        if (dueDate < today)
            return DueDateStatus.Overdue;
        if (dueDate == today)
            return DueDateStatus.DueToday;
        return DueDateStatus.Future;
    }

    private static string GetTimeEstimateLabel(TimeEstimate estimate) => estimate switch
    {
        TimeEstimate.FifteenMinutes => "15 min",
        TimeEstimate.ThirtyMinutes  => "30 min",
        TimeEstimate.OneHour        => "1 h",
        TimeEstimate.TwoHours       => "2 h",
        TimeEstimate.FourHours      => "4 h",
        TimeEstimate.OneDay         => "1 day",
        _                           => string.Empty
    };

    private static string FormatEstimatedTime(int minutes)
    {
        if (minutes < 60)
            return $"{minutes} min";
        var hours = minutes / 60;
        var remainder = minutes % 60;
        return remainder == 0 ? $"{hours} h" : $"{hours} h {remainder} min";
    }

    private static int GetHeatmapLevel(int count) => count switch
    {
        0        => 0,
        <= 2     => 1,
        <= 4     => 2,
        _        => 3
    };

    private static string GetHeatmapStyle(int count, bool isToday)
    {
        var bg = count switch
        {
            0    => "var(--mud-palette-action-disabled-background)",
            <= 2 => "#a5d6a7",
            <= 4 => "#4caf50",
            _    => "#1b5e20"
        };
        var border = isToday ? "2px solid var(--mud-palette-primary)" : "2px solid transparent";
        return $"display:inline-block;width:14px;height:14px;border-radius:3px;background:{bg};border:{border};";
    }
