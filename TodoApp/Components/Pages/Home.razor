@page "/"
@using TodoApp.Features.Todos
@using TodoApp.Features.Todos.AddTodo
@using TodoApp.Features.Todos.CompleteTodo
@using TodoApp.Features.Todos.DeleteTodo
@using TodoApp.Features.Todos.BulkOperations
@using TodoApp.Features.Todos.EditTodo
@using TodoApp.Features.Todos.FilterSortTodos
@using TodoApp.Features.Todos.GetTodos
@using TodoApp.Features.Todos.GetTodosStats
@using TodoApp.Features.Todos.ClearCompleted
@using TodoApp.Features.Todos.Export
@using TodoApp.Features.Todos.Import
@using Microsoft.AspNetCore.Components.Forms
@using TodoApp.Features.Todos.PinTodo
@using TodoApp.Features.Todos.UpdateNotes
@using TodoApp.Features.Todos.Subtasks
@using TodoApp.Features.Todos.Tags
@using TodoApp.Features.Lists
@using TodoApp.Features.Todos.ReorderTodos
@using TodoApp.Features.Todos.MoveTodo
@using TodoApp.Features.Todos.QuickAdd
@using TodoApp.Features.Todos.RecurringTodos
@using TodoApp.Features.Todos.UndoRedo
@using TodoApp.Features.Todos.SnoozeTodo
@using TodoApp.Features.Todos.TimeEstimates
@using TodoApp.Features.Todos.FocusMode
@using TodoApp.Features.Todos.DuplicateTodo
@using TodoApp.Features.Todos.ActivityStats
@using TodoApp.Features.Todos.Notes
@using TodoApp.Features.Todos.ColorLabel
@using TodoApp.Features.Todos.SetDueDate
@inject AddSubtaskHandler AddSubtaskHandler
@inject EditSubtaskHandler EditSubtaskHandler
@inject AddTagHandler AddTagHandler
@inject AddTodoHandler AddTodoHandler
@inject BulkOperationsHandler BulkOperationsHandler
@inject CompleteTodoHandler CompleteTodoHandler
@inject DeleteTodoHandler DeleteTodoHandler
@inject EditTodoHandler EditTodoHandler
@inject ClearCompletedHandler ClearCompletedHandler
@inject UpdateNotesHandler UpdateNotesHandler
@inject CsvExportHandler CsvExportHandler
@inject ImportTodosHandler ImportTodosHandler
@inject PinTodoHandler PinTodoHandler
@inject CompleteSubtaskHandler CompleteSubtaskHandler
@inject DeleteSubtaskHandler DeleteSubtaskHandler
@inject GetSubtasksHandler GetSubtasksHandler
@inject GetTodoTagsHandler GetTodoTagsHandler
@inject GetAllTagNamesHandler GetAllTagNamesHandler
@inject GetTodosHandler GetTodosHandler
@inject FilterSortTodosHandler FilterSortTodosHandler
@inject GetTodosStatsHandler GetTodosStatsHandler
@inject RemoveTagHandler RemoveTagHandler
@inject RenameTagHandler RenameTagHandler
@inject CreateListHandler CreateListHandler
@inject CreateRecurringInstanceHandler CreateRecurringInstanceHandler
@inject DeleteListHandler DeleteListHandler
@inject GetListsHandler GetListsHandler
@inject RenameListHandler RenameListHandler
@inject ReorderTodosHandler ReorderTodosHandler
@inject MoveTodoHandler MoveTodoHandler
@inject RestoreTodosHandler RestoreTodosHandler
@inject SnoozeTodoHandler SnoozeTodoHandler
@inject FocusModeHandler FocusModeHandler
@inject DuplicateTodoHandler DuplicateTodoHandler
@inject ActivityStatsHandler ActivityStatsHandler
@inject SetColorLabelHandler SetColorLabelHandler
@inject SetDueDateHandler SetDueDateHandler
@inject ISnackbar Snackbar
@inject IJSRuntime JS
@implements IAsyncDisposable

<PageTitle>My Todo List</PageTitle>

@if (_lists is { Count: > 0 })
{
    <MudCard Elevation="1" Class="mb-4">
        <MudCardContent Class="py-2">
            <div class="d-flex align-center gap-1 flex-wrap list-selector-row">
                @foreach (var list in _lists)
                {
                    var listId = list.Id;
                    @if (_renamingListId == listId)
                    {
                        <MudTextField
                            @bind-Value="_renameListValue"
                            Variant="Variant.Outlined"
                            Margin="Margin.Dense"
                            Style="width: 130px; font-size: 0.875rem;"
                            OnKeyUp="@(async (KeyboardEventArgs e) => await HandleRenameListKeyUp(e, listId))"
                            Class="rename-list-input" />
                    }
                    else
                    {
                        <MudChip T="string"
                                 Variant="@(_activeListId == listId ? Variant.Filled : Variant.Outlined)"
                                 Color="Color.Primary"
                                 OnClick="@(() => HandleSwitchList(listId))"
                                 OnClose="@(list.Id != DeleteListHandler.DefaultListId ? EventCallback.Factory.Create<MudChip<string>>(this, async (MudChip<string> _) => await HandleDeleteList(listId)) : new EventCallback<MudChip<string>>())"
                                 Class="list-chip"
                                 @ondblclick="@(() => HandleStartRenameList(listId, list.Name))">
                            @list.Name
                        </MudChip>
                    }
                }
                @if (_creatingList)
                {
                    <MudTextField
                        @bind-Value="_newListName"
                        Variant="Variant.Outlined"
                        Margin="Margin.Dense"
                        Placeholder="List name..."
                        Style="width: 130px; font-size: 0.875rem;"
                        OnKeyUp="HandleNewListKeyUp"
                        Class="new-list-input" />
                }
                else
                {
                    <MudIconButton
                        Icon="@Icons.Material.Filled.Add"
                        Size="Size.Small"
                        Color="Color.Primary"
                        OnClick="@(() => { _creatingList = true; _newListName = string.Empty; })"
                        title="New list"
                        Class="add-list-btn" />
                }
            </div>
        </MudCardContent>
    </MudCard>
}

<MudCard Elevation="2" Class="mb-6">
    <MudCardContent>
        <div class="d-flex align-center justify-space-between mb-4">
            <MudText Typo="Typo.h6">Add a New Todo</MudText>
            <MudIconButton
                Icon="@Icons.Material.Filled.Keyboard"
                Size="Size.Small"
                Color="Color.Default"
                OnClick="ToggleShortcutsHelp"
                title="Keyboard shortcuts"
                Class="keyboard-shortcuts-btn" />
        </div>
        @if (_showShortcutsHelp)
        {
            <MudPaper Elevation="0" Class="pa-3 mb-4 keyboard-shortcuts-panel" Style="background: var(--mud-palette-background-grey); border-radius: 8px;">
                <MudText Typo="Typo.subtitle2" Class="mb-2">Keyboard Shortcuts</MudText>
                <div class="d-flex flex-column gap-1">
                    <div class="d-flex align-center gap-3">
                        <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Class="shortcut-key">N</MudChip>
                        <MudText Typo="Typo.body2">Focus new todo input</MudText>
                    </div>
                    <div class="d-flex align-center gap-3">
                        <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Class="shortcut-key">/</MudChip>
                        <MudText Typo="Typo.body2">Focus search</MudText>
                    </div>
                    <div class="d-flex align-center gap-3">
                        <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Class="shortcut-key">?</MudChip>
                        <MudText Typo="Typo.body2">Toggle this panel</MudText>
                    </div>
                </div>
                <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mt-2">Shortcuts are inactive when typing in an input.</MudText>
            </MudPaper>
        }
        <MudTextField
            @bind-Value="_newTitle"
            Label="What needs to be done?"
            Variant="Variant.Outlined"
            FullWidth="true"
            Class="mb-3 new-todo-input"
            OnKeyUp="HandleEnterKey"
            Disabled="_isSubmitting" />
        @{
            var hints = NaturalLanguageParser.Parse(_newTitle);
        }
        @if (!string.IsNullOrWhiteSpace(_newTitle) && (hints.Priority.HasValue || hints.DueDate.HasValue))
        {
            <div class="d-flex align-center gap-1 mb-2 quick-add-hint-strip">
                <MudIcon Icon="@Icons.Material.Filled.AutoAwesome" Size="Size.Small" Color="Color.Tertiary" />
                <MudText Typo="Typo.caption" Color="Color.Tertiary" Class="quick-add-hint-text">
                    Quick-add:
                    @if (!string.IsNullOrWhiteSpace(hints.CleanTitle))
                    {
                        <strong>@hints.CleanTitle</strong>
                    }
                    @if (hints.DueDate.HasValue)
                    {
                        <span> · Due @FormatDueDateDisplay(hints.DueDate.Value)</span>
                    }
                    @if (hints.Priority.HasValue)
                    {
                        <span> · @hints.Priority.Value priority</span>
                    }
                </MudText>
            </div>
        }
        <MudSelect
            T="TodoPriority"
            @bind-Value="_newPriority"
            Label="Priority"
            Variant="Variant.Outlined"
            Class="mb-3"
            Disabled="_isSubmitting">
            <MudSelectItem Value="@TodoPriority.None">None</MudSelectItem>
            <MudSelectItem Value="@TodoPriority.Low">Low</MudSelectItem>
            <MudSelectItem Value="@TodoPriority.Medium">Medium</MudSelectItem>
            <MudSelectItem Value="@TodoPriority.High">High</MudSelectItem>
        </MudSelect>
        <MudDatePicker
            @bind-Date="_newDueDate"
            Label="Due date (optional)"
            Variant="Variant.Outlined"
            Class="mb-2"
            Disabled="_isSubmitting"
            Clearable="true" />
        <div class="d-flex gap-2 mb-3 due-date-shortcuts">
            <MudButton
                Size="Size.Small"
                Variant="@(_newDueDate?.Date == DateTime.Today ? Variant.Filled : Variant.Outlined)"
                Color="Color.Secondary"
                OnClick="@(() => SetQuickDueDate(0))"
                Disabled="_isSubmitting"
                Class="due-date-today-btn">Today</MudButton>
            <MudButton
                Size="Size.Small"
                Variant="@(_newDueDate?.Date == DateTime.Today.AddDays(1) ? Variant.Filled : Variant.Outlined)"
                Color="Color.Secondary"
                OnClick="@(() => SetQuickDueDate(1))"
                Disabled="_isSubmitting"
                Class="due-date-tomorrow-btn">Tomorrow</MudButton>
            <MudButton
                Size="Size.Small"
                Variant="@(_newDueDate?.Date == DateTime.Today.AddDays(7) ? Variant.Filled : Variant.Outlined)"
                Color="Color.Secondary"
                OnClick="@(() => SetQuickDueDate(7))"
                Disabled="_isSubmitting"
                Class="due-date-next-week-btn">Next week</MudButton>
        </div>
        <MudSelect
            T="RecurrenceRule"
            @bind-Value="_newRecurrence"
            Label="Repeats"
            Variant="Variant.Outlined"
            Class="mb-3 recurrence-select"
            Disabled="_isSubmitting">
            <MudSelectItem Value="@RecurrenceRule.None">Does not repeat</MudSelectItem>
            <MudSelectItem Value="@RecurrenceRule.Daily">Daily</MudSelectItem>
            <MudSelectItem Value="@RecurrenceRule.Weekly">Weekly</MudSelectItem>
            <MudSelectItem Value="@RecurrenceRule.Monthly">Monthly</MudSelectItem>
        </MudSelect>
        <MudSelect
            T="TimeEstimate"
            @bind-Value="_newTimeEstimate"
            Label="Time estimate"
            Variant="Variant.Outlined"
            Class="mb-3 time-estimate-select"
            Disabled="_isSubmitting">
            <MudSelectItem Value="@TimeEstimate.None">No estimate</MudSelectItem>
            <MudSelectItem Value="@TimeEstimate.FifteenMinutes">15 min</MudSelectItem>
            <MudSelectItem Value="@TimeEstimate.ThirtyMinutes">30 min</MudSelectItem>
            <MudSelectItem Value="@TimeEstimate.OneHour">1 hour</MudSelectItem>
            <MudSelectItem Value="@TimeEstimate.TwoHours">2 hours</MudSelectItem>
            <MudSelectItem Value="@TimeEstimate.FourHours">4 hours</MudSelectItem>
            <MudSelectItem Value="@TimeEstimate.OneDay">1 day</MudSelectItem>
        </MudSelect>
        <MudButton
            Variant="Variant.Filled"
            Color="Color.Primary"
            OnClick="HandleAddTodo"
            Disabled="_isSubmitting"
            FullWidth="true"
            Size="Size.Large"
            Class="add-todo-btn">
            @if (_isSubmitting)
            {
                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
            }
            Add Todo
        </MudButton>
        @if (!string.IsNullOrEmpty(_errorMessage))
        {
            <MudAlert Severity="Severity.Error" Class="mt-3" Dense="true">@_errorMessage</MudAlert>
        }
    </MudCardContent>
</MudCard>

@if (_todos is { Count: > 0 })
{
    var stats = GetTodosStatsHandler.Handle(_todos);
    <MudPaper Elevation="1" Class="pa-4 mb-4 stats-panel">
        <div class="d-flex align-center gap-2 mb-3 flex-wrap">
            <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Color="Color.Default" Class="stats-total">
                Total: @stats.Total
            </MudChip>
            <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Color="Color.Info" Class="stats-active">
                Active: @stats.Active
            </MudChip>
            <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Color="Color.Success" Class="stats-completed">
                Completed: @stats.Completed
            </MudChip>
            @if (stats.Overdue > 0)
            {
                <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Color="Color.Error" Class="stats-overdue">
                    Overdue: @stats.Overdue
                </MudChip>
            }
            @if (stats.TotalEstimatedMinutes > 0)
            {
                <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Color="Color.Tertiary" Class="stats-estimated-time">
                    ~@FormatEstimatedTime(stats.TotalEstimatedMinutes) remaining
                </MudChip>
            }
        </div>
        <div class="d-flex align-center gap-3">
            <MudProgressLinear
                Value="@stats.CompletionPercentage"
                Color="Color.Success"
                Rounded="true"
                Size="Size.Small"
                Class="flex-grow-1 stats-progress" />
            <MudText Typo="Typo.caption" Color="Color.Secondary" Class="stats-percentage">@stats.CompletionPercentage%</MudText>
        </div>
        @if (_activityStats is not null && (_activityStats.CurrentStreak > 0 || _activityStats.CompletedToday > 0 || _activityStats.CompletedThisWeek > 0))
        {
            <div class="d-flex align-center gap-2 mt-3 flex-wrap activity-stats-row">
                @if (_activityStats.CurrentStreak > 0)
                {
                    <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Color="Color.Warning" Class="streak-chip"
                             title="@($"Longest streak: {_activityStats.LongestStreak} day{(_activityStats.LongestStreak == 1 ? "" : "s")}")">
                        🔥 @_activityStats.CurrentStreak day streak
                    </MudChip>
                }
                @if (_activityStats.LongestStreak > _activityStats.CurrentStreak && _activityStats.LongestStreak > 0)
                {
                    <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Color="Color.Default" Class="longest-streak-chip">
                        Best: @_activityStats.LongestStreak days
                    </MudChip>
                }
                @if (_activityStats.CompletedToday > 0)
                {
                    <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Color="Color.Success" Class="completed-today-chip">
                        Today: @_activityStats.CompletedToday done
                    </MudChip>
                }
                <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Color="Color.Info" Class="completed-week-chip">
                    This week: @_activityStats.CompletedThisWeek done
                </MudChip>
            </div>
        }
        @if (_activityStats is not null)
        {
            <div class="d-flex align-center gap-1 mt-3 activity-heatmap-row" title="Past 14 days — daily completions">
                <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mr-1" Style="white-space:nowrap;">14 days:</MudText>
                @foreach (var day in _activityStats.DailyActivity)
                {
                    var isToday = day.Date == DateOnly.FromDateTime(DateTime.Today);
                    var tooltip = $"{day.Date:MMM d}: {day.Count} completed";
                    var cssClass = $"heatmap-day heatmap-day-{GetHeatmapLevel(day.Count)}{(isToday ? " heatmap-today" : "")}";
                    <span class="@cssClass"
                          title="@tooltip"
                          style="@GetHeatmapStyle(day.Count, isToday)"></span>
                }
            </div>
        }
        @if (stats.Completed > 0)
        {
            <div class="d-flex justify-end mt-2">
                <MudButton
                    Variant="Variant.Text"
                    Color="Color.Error"
                    Size="Size.Small"
                    OnClick="HandleClearCompleted"
                    Class="clear-completed-btn">
                    Clear completed
                </MudButton>
            </div>
        }
    </MudPaper>
}

@if (_todos is null)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
}
else if (_todos.Count == 0)
{
    <MudPaper Elevation="1" Class="pa-8 d-flex justify-center align-center">
        <MudText Typo="Typo.body1" Color="Color.Secondary">No todos yet — add one above!</MudText>
    </MudPaper>
}
else
{
    <MudCard Elevation="1" Class="mb-4">
        <MudCardContent Class="pb-3">
            <MudTextField
                @bind-Value="_searchQuery"
                Label="Search todos..."
                Variant="Variant.Outlined"
                Adornment="Adornment.Start"
                AdornmentIcon="@Icons.Material.Filled.Search"
                Clearable="true"
                Immediate="true"
                Class="mb-2 todo-search-field" />
            @if (IsGlobalSearch)
            {
                <div class="d-flex align-center gap-1 mb-2 search-all-lists-hint">
                    <MudIcon Icon="@Icons.Material.Filled.Layers" Size="Size.Small" Color="Color.Info" />
                    <MudText Typo="Typo.caption" Color="Color.Info">Showing results across all lists</MudText>
                </div>
            }
            <div class="d-flex align-center gap-2 flex-wrap justify-space-between">
                <div class="d-flex align-center gap-2 flex-wrap">
                    <MudButtonGroup Variant="Variant.Outlined" Size="Size.Small">
                        <MudButton
                            Color="Color.Primary"
                            Variant="@(_statusFilter == TodoStatusFilter.All ? Variant.Filled : Variant.Outlined)"
                            OnClick="@(() => _statusFilter = TodoStatusFilter.All)">All</MudButton>
                        <MudButton
                            Color="Color.Primary"
                            Variant="@(_statusFilter == TodoStatusFilter.Active ? Variant.Filled : Variant.Outlined)"
                            OnClick="@(() => _statusFilter = TodoStatusFilter.Active)">Active</MudButton>
                        <MudButton
                            Color="Color.Primary"
                            Variant="@(_statusFilter == TodoStatusFilter.Completed ? Variant.Filled : Variant.Outlined)"
                            OnClick="@(() => _statusFilter = TodoStatusFilter.Completed)">Completed</MudButton>
                    </MudButtonGroup>
                    <MudButton
                        Variant="@(_isSelectMode ? Variant.Filled : Variant.Outlined)"
                        Color="@(_isSelectMode ? Color.Warning : Color.Default)"
                        Size="Size.Small"
                        OnClick="HandleToggleSelectMode"
                        Class="select-mode-btn">
                        @(_isSelectMode ? "Cancel" : "Select")
                    </MudButton>
                    <MudButton
                        Variant="@(_isFocusMode ? Variant.Filled : Variant.Outlined)"
                        Color="@(_isFocusMode ? Color.Success : Color.Default)"
                        Size="Size.Small"
                        StartIcon="@Icons.Material.Filled.FilterCenterFocus"
                        OnClick="HandleToggleFocusMode"
                        title="Focus mode — show only urgent and important todos"
                        Class="focus-mode-btn">
                        Focus
                    </MudButton>
                </div>
                <div class="d-flex align-center gap-1">
                    <MudSelect
                        T="TodoSortOrder"
                        @bind-Value="_sortOrder"
                        Label="Sort"
                        Variant="Variant.Outlined"
                        Dense="true"
                        Style="min-width: 150px;">
                        <MudSelectItem Value="@TodoSortOrder.Newest">Newest first</MudSelectItem>
                        <MudSelectItem Value="@TodoSortOrder.Oldest">Oldest first</MudSelectItem>
                        <MudSelectItem Value="@TodoSortOrder.DueDateAsc">Due date</MudSelectItem>
                        <MudSelectItem Value="@TodoSortOrder.PriorityDesc">Priority</MudSelectItem>
                        <MudSelectItem Value="@TodoSortOrder.Manual">Custom order</MudSelectItem>
                    </MudSelect>
                    <MudTooltip Text="Export to CSV">
                        <MudIconButton
                            Icon="@Icons.Material.Filled.FileDownload"
                            Size="Size.Small"
                            Color="Color.Default"
                            OnClick="HandleExportCsv"
                            title="Export to CSV"
                            Class="export-csv-btn" />
                    </MudTooltip>
                    <MudTooltip Text="Import from CSV">
                        <MudIconButton
                            Icon="@Icons.Material.Filled.FileUpload"
                            Size="Size.Small"
                            Color="Color.Default"
                            OnClick="HandleImportClick"
                            title="Import from CSV"
                            Class="import-csv-btn" />
                    </MudTooltip>
                    <InputFile id="csv-import-input" OnChange="HandleFileSelected" accept=".csv" style="display:none;" />
                </div>
            </div>
            <div class="d-flex align-center gap-1 flex-wrap mt-3 priority-filter-row">
                <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mr-1">Priority:</MudText>
                <MudChip T="string" Size="Size.Small"
                         Variant="@(_priorityFilter is null ? Variant.Filled : Variant.Outlined)"
                         Color="Color.Secondary"
                         OnClick="@(() => _priorityFilter = null)"
                         Class="priority-filter-all">All</MudChip>
                @foreach (var p in new[] { TodoPriority.High, TodoPriority.Medium, TodoPriority.Low, TodoPriority.None })
                {
                    var pri = p;
                    <MudChip T="string" Size="Size.Small"
                             Variant="@(_priorityFilter == pri ? Variant.Filled : Variant.Outlined)"
                             Color="@GetPriorityColor(pri)"
                             OnClick="@(() => _priorityFilter = pri)"
                             Class="@($"priority-filter-{pri.ToString().ToLower()}")">
                        @(pri == TodoPriority.None ? "None" : pri.ToString())
                    </MudChip>
                }
            </div>
            <div class="d-flex align-center gap-1 flex-wrap mt-2 date-filter-row">
                <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mr-1">Due:</MudText>
                <MudChip T="string" Size="Size.Small"
                         Variant="@(_dateFilter == TodoDateFilter.None ? Variant.Filled : Variant.Outlined)"
                         Color="Color.Secondary"
                         OnClick="@(() => _dateFilter = TodoDateFilter.None)"
                         Class="date-filter-all">Any</MudChip>
                <MudChip T="string" Size="Size.Small"
                         Variant="@(_dateFilter == TodoDateFilter.Overdue ? Variant.Filled : Variant.Outlined)"
                         Color="Color.Error"
                         OnClick="@(() => _dateFilter = TodoDateFilter.Overdue)"
                         Class="date-filter-overdue">Overdue</MudChip>
                <MudChip T="string" Size="Size.Small"
                         Variant="@(_dateFilter == TodoDateFilter.DueToday ? Variant.Filled : Variant.Outlined)"
                         Color="Color.Warning"
                         OnClick="@(() => _dateFilter = TodoDateFilter.DueToday)"
                         Class="date-filter-today">Today</MudChip>
                <MudChip T="string" Size="Size.Small"
                         Variant="@(_dateFilter == TodoDateFilter.DueThisWeek ? Variant.Filled : Variant.Outlined)"
                         Color="Color.Info"
                         OnClick="@(() => _dateFilter = TodoDateFilter.DueThisWeek)"
                         Class="date-filter-week">This week</MudChip>
            </div>
            @if (AllTagNames.Count > 0)
            {
                <div class="d-flex align-center gap-1 flex-wrap mt-2 tag-filter-row">
                    <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mr-1">Tag:</MudText>
                    <MudChip T="string"
                             Size="Size.Small"
                             Variant="@(_tagFilter is null ? Variant.Filled : Variant.Outlined)"
                             Color="Color.Secondary"
                             OnClick="@(() => _tagFilter = null)"
                             Class="tag-filter-all">All</MudChip>
                    @foreach (var name in AllTagNames)
                    {
                        var tagName = name;
                        @if (_renamingTagName == tagName)
                        {
                            var renamingTag = tagName;
                            <MudTextField
                                @bind-Value="_renameTagValue"
                                Variant="Variant.Outlined"
                                Margin="Margin.Dense"
                                Style="width: 100px; font-size: 0.75rem;"
                                OnKeyUp="@(async (KeyboardEventArgs e) => await HandleRenameTagKeyUp(e, renamingTag))"
                                Class="rename-tag-input" />
                        }
                        else
                        {
                            <MudChip T="string"
                                     Size="Size.Small"
                                     Variant="@(_tagFilter == tagName ? Variant.Filled : Variant.Outlined)"
                                     Color="Color.Secondary"
                                     OnClick="@(() => _tagFilter = tagName)"
                                     Class="tag-filter-chip"
                                     @ondblclick="@(() => HandleStartRenameTag(tagName))">@tagName</MudChip>
                        }
                    }
                </div>
            }
            <div class="d-flex align-center gap-1 flex-wrap mt-2 color-filter-row">
                <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mr-1">Color:</MudText>
                <span class="color-filter-dot color-filter-all @(_colorFilter is null ? "color-dot-selected" : "")"
                      style="display:inline-block;width:18px;height:18px;border-radius:50%;background:#9e9e9e;border:2px solid @(_colorFilter is null ? "var(--mud-palette-primary)" : "transparent");cursor:pointer;vertical-align:middle;"
                      title="Any color"
                      @onclick="@(() => _colorFilter = null)"></span>
                @foreach (var cl in new[] { TodoColorLabel.Red, TodoColorLabel.Orange, TodoColorLabel.Yellow, TodoColorLabel.Green, TodoColorLabel.Blue, TodoColorLabel.Purple })
                {
                    var label = cl;
                    <span class="color-filter-dot color-filter-@(label.ToString().ToLower())"
                          style="display:inline-block;width:18px;height:18px;border-radius:50%;background:@GetColorCss(label);border:2px solid @(_colorFilter == label ? "var(--mud-palette-primary)" : "transparent");cursor:pointer;vertical-align:middle;"
                          title="@label"
                          @onclick="@(() => _colorFilter = label)"></span>
                }
            </div>
        </MudCardContent>
    </MudCard>

    @if (_isFocusMode)
    {
        var focusTodos = FocusModeHandler.Handle(_todos!.Where(t => t.ListId == _activeListId).ToList());
        var focusMinutes = focusTodos
            .Where(t => t.TimeEstimate != TimeEstimate.None)
            .Sum(t => (int)t.TimeEstimate);
        <MudPaper Elevation="0" Class="pa-3 mb-3 d-flex align-center gap-2 focus-mode-banner"
                  Style="background: var(--mud-palette-success-lighten); border: 1px solid var(--mud-palette-success); border-radius: 8px;">
            <MudIcon Icon="@Icons.Material.Filled.FilterCenterFocus" Color="Color.Success" Size="Size.Small" />
            <MudText Typo="Typo.body2" Color="Color.Success">
                <strong>Focus mode</strong> — @(focusTodos.Count == 0 ? "nothing urgent right now" : $"{focusTodos.Count} todo{(focusTodos.Count == 1 ? "" : "s")} need attention")
                @if (focusMinutes > 0)
                {
                    <span> · ~@FormatEstimatedTime(focusMinutes)</span>
                }
            </MudText>
            <MudSpacer />
            <MudButton Variant="Variant.Text" Color="Color.Success" Size="Size.Small" OnClick="HandleToggleFocusMode" Class="focus-mode-exit-btn">Exit focus</MudButton>
        </MudPaper>
    }

    @if (_isSelectMode && _selectedIds.Count > 0)
    {
        <MudPaper Elevation="1" Class="pa-3 mb-3 d-flex align-center gap-3 flex-wrap bulk-action-bar">
            <MudText Typo="Typo.body2">@_selectedIds.Count selected</MudText>
            <MudSpacer />
            <MudButton
                Variant="Variant.Filled"
                Color="Color.Primary"
                Size="Size.Small"
                OnClick="HandleBulkComplete"
                Class="bulk-complete-btn">
                Mark Complete
            </MudButton>
            @if (_lists is { Count: > 1 })
            {
                <div class="d-flex align-center gap-1 bulk-move-row">
                    <MudSelect
                        T="int"
                        @bind-Value="_bulkMoveTargetListId"
                        Label="Move to list"
                        Variant="Variant.Outlined"
                        Dense="true"
                        Style="min-width: 130px; font-size: 0.8rem;"
                        Class="bulk-move-select">
                        @foreach (var list in _lists.Where(l => l.Id != _activeListId))
                        {
                            <MudSelectItem Value="@list.Id">@list.Name</MudSelectItem>
                        }
                    </MudSelect>
                    <MudButton
                        Variant="Variant.Filled"
                        Color="Color.Info"
                        Size="Size.Small"
                        Disabled="@(_bulkMoveTargetListId == 0)"
                        OnClick="HandleBulkMove"
                        Class="bulk-move-btn">
                        Move
                    </MudButton>
                </div>
            }
            <MudButton
                Variant="Variant.Filled"
                Color="Color.Error"
                Size="Size.Small"
                OnClick="HandleBulkDelete"
                Class="bulk-delete-btn">
                Delete
            </MudButton>
        </MudPaper>
    }

    @if (DisplayedTodos.Count == 0)
    {
        <MudPaper Elevation="1" Class="pa-8 d-flex justify-center align-center">
            <MudText Typo="Typo.body1" Color="Color.Secondary">No todos match your filters.</MudText>
        </MudPaper>
    }
    else
    {
        <MudPaper Elevation="2">
            <MudList T="TodoSummary" Dense="false">
                @foreach (var todo in DisplayedTodos)
                {
                    var todoId = todo.Id;
                    <div draggable="@(_sortOrder == TodoSortOrder.Manual ? "true" : "false")"
                         @ondragstart="@(() => _draggingId = todoId)"
                         @ondragend="@(() => { _draggingId = null; _dragOverId = null; })"
                         @ondragover:preventDefault
                         @ondragover="@(() => _dragOverId = todoId)"
                         @ondrop="@(async () => await HandleDrop(todoId))"
                         class="@(_dragOverId == todo.Id && _sortOrder == TodoSortOrder.Manual ? "drag-over" : "")"
                         style="@(todo.ColorLabel != TodoColorLabel.None ? $"border-left: 4px solid {GetColorCss(todo.ColorLabel)};" : "")"
                         >
                    <MudListItem>
                        <div class="d-flex align-center gap-3 flex-grow-1">
                            @if (_sortOrder == TodoSortOrder.Manual)
                            {
                                <MudIcon Icon="@Icons.Material.Filled.DragIndicator"
                                         Size="Size.Small"
                                         Color="Color.Default"
                                         Style="cursor: grab; opacity: 0.5;"
                                         Class="drag-handle" />
                            }
                            @if (_isSelectMode)
                            {
                                <MudCheckBox
                                    Value="@_selectedIds.Contains(todo.Id)"
                                    ValueChanged="@((bool selected) => HandleToggleTodoSelection(todo.Id, selected))"
                                    Color="Color.Secondary"
                                    Class="todo-select-checkbox" />
                            }
                            <MudCheckBox
                                Value="@todo.IsCompleted"
                                ValueChanged="@(async (bool _) => await HandleToggleComplete(todo.Id))"
                                Color="Color.Primary" />
                            <div class="flex-grow-1">
                                @if (_editingTodoId == todo.Id)
                                {
                                    <div class="d-flex flex-column gap-2 todo-edit-form">
                                        <div class="d-flex align-center gap-2">
                                            <MudTextField
                                                @bind-Value="_editValue"
                                                Variant="Variant.Outlined"
                                                FullWidth="true"
                                                OnKeyUp="HandleEditKeyUp"
                                                Class="todo-edit-field" />
                                            <MudIconButton
                                                Icon="@Icons.Material.Filled.Check"
                                                Color="Color.Success"
                                                Size="Size.Small"
                                                OnClick="HandleSaveEdit"
                                                title="Save"
                                                Class="todo-edit-save-btn" />
                                            <MudIconButton
                                                Icon="@Icons.Material.Filled.Close"
                                                Color="Color.Default"
                                                Size="Size.Small"
                                                OnClick="HandleCancelEdit"
                                                title="Cancel"
                                                Class="todo-edit-cancel-btn" />
                                        </div>
                                        <div class="d-flex align-center gap-2 flex-wrap">
                                            <MudSelect
                                                T="TodoPriority"
                                                @bind-Value="_editPriority"
                                                Label="Priority"
                                                Variant="Variant.Outlined"
                                                Dense="true"
                                                Style="min-width: 130px;"
                                                Class="todo-edit-priority">
                                                <MudSelectItem Value="@TodoPriority.None">None</MudSelectItem>
                                                <MudSelectItem Value="@TodoPriority.Low">Low</MudSelectItem>
                                                <MudSelectItem Value="@TodoPriority.Medium">Medium</MudSelectItem>
                                                <MudSelectItem Value="@TodoPriority.High">High</MudSelectItem>
                                            </MudSelect>
                                            <MudDatePicker
                                                @bind-Date="_editDueDate"
                                                Label="Due date"
                                                Variant="Variant.Outlined"
                                                Clearable="true"
                                                Style="min-width: 160px;"
                                                Class="todo-edit-due-date" />
                                            <MudSelect
                                                T="TimeEstimate"
                                                @bind-Value="_editTimeEstimate"
                                                Label="Time estimate"
                                                Variant="Variant.Outlined"
                                                Dense="true"
                                                Style="min-width: 130px;"
                                                Class="todo-edit-time-estimate">
                                                <MudSelectItem Value="@TimeEstimate.None">No estimate</MudSelectItem>
                                                <MudSelectItem Value="@TimeEstimate.FifteenMinutes">15 min</MudSelectItem>
                                                <MudSelectItem Value="@TimeEstimate.ThirtyMinutes">30 min</MudSelectItem>
                                                <MudSelectItem Value="@TimeEstimate.OneHour">1 hour</MudSelectItem>
                                                <MudSelectItem Value="@TimeEstimate.TwoHours">2 hours</MudSelectItem>
                                                <MudSelectItem Value="@TimeEstimate.FourHours">4 hours</MudSelectItem>
                                                <MudSelectItem Value="@TimeEstimate.OneDay">1 day</MudSelectItem>
                                            </MudSelect>
                                        </div>
                                    </div>
                                }
                                else
                                {
                                    <div class="d-flex align-center gap-2 mb-1">
                                        <MudText Typo="Typo.body1"
                                            Style="@(todo.IsCompleted ? "text-decoration: line-through; opacity: 0.5;" : "")">
                                            @todo.Title
                                        </MudText>
                                        @if (todo.Priority != TodoPriority.None)
                                        {
                                            <MudChip T="string" Size="Size.Small" Color="@GetPriorityColor(todo.Priority)" Variant="Variant.Filled">
                                                @todo.Priority.ToString()
                                            </MudChip>
                                        }
                                        @if (todo.Recurrence != RecurrenceRule.None)
                                        {
                                            <MudChip T="string" Size="Size.Small" Color="Color.Tertiary" Variant="Variant.Outlined" Class="recurrence-badge">
                                                @GetRecurrenceLabel(todo.Recurrence)
                                            </MudChip>
                                        }
                                        @if (todo.TimeEstimate != TimeEstimate.None)
                                        {
                                            <MudChip T="string" Size="Size.Small" Color="Color.Default" Variant="Variant.Outlined" Class="time-estimate-badge">
                                                ~@GetTimeEstimateLabel(todo.TimeEstimate)
                                            </MudChip>
                                        }
                                        @if (IsGlobalSearch && todo.ListId != _activeListId)
                                        {
                                            var listName = _lists?.FirstOrDefault(l => l.Id == todo.ListId)?.Name;
                                            @if (listName is not null)
                                            {
                                                <MudChip T="string" Size="Size.Small" Color="Color.Info" Variant="Variant.Outlined" Class="search-result-list-badge">@listName</MudChip>
                                            }
                                        }
                                        <MudIconButton
                                            Icon="@Icons.Material.Filled.Edit"
                                            Color="Color.Default"
                                            Size="Size.Small"
                                            OnClick="@(() => HandleStartEdit(todo.Id, todo.Title, todo.Priority, todo.DueDate, todo.TimeEstimate))"
                                            title="Edit"
                                            Class="todo-edit-btn" />
                                    </div>
                                }
                                <MudText Typo="Typo.caption" Color="Color.Secondary">
                                    Added @todo.CreatedAt.ToLocalTime().ToString("MMM d, yyyy h:mm tt")
                                </MudText>
                                @if (todo.IsCompleted && todo.CompletedAt.HasValue)
                                {
                                    <MudText Typo="Typo.caption" Color="Color.Success" Class="completed-at-text">
                                        ✓ @FormatCompletedAt(todo.CompletedAt.Value)
                                    </MudText>
                                }
                                @{
                                    var quickDateTodoId = todo.Id;
                                }
                                @if (_settingDueDateForTodoId == todo.Id)
                                {
                                    <div class="mt-1 quick-due-date-editor">
                                        <MudDatePicker
                                            @bind-Date="_quickDueDateValue"
                                            Label="Due date"
                                            Variant="Variant.Outlined"
                                            Clearable="true"
                                            Style="max-width: 200px;"
                                            Class="quick-due-date-picker" />
                                        <div class="d-flex gap-1 mt-1 align-center">
                                            <MudButton
                                                Size="Size.Small"
                                                Variant="Variant.Filled"
                                                Color="Color.Primary"
                                                OnClick="@(async () => await HandleSaveQuickDueDate(quickDateTodoId))"
                                                Class="quick-date-save-btn">Save</MudButton>
                                            @if (todo.DueDate.HasValue)
                                            {
                                                <MudButton
                                                    Size="Size.Small"
                                                    Variant="Variant.Outlined"
                                                    Color="Color.Error"
                                                    OnClick="@(async () => await HandleClearQuickDueDate(quickDateTodoId))"
                                                    Class="quick-date-clear-btn">Remove date</MudButton>
                                            }
                                            <MudButton
                                                Size="Size.Small"
                                                Variant="Variant.Text"
                                                Color="Color.Default"
                                                OnClick="@(() => _settingDueDateForTodoId = null)"
                                                Class="quick-date-cancel-btn">Cancel</MudButton>
                                        </div>
                                    </div>
                                }
                                else if (todo.DueDate.HasValue)
                                {
                                    var dueDateStatus = GetDueDateStatus(todo);
                                    <div class="d-flex align-center gap-1 mt-1 due-date-display"
                                         style="cursor:pointer;"
                                         title="Click to change due date"
                                         @onclick="@(() => HandleStartQuickDueDate(todo.Id, todo.DueDate))">
                                        @if (dueDateStatus == DueDateStatus.Overdue)
                                        {
                                            <MudIcon Icon="@Icons.Material.Filled.Warning" Size="Size.Small" Color="Color.Error" />
                                            <MudText Typo="Typo.caption" Color="Color.Error" Class="due-date-text">
                                                @FormatDueDateDisplay(todo.DueDate.Value)
                                            </MudText>
                                        }
                                        else if (dueDateStatus == DueDateStatus.DueToday)
                                        {
                                            <MudIcon Icon="@Icons.Material.Filled.Schedule" Size="Size.Small" Color="Color.Warning" />
                                            <MudText Typo="Typo.caption" Color="Color.Warning" Class="due-date-text">
                                                @FormatDueDateDisplay(todo.DueDate.Value)
                                            </MudText>
                                        }
                                        else
                                        {
                                            <MudText Typo="Typo.caption" Color="Color.Secondary" Class="due-date-text">
                                                @FormatDueDateDisplay(todo.DueDate.Value)
                                            </MudText>
                                        }
                                    </div>
                                }
                                else if (!todo.IsCompleted)
                                {
                                    <MudButton
                                        Size="Size.Small"
                                        Variant="Variant.Text"
                                        Color="Color.Secondary"
                                        StartIcon="@Icons.Material.Outlined.CalendarToday"
                                        OnClick="@(() => HandleStartQuickDueDate(todo.Id, null))"
                                        Class="quick-date-set-btn">Set date</MudButton>
                                }
                                @if (_editingNotesForTodoId == todo.Id)
                                {
                                    var currentTodoId = todo.Id;
                                    <div class="mt-2 todo-notes-editor">
                                        <MudTextField
                                            @bind-Value="_notesValue"
                                            Label="Notes"
                                            Variant="Variant.Outlined"
                                            Lines="3"
                                            FullWidth="true"
                                            Class="todo-notes-input" />
                                        <div class="d-flex align-center gap-2 mt-1">
                                            <MudButton
                                                Variant="Variant.Filled"
                                                Color="Color.Primary"
                                                Size="Size.Small"
                                                OnClick="@(async () => await HandleSaveNotes(currentTodoId))"
                                                Class="todo-notes-save-btn">Save</MudButton>
                                            <MudButton
                                                Variant="Variant.Text"
                                                Color="Color.Default"
                                                Size="Size.Small"
                                                OnClick="HandleCancelNotes"
                                                Class="todo-notes-cancel-btn">Cancel</MudButton>
                                            <MudText Typo="Typo.caption" Color="Color.Tertiary" Class="notes-markdown-hint">Markdown supported</MudText>
                                        </div>
                                    </div>
                                }
                                else if (!string.IsNullOrEmpty(todo.Notes))
                                {
                                    <div class="mt-1 todo-notes-display mud-typography mud-typography-caption"
                                         style="cursor:pointer; color: var(--mud-palette-text-secondary);"
                                         @onclick="@(() => HandleStartEditNotes(todo.Id, todo.Notes!))">
                                        @((MarkupString)MarkdownRenderer.Render(todo.Notes))
                                    </div>
                                }
                                <div class="d-flex align-center gap-1 mt-1 flex-wrap todo-tags-row">
                                    @foreach (var tag in _todoTags.GetValueOrDefault(todo.Id, []))
                                    {
                                        var tagId = tag.Id;
                                        <MudChip T="string"
                                                 Size="Size.Small"
                                                 Color="Color.Secondary"
                                                 Variant="Variant.Outlined"
                                                 OnClose="@(async (MudChip<string> _) => await HandleRemoveTag(tagId))"
                                                 Class="todo-tag-chip">
                                            @tag.Name
                                        </MudChip>
                                    }
                                    @if (_addingTagForTodoId == todo.Id)
                                    {
                                        var currentTodoId = todo.Id;
                                        <div style="position:relative;">
                                            <MudTextField
                                                @bind-Value="_newTagInput"
                                                Variant="Variant.Outlined"
                                                Margin="Margin.Dense"
                                                Style="width: 110px; font-size: 0.75rem;"
                                                Immediate="true"
                                                OnKeyUp="@(async (KeyboardEventArgs e) => await HandleTagInputKeyUp(e, currentTodoId))"
                                                Class="todo-tag-input" />
                                            @{
                                                var suggestions = GetTagSuggestions(currentTodoId);
                                            }
                                            @if (suggestions.Count > 0)
                                            {
                                                <div class="tag-autocomplete-dropdown"
                                                     style="position:absolute;top:100%;left:0;min-width:110px;background:var(--mud-palette-surface);border:1px solid var(--mud-palette-divider);border-radius:4px;z-index:1000;box-shadow:0 2px 6px rgba(0,0,0,0.15);">
                                                    @foreach (var s in suggestions)
                                                    {
                                                        var suggestion = s;
                                                        <div class="tag-suggestion-item"
                                                             style="padding:4px 10px;cursor:pointer;font-size:0.75rem;white-space:nowrap;"
                                                             @onclick="@(async () => await HandleSelectTagSuggestion(currentTodoId, suggestion))">
                                                            @suggestion
                                                        </div>
                                                    }
                                                </div>
                                            }
                                        </div>
                                    }
                                    else
                                    {
                                        var currentTodoId = todo.Id;
                                        <MudIconButton
                                            Icon="@Icons.Material.Filled.LocalOffer"
                                            Size="Size.Small"
                                            Color="Color.Secondary"
                                            OnClick="@(() => HandleStartAddTag(currentTodoId))"
                                            title="Add tag"
                                            Class="add-tag-btn" />
                                    }
                                </div>
                                @{
                                    var todoSubtasks = _subtasks.GetValueOrDefault(todo.Id, []);
                                    var completedSubtasks = todoSubtasks.Count(s => s.IsCompleted);
                                    var isExpanded = _expandedSubtasksForTodoId == todo.Id;
                                }
                                <div class="mt-1 subtasks-section">
                                    <MudButton
                                        Size="Size.Small"
                                        Variant="Variant.Text"
                                        Color="@(todoSubtasks.Count > 0 ? Color.Primary : Color.Secondary)"
                                        StartIcon="@(isExpanded ? Icons.Material.Filled.ExpandLess : Icons.Material.Filled.ChevronRight)"
                                        OnClick="@(() => ToggleSubtasksExpanded(todo.Id))"
                                        Class="subtasks-toggle-btn">
                                        @if (todoSubtasks.Count > 0)
                                        {
                                            @($"{completedSubtasks}/{todoSubtasks.Count} subtask{(todoSubtasks.Count == 1 ? "" : "s")}")
                                        }
                                        else
                                        {
                                            @("Subtasks")
                                        }
                                    </MudButton>
                                    @if (isExpanded)
                                    {
                                        <div class="ps-3 subtasks-list">
                                            @foreach (var subtask in todoSubtasks)
                                            {
                                                var stId = subtask.Id;
                                                <div class="d-flex align-center gap-1">
                                                    <MudCheckBox
                                                        Value="@subtask.IsCompleted"
                                                        ValueChanged="@(async (bool _) => await HandleToggleSubtask(stId))"
                                                        Color="Color.Primary"
                                                        Size="Size.Small"
                                                        Class="subtask-checkbox" />
                                                    @if (_editingSubtaskId == subtask.Id)
                                                    {
                                                        var editStId = subtask.Id;
                                                        <MudTextField
                                                            @bind-Value="_editSubtaskTitle"
                                                            Variant="Variant.Outlined"
                                                            Margin="Margin.Dense"
                                                            FullWidth="true"
                                                            OnKeyUp="@(async (KeyboardEventArgs e) => await HandleSubtaskEditKeyUp(e, editStId))"
                                                            Class="subtask-edit-input" />
                                                        <MudIconButton
                                                            Icon="@Icons.Material.Filled.Check"
                                                            Color="Color.Success"
                                                            Size="Size.Small"
                                                            OnClick="@(async () => await HandleSaveSubtaskEdit(editStId))"
                                                            title="Save"
                                                            Class="subtask-edit-save-btn" />
                                                        <MudIconButton
                                                            Icon="@Icons.Material.Filled.Close"
                                                            Color="Color.Default"
                                                            Size="Size.Small"
                                                            OnClick="@(() => _editingSubtaskId = null)"
                                                            title="Cancel"
                                                            Class="subtask-edit-cancel-btn" />
                                                    }
                                                    else
                                                    {
                                                        var editStId = subtask.Id;
                                                        <MudText Typo="Typo.body2" Class="flex-grow-1"
                                                            Style="@(subtask.IsCompleted ? "text-decoration: line-through; opacity: 0.5;" : "")"
                                                            @ondblclick="@(() => HandleStartEditSubtask(editStId, subtask.Title))">
                                                            @subtask.Title
                                                        </MudText>
                                                        <MudIconButton
                                                            Icon="@Icons.Material.Filled.Edit"
                                                            Color="Color.Default"
                                                            Size="Size.Small"
                                                            OnClick="@(() => HandleStartEditSubtask(editStId, subtask.Title))"
                                                            title="Edit subtask"
                                                            Class="subtask-edit-btn" />
                                                        <MudIconButton
                                                            Icon="@Icons.Material.Filled.Close"
                                                            Size="Size.Small"
                                                            Color="Color.Default"
                                                            OnClick="@(async () => await HandleDeleteSubtask(stId))"
                                                            Class="subtask-delete-btn" />
                                                    }
                                                </div>
                                            }
                                            @if (_addingSubtaskForTodoId == todo.Id)
                                            {
                                                var currentTodoId = todo.Id;
                                                <MudTextField
                                                    @bind-Value="_newSubtaskTitle"
                                                    Variant="Variant.Outlined"
                                                    Margin="Margin.Dense"
                                                    Placeholder="New subtask..."
                                                    OnKeyUp="@(async (KeyboardEventArgs e) => await HandleSubtaskInputKeyUp(e, currentTodoId))"
                                                    Class="subtask-input" />
                                            }
                                            else
                                            {
                                                var currentTodoId = todo.Id;
                                                <MudButton
                                                    Size="Size.Small"
                                                    Variant="Variant.Text"
                                                    Color="Color.Secondary"
                                                    StartIcon="@Icons.Material.Filled.Add"
                                                    OnClick="@(() => HandleStartAddSubtask(currentTodoId))"
                                                    Class="add-subtask-btn">
                                                    Add subtask
                                                </MudButton>
                                            }
                                        </div>
                                    }
                                </div>
                            </div>
                            <MudIconButton
                                Icon="@(string.IsNullOrEmpty(todo.Notes) ? Icons.Material.Outlined.StickyNote2 : Icons.Material.Filled.StickyNote2)"
                                Color="@(string.IsNullOrEmpty(todo.Notes) ? Color.Default : Color.Info)"
                                Size="Size.Small"
                                OnClick="@(() => HandleStartEditNotes(todo.Id, todo.Notes ?? string.Empty))"
                                title="@(string.IsNullOrEmpty(todo.Notes) ? "Add notes" : "Edit notes")"
                                Class="todo-notes-btn" />
                            <MudIconButton
                                Icon="@(todo.IsPinned ? Icons.Material.Filled.Star : Icons.Material.Outlined.StarBorder)"
                                Color="@(todo.IsPinned ? Color.Warning : Color.Default)"
                                Size="Size.Small"
                                OnClick="@(async () => await HandleTogglePin(todo.Id))"
                                title="@(todo.IsPinned ? "Unpin" : "Pin to top")"
                                Class="todo-pin-btn" />
                            @{
                                var snoozeTodoId = todo.Id;
                            }
                            @if (_snoozingTodoId == todo.Id)
                            {
                                <div class="d-flex gap-1 align-center snooze-options">
                                    <MudButton Size="Size.Small" Variant="Variant.Outlined" Color="Color.Info"
                                               OnClick="@(async () => await HandleSnooze(snoozeTodoId, 1))"
                                               Class="snooze-tomorrow-btn">Tomorrow</MudButton>
                                    <MudButton Size="Size.Small" Variant="Variant.Outlined" Color="Color.Info"
                                               OnClick="@(async () => await HandleSnooze(snoozeTodoId, 7))"
                                               Class="snooze-week-btn">+1 week</MudButton>
                                    <MudButton Size="Size.Small" Variant="Variant.Outlined" Color="Color.Info"
                                               OnClick="@(async () => await HandleSnooze(snoozeTodoId, 14))"
                                               Class="snooze-two-weeks-btn">+2 weeks</MudButton>
                                    <MudIconButton
                                        Icon="@Icons.Material.Filled.Close"
                                        Color="Color.Default"
                                        Size="Size.Small"
                                        OnClick="@(() => _snoozingTodoId = null)"
                                        title="Cancel snooze"
                                        Class="snooze-cancel-btn" />
                                </div>
                            }
                            else
                            {
                                <MudIconButton
                                    Icon="@Icons.Material.Filled.Snooze"
                                    Color="Color.Default"
                                    Size="Size.Small"
                                    OnClick="@(() => _snoozingTodoId = snoozeTodoId)"
                                    title="Snooze"
                                    Class="todo-snooze-btn" />
                            }
                            @if (_lists is { Count: > 1 })
                            {
                                var currentTodoId = todo.Id;
                                @if (_movingTodoId == todo.Id)
                                {
                                    <MudSelect
                                        T="int"
                                        Value="0"
                                        ValueChanged="@(async (int targetListId) => await HandleMoveTodo(currentTodoId, targetListId))"
                                        Dense="true"
                                        Variant="Variant.Outlined"
                                        Style="width: 110px; font-size: 0.75rem;"
                                        Label="Move to"
                                        Class="todo-move-select">
                                        @foreach (var list in _lists.Where(l => l.Id != todo.ListId))
                                        {
                                            <MudSelectItem Value="@list.Id">@list.Name</MudSelectItem>
                                        }
                                    </MudSelect>
                                    <MudIconButton
                                        Icon="@Icons.Material.Filled.Close"
                                        Color="Color.Default"
                                        Size="Size.Small"
                                        OnClick="@(() => _movingTodoId = null)"
                                        title="Cancel move"
                                        Class="todo-move-cancel-btn" />
                                }
                                else
                                {
                                    <MudIconButton
                                        Icon="@Icons.Material.Filled.DriveFileMove"
                                        Color="Color.Default"
                                        Size="Size.Small"
                                        OnClick="@(() => _movingTodoId = currentTodoId)"
                                        title="Move to list"
                                        Class="todo-move-btn" />
                                }
                            }
                            <MudIconButton
                                Icon="@Icons.Material.Filled.Delete"
                                Color="Color.Error"
                                Size="Size.Small"
                                OnClick="@(async () => await HandleDeleteTodo(todo.Id))"
                                Class="todo-delete-btn" />
                            <MudIconButton
                                Icon="@Icons.Material.Filled.ContentCopy"
                                Color="Color.Default"
                                Size="Size.Small"
                                OnClick="@(async () => await HandleDuplicateTodo(todo.Id))"
                                title="Duplicate"
                                Class="todo-duplicate-btn" />
                            @{
                                var colorTodoId = todo.Id;
                            }
                            @if (_colorPickingTodoId == todo.Id)
                            {
                                <div class="d-flex gap-1 align-center color-picker-palette">
                                    <span style="display:inline-block;width:16px;height:16px;border-radius:50%;background:#9e9e9e;cursor:pointer;border:2px solid transparent;"
                                          title="Clear color"
                                          class="color-picker-none"
                                          @onclick="@(async () => await HandleSetColor(colorTodoId, TodoColorLabel.None))"></span>
                                    @foreach (var cl in new[] { TodoColorLabel.Red, TodoColorLabel.Orange, TodoColorLabel.Yellow, TodoColorLabel.Green, TodoColorLabel.Blue, TodoColorLabel.Purple })
                                    {
                                        var pickerLabel = cl;
                                        <span style="display:inline-block;width:16px;height:16px;border-radius:50%;background:@GetColorCss(pickerLabel);cursor:pointer;border:2px solid @(todo.ColorLabel == pickerLabel ? "var(--mud-palette-primary)" : "transparent");"
                                              title="@pickerLabel"
                                              class="color-picker-dot color-picker-@(pickerLabel.ToString().ToLower())"
                                              @onclick="@(async () => await HandleSetColor(colorTodoId, pickerLabel))"></span>
                                    }
                                    <MudIconButton
                                        Icon="@Icons.Material.Filled.Close"
                                        Color="Color.Default"
                                        Size="Size.Small"
                                        OnClick="@(() => _colorPickingTodoId = null)"
                                        title="Cancel"
                                        Class="color-picker-cancel-btn" />
                                </div>
                            }
                            else
                            {
                                <MudIconButton
                                    Icon="@Icons.Material.Filled.Palette"
                                    Color="@(todo.ColorLabel != TodoColorLabel.None ? Color.Primary : Color.Default)"
                                    Size="Size.Small"
                                    OnClick="@(() => _colorPickingTodoId = colorTodoId)"
                                    title="Set color label"
                                    Style="@(todo.ColorLabel != TodoColorLabel.None ? $"color:{GetColorCss(todo.ColorLabel)}!important;" : "")"
                                    Class="todo-color-btn" />
                            }
                        </div>
                    </MudListItem>
                    </div>
                    <MudDivider />
                }
            </MudList>
        </MudPaper>
    }
}

@code {
    private string _newTitle = string.Empty;
    private TodoPriority _newPriority = TodoPriority.None;
    private DateTime? _newDueDate;
    private RecurrenceRule _newRecurrence = RecurrenceRule.None;
    private TimeEstimate _newTimeEstimate = TimeEstimate.None;

    private IReadOnlyList<TodoList>? _lists;
    private int _activeListId = 1;
    private bool _creatingList;
    private string _newListName = string.Empty;
    private int? _renamingListId;
    private string _renameListValue = string.Empty;

    private int? _draggingId;
    private int? _dragOverId;
    private IReadOnlyList<TodoSummary>? _todos;
    private bool _isSubmitting;
    private string? _errorMessage;

    private int? _movingTodoId;
    private int? _snoozingTodoId;
    private int? _settingDueDateForTodoId;
    private DateTime? _quickDueDateValue;

    private TodoStatusFilter _statusFilter = TodoStatusFilter.All;
    private TodoSortOrder _sortOrder = TodoSortOrder.Newest;
    private string _searchQuery = string.Empty;
    private TodoDateFilter _dateFilter = TodoDateFilter.None;

    private int? _editingTodoId;
    private string _editValue = string.Empty;
    private TodoPriority _editPriority = TodoPriority.None;
    private DateTime? _editDueDate;
    private TimeEstimate _editTimeEstimate = TimeEstimate.None;

    private bool _isSelectMode;
    private HashSet<int> _selectedIds = new();
    private int _bulkMoveTargetListId;

    private bool _isFocusMode;

    private TodoColorLabel? _colorFilter;
    private int? _colorPickingTodoId;

    private ActivityStats? _activityStats;

    private bool _showShortcutsHelp;
    private DotNetObjectReference<Home>? _dotNetRef;
    private bool _shortcutsRegistered;

    private Dictionary<int, List<Tag>> _todoTags = new();
    private IReadOnlyList<string> _allTagNames = [];
    private int? _addingTagForTodoId;
    private string _newTagInput = string.Empty;
    private string? _tagFilter;
    private TodoPriority? _priorityFilter;

    private int? _editingNotesForTodoId;
    private string _notesValue = string.Empty;

    private string? _renamingTagName;
    private string _renameTagValue = string.Empty;

    private Dictionary<int, List<Subtask>> _subtasks = new();
    private int? _expandedSubtasksForTodoId;
    private int? _addingSubtaskForTodoId;
    private string _newSubtaskTitle = string.Empty;
    private int? _editingSubtaskId;
    private string _editSubtaskTitle = string.Empty;

    private IReadOnlyList<string> AllTagNames =>
        _todoTags.Values.SelectMany(tags => tags.Select(t => t.Name))
            .Distinct().OrderBy(n => n).ToList();

    // Cross-list mode: active when searching or date-filtering with multiple lists.
    private bool IsGlobalSearch =>
        (!string.IsNullOrWhiteSpace(_searchQuery) || _dateFilter != TodoDateFilter.None)
        && _lists is { Count: > 1 };

    private IReadOnlyList<TodoSummary> DisplayedTodos
    {
        get
        {
            if (_todos is null) return [];
            if (_isFocusMode)
            {
                var listSource = _todos.Where(t => t.ListId == _activeListId).ToList();
                return FocusModeHandler.Handle(listSource);
            }
            var source = IsGlobalSearch
                ? _todos.ToList()
                : _todos.Where(t => t.ListId == _activeListId).ToList();
            var filtered = FilterSortTodosHandler.Handle(source, _statusFilter, _sortOrder, _searchQuery, _priorityFilter, _dateFilter);
            var tagFiltered = _tagFilter is null
                ? filtered
                : filtered.Where(t => _todoTags.TryGetValue(t.Id, out var tags) && tags.Any(tag => tag.Name == _tagFilter)).ToList();
            if (_colorFilter is null) return tagFiltered;
            return tagFiltered.Where(t => t.ColorLabel == _colorFilter.Value).ToList();
        }
    }

    private enum DueDateStatus { Future, DueToday, Overdue }

    protected override async Task OnInitializedAsync()
    {
        await LoadTodosAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _dotNetRef = DotNetObjectReference.Create(this);
            await JS.InvokeVoidAsync("todoApp.registerKeyboardShortcuts", _dotNetRef);
            _shortcutsRegistered = true;
        }
    }

    public async ValueTask DisposeAsync()
    {
        if (_shortcutsRegistered)
        {
            try { await JS.InvokeVoidAsync("todoApp.unregisterKeyboardShortcuts"); }
            catch { /* ignore disposal errors */ }
        }
        _dotNetRef?.Dispose();
    }

    [JSInvokable]
    public async Task FocusNewTodoInput()
    {
        await JS.InvokeVoidAsync("todoApp.focusElement", ".new-todo-input input");
    }

    [JSInvokable]
    public async Task FocusSearchInput()
    {
        await JS.InvokeVoidAsync("todoApp.focusElement", ".todo-search-field input");
    }

    [JSInvokable]
    public void ToggleShortcutsHelp()
    {
        _showShortcutsHelp = !_showShortcutsHelp;
        StateHasChanged();
    }

    private async Task LoadTodosAsync()
    {
        _lists = await GetListsHandler.HandleAsync();
        _todos = await GetTodosHandler.HandleAsync();
        _activityStats = await ActivityStatsHandler.HandleAsync();
        _allTagNames = await GetAllTagNamesHandler.HandleAsync();
        if (_todos.Count > 0)
        {
            var ids = _todos.Select(t => t.Id).ToList();
            _todoTags = await GetTodoTagsHandler.HandleAsync(ids);
            _subtasks = await GetSubtasksHandler.HandleAsync(ids);
        }
        else
        {
            _todoTags = [];
            _subtasks = [];
        }
    }

    private async Task HandleAddTodo()
    {
        if (string.IsNullOrWhiteSpace(_newTitle))
        {
            _errorMessage = "Please enter a title.";
            return;
        }

        _errorMessage = null;
        _isSubmitting = true;

        try
        {
            var parsed = NaturalLanguageParser.Parse(_newTitle);
            var effectiveTitle    = parsed.CleanTitle.Length > 0 ? parsed.CleanTitle : _newTitle;
            var effectivePriority = _newPriority != TodoPriority.None ? _newPriority : (parsed.Priority ?? TodoPriority.None);
            var effectiveDueDate  = _newDueDate ?? parsed.DueDate;

            await AddTodoHandler.HandleAsync(effectiveTitle, effectivePriority, effectiveDueDate, _newRecurrence, _activeListId, _newTimeEstimate);
            _newTitle = string.Empty;
            _newPriority = TodoPriority.None;
            _newDueDate = null;
            _newRecurrence = RecurrenceRule.None;
            _newTimeEstimate = TimeEstimate.None;
            await LoadTodosAsync();
        }
        catch (ArgumentException ex)
        {
            _errorMessage = ex.Message;
        }
        finally
        {
            _isSubmitting = false;
        }
    }

    private async Task HandleEnterKey(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
            await HandleAddTodo();
    }

    private async Task HandleToggleComplete(int id)
    {
        var todo = _todos?.FirstOrDefault(t => t.Id == id);
        await CompleteTodoHandler.HandleAsync(id);

        // If completing a recurring todo, spawn the next instance
        if (todo is { Recurrence: not RecurrenceRule.None, IsCompleted: false })
        {
            await CreateRecurringInstanceHandler.HandleAsync(todo);
            Snackbar.Add($"Next \"{todo.Title}\" scheduled ({todo.Recurrence.ToString().ToLower()})", Severity.Info);
        }

        await LoadTodosAsync();
    }

    private async Task HandleSetColor(int id, TodoColorLabel label)
    {
        await SetColorLabelHandler.HandleAsync(id, label);
        _colorPickingTodoId = null;
        await LoadTodosAsync();
    }

    private static string GetColorCss(TodoColorLabel label) => label switch
    {
        TodoColorLabel.Red    => "#ef5350",
        TodoColorLabel.Orange => "#ff9800",
        TodoColorLabel.Yellow => "#ffc107",
        TodoColorLabel.Green  => "#4caf50",
        TodoColorLabel.Blue   => "#2196f3",
        TodoColorLabel.Purple => "#9c27b0",
        _                 => "transparent"
    };

    private async Task HandleDuplicateTodo(int id)
    {
        var newId = await DuplicateTodoHandler.HandleAsync(id);
        await LoadTodosAsync();

        Snackbar.Add("Todo duplicated", Severity.Normal, config =>
        {
            config.Action = "Undo";
            config.ActionColor = Color.Primary;
            config.Onclick = async _ =>
            {
                await DeleteTodoHandler.HandleAsync(newId);
                await LoadTodosAsync();
                StateHasChanged();
            };
        });
    }

    private async Task HandleDeleteTodo(int id)
    {
        var deleted = _todos?.FirstOrDefault(t => t.Id == id);
        await DeleteTodoHandler.HandleAsync(id);
        await LoadTodosAsync();

        if (deleted is not null)
        {
            var snapshot = deleted;
            Snackbar.Add("1 todo deleted", Severity.Normal, config =>
            {
                config.Action = "Undo";
                config.ActionColor = Color.Primary;
                config.Onclick = async _ =>
                {
                    await RestoreTodosHandler.HandleAsync([snapshot]);
                    await LoadTodosAsync();
                    StateHasChanged();
                };
            });
        }
    }

    private void HandleStartEdit(int id, string currentTitle, TodoPriority priority, DateTime? dueDate, TimeEstimate timeEstimate)
    {
        _editingTodoId = id;
        _editValue = currentTitle;
        _editPriority = priority;
        _editDueDate = dueDate;
        _editTimeEstimate = timeEstimate;
    }

    private async Task HandleSaveEdit()
    {
        if (_editingTodoId is null) return;

        try
        {
            await EditTodoHandler.HandleAsync(_editingTodoId.Value, _editValue, _editPriority, _editDueDate, _editTimeEstimate);
            _editingTodoId = null;
            await LoadTodosAsync();
        }
        catch (ArgumentException)
        {
            // keep editing state so user can fix the value
        }
    }

    private void HandleCancelEdit()
    {
        _editingTodoId = null;
    }

    private async Task HandleEditKeyUp(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
            await HandleSaveEdit();
        else if (e.Key == "Escape")
            HandleCancelEdit();
    }

    private void HandleToggleSelectMode()
    {
        _isSelectMode = !_isSelectMode;
        if (!_isSelectMode)
        {
            _selectedIds.Clear();
            _bulkMoveTargetListId = 0;
        }
    }

    private void HandleToggleFocusMode()
    {
        _isFocusMode = !_isFocusMode;
        if (_isFocusMode)
            _isSelectMode = false;
    }

    private void HandleToggleTodoSelection(int id, bool selected)
    {
        if (selected)
            _selectedIds.Add(id);
        else
            _selectedIds.Remove(id);
    }

    private async Task HandleBulkComplete()
    {
        // Only capture todos that were NOT already completed — those are the ones we'll undo
        var toUndo = DisplayedTodos
            .Where(t => _selectedIds.Contains(t.Id) && !t.IsCompleted)
            .ToList();

        await BulkOperationsHandler.CompleteAsync(_selectedIds.ToList());
        _selectedIds.Clear();
        await LoadTodosAsync();

        if (toUndo.Count > 0)
        {
            var count = toUndo.Count;
            var ids = toUndo.Select(t => t.Id).ToList();
            Snackbar.Add($"{count} todo{(count == 1 ? "" : "s")} marked complete", Severity.Normal, config =>
            {
                config.Action = "Undo";
                config.ActionColor = Color.Primary;
                config.Onclick = async _ =>
                {
                    await BulkOperationsHandler.CompleteAsync(ids);
                    await LoadTodosAsync();
                    StateHasChanged();
                };
            });
        }
    }

    private async Task HandleBulkDelete()
    {
        var deleted = DisplayedTodos
            .Where(t => _selectedIds.Contains(t.Id))
            .ToList();

        await BulkOperationsHandler.DeleteAsync(_selectedIds.ToList());
        _selectedIds.Clear();
        await LoadTodosAsync();

        if (deleted.Count > 0)
        {
            var snapshot = deleted.AsReadOnly();
            var count = snapshot.Count;
            Snackbar.Add($"{count} todo{(count == 1 ? "" : "s")} deleted", Severity.Normal, config =>
            {
                config.Action = "Undo";
                config.ActionColor = Color.Primary;
                config.Onclick = async _ =>
                {
                    await RestoreTodosHandler.HandleAsync(snapshot);
                    await LoadTodosAsync();
                    StateHasChanged();
                };
            });
        }
    }

    private async Task HandleBulkMove()
    {
        if (_bulkMoveTargetListId == 0 || _selectedIds.Count == 0) return;

        var ids = _selectedIds.ToList();
        var count = ids.Count;
        var targetList = _lists?.FirstOrDefault(l => l.Id == _bulkMoveTargetListId);

        await BulkOperationsHandler.MoveAsync(ids, _bulkMoveTargetListId);
        _selectedIds.Clear();
        _bulkMoveTargetListId = 0;
        _isSelectMode = false;
        await LoadTodosAsync();

        if (targetList is not null)
            Snackbar.Add($"{count} todo{(count == 1 ? "" : "s")} moved to \"{targetList.Name}\"", Severity.Normal);
    }

    private static string GetRecurrenceLabel(RecurrenceRule rule) => rule switch
    {
        RecurrenceRule.Daily   => "Daily",
        RecurrenceRule.Weekly  => "Weekly",
        RecurrenceRule.Monthly => "Monthly",
