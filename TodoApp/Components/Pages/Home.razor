    private async Task HandleListDrop(int targetListId)
    {
        if (_draggingListId is null || _draggingListId == targetListId || _lists is null)
            return;

        var current = _lists.ToList();
        var dragIdx = current.FindIndex(l => l.Id == _draggingListId.Value);
        var dropIdx = current.FindIndex(l => l.Id == targetListId);
        if (dragIdx < 0 || dropIdx < 0) return;

        var item = current[dragIdx];
        current.RemoveAt(dragIdx);
        current.Insert(dropIdx, item);

        var orderedIds = current.Select(l => l.Id).ToList();
        await ReorderListsHandler.HandleAsync(orderedIds);
        await LoadTodosAsync();

        _draggingListId = null;
        _dragOverListId = null;
    }

