    private async Task HandleSubtaskEditKeyUp(KeyboardEventArgs e, int subtaskId)
    {
        if (e.Key == "Enter")
            await HandleSaveSubtaskEdit(subtaskId);
        else if (e.Key == "Escape")
            _editingSubtaskId = null;
    }

    private IReadOnlyList<string> GetTagSuggestions(int todoId)
    {
        if (string.IsNullOrWhiteSpace(_newTagInput)) return [];
        var input = _newTagInput.Trim().ToLowerInvariant();
        var existing = _todoTags.GetValueOrDefault(todoId, []).Select(t => t.Name).ToHashSet();
        return _allTagNames
            .Where(n => n.StartsWith(input, StringComparison.OrdinalIgnoreCase)
                        && !existing.Contains(n)
                        && n != input)
            .Take(5)
            .ToList();
    }

    private async Task HandleSelectTagSuggestion(int todoId, string tagName)
    {
        _newTagInput = tagName;
        await HandleSaveTag(todoId);
    }

    private void HandleStartAddTag(int todoId)
    {
        _addingTagForTodoId = todoId;
        _newTagInput = string.Empty;
    }

    private async Task HandleTagInputKeyUp(KeyboardEventArgs e, int todoId)
    {
        if (e.Key == "Enter")
            await HandleSaveTag(todoId);
        else if (e.Key == "Escape")
            _addingTagForTodoId = null;
    }

    private async Task HandleSaveTag(int todoId)
    {
        if (string.IsNullOrWhiteSpace(_newTagInput))
        {
            _addingTagForTodoId = null;
            return;
        }

        try
        {
            await AddTagHandler.HandleAsync(todoId, _newTagInput);
            _addingTagForTodoId = null;
            _newTagInput = string.Empty;
            await LoadTodosAsync();
        }
        catch (ArgumentException)
        {
            _addingTagForTodoId = null;
        }
    }

    private async Task HandleRemoveTag(int tagId)
    {
        await RemoveTagHandler.HandleAsync(tagId);
        await LoadTodosAsync();
    }

    private void HandleStartRenameTag(string tagName)
    {
        _renamingTagName = tagName;
        _renameTagValue = tagName;
    }

    private async Task HandleRenameTagKeyUp(KeyboardEventArgs e, string oldTagName)
    {
        if (e.Key == "Enter")
            await HandleSaveRenameTag(oldTagName);
        else if (e.Key == "Escape")
            _renamingTagName = null;
    }

    private async Task HandleSaveRenameTag(string oldTagName)
    {
        if (string.IsNullOrWhiteSpace(_renameTagValue))
        {
            _renamingTagName = null;
            return;
        }

        try
        {
            await RenameTagHandler.HandleAsync(oldTagName, _renameTagValue);
            var newName = _renameTagValue.Trim().ToLowerInvariant();
            if (_tagFilter == oldTagName)
                _tagFilter = newName;
            _renamingTagName = null;
            _renameTagValue = string.Empty;
            await LoadTodosAsync();
        }
        catch (ArgumentException)
        {
            _renamingTagName = null;
        }
    }

    private async Task HandleDrop(int targetId)
    {
        if (_draggingId is null || _draggingId == targetId)
        {
            _draggingId = null;
            _dragOverId = null;
            return;
        }

        // Build a new order by moving the dragged item to the target's position
        var listTodos = _todos!.Where(t => t.ListId == _activeListId).ToList();
        var dragged = listTodos.FirstOrDefault(t => t.Id == _draggingId.Value);
        var target  = listTodos.FirstOrDefault(t => t.Id == targetId);
        if (dragged is null || target is null) { _draggingId = null; _dragOverId = null; return; }

        var reordered = listTodos.Where(t => t.Id != _draggingId.Value).ToList();
        var insertAt  = reordered.IndexOf(target);
        reordered.Insert(insertAt, dragged);

        _draggingId = null;
        _dragOverId = null;

        await ReorderTodosHandler.HandleAsync(reordered.Select(t => t.Id).ToList());
        await LoadTodosAsync();
    }

    private async Task HandleMoveTodo(int todoId, int targetListId)
    {
        if (targetListId <= 0) return;
        await MoveTodoHandler.HandleAsync(todoId, targetListId);
        _movingTodoId = null;
        await LoadTodosAsync();
    }

    private async Task HandleSnooze(int todoId, int daysFromToday)
    {
        var newDate = DateTime.Today.AddDays(daysFromToday);
        await SnoozeTodoHandler.HandleAsync(todoId, newDate);
        _snoozingTodoId = null;
        await LoadTodosAsync();
        Snackbar.Add($"Snoozed to {newDate:MMM d}", Severity.Info);
    }

    private void HandleStartQuickDueDate(int todoId, DateTime? currentDueDate)
    {
        _settingDueDateForTodoId = todoId;
        _quickDueDateValue = currentDueDate;
        _snoozingTodoId = null;
    }

    private async Task HandleSaveQuickDueDate(int todoId)
    {
        await SetDueDateHandler.HandleAsync(todoId, _quickDueDateValue);
        _settingDueDateForTodoId = null;
        await LoadTodosAsync();
    }

    private async Task HandleClearQuickDueDate(int todoId)
    {
        await SetDueDateHandler.HandleAsync(todoId, null);
        _settingDueDateForTodoId = null;
        await LoadTodosAsync();
    }

    private void HandleSwitchList(int listId)
    {
        _activeListId = listId;
        // Reset filters when switching lists
        _statusFilter = TodoStatusFilter.All;
        _searchQuery = string.Empty;
        _priorityFilter = null;
        _tagFilter = null;
        _dateFilter = TodoDateFilter.None;
        _colorFilter = null;
        _isFocusMode = false;
    }

    private async Task HandleNewListKeyUp(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
            await HandleSaveNewList();
        else if (e.Key == "Escape")
            _creatingList = false;
    }

    private async Task HandleSaveNewList()
    {
        if (string.IsNullOrWhiteSpace(_newListName))
        {
            _creatingList = false;
            return;
        }

        try
        {
            var newId = await CreateListHandler.HandleAsync(_newListName);
            _newListName = string.Empty;
            _creatingList = false;
            await LoadTodosAsync();
            HandleSwitchList(newId);
        }
        catch (ArgumentException)
        {
            _creatingList = false;
        }
    }

    private void HandleStartRenameList(int listId, string currentName)
    {
        _renamingListId = listId;
        _renameListValue = currentName;
    }

    private async Task HandleRenameListKeyUp(KeyboardEventArgs e, int listId)
    {
        if (e.Key == "Enter")
            await HandleSaveRenameList(listId);
        else if (e.Key == "Escape")
            _renamingListId = null;
    }

    private async Task HandleSaveRenameList(int listId)
    {
        if (string.IsNullOrWhiteSpace(_renameListValue))
        {
            _renamingListId = null;
            return;
        }

        try
        {
            await RenameListHandler.HandleAsync(listId, _renameListValue);
            _renamingListId = null;
            await LoadTodosAsync();
        }
        catch (ArgumentException)
        {
            _renamingListId = null;
        }
    }

    private async Task HandleDeleteList(int listId)
    {
        if (listId == DeleteListHandler.DefaultListId) return;

        await DeleteListHandler.HandleAsync(listId);
        if (_activeListId == listId)
            _activeListId = DeleteListHandler.DefaultListId;
        await LoadTodosAsync();
    }

    private void SetQuickDueDate(int daysFromToday)
    {
        var target = DateTime.Today.AddDays(daysFromToday);
        // Toggle: clicking the active shortcut clears the date
        _newDueDate = _newDueDate?.Date == target.Date ? null : target;
    }

    private static string FormatCompletedAt(DateTime completedAt)
    {
        var local = completedAt.ToLocalTime();
        var diff = (DateTime.Today - local.Date).Days;
        return diff switch
        {
            0    => $"Completed today at {local:h:mm tt}",
            1    => "Completed yesterday",
            <= 7 => $"Completed {diff} days ago",
            _    => $"Completed {local:MMM d, yyyy}"
        };
    }

    private static string FormatDueDateDisplay(DateTime dueDate)
    {
        var diff = (dueDate.Date - DateTime.Today).Days;
        return diff switch
        {
            0    => "Due today",
            1    => "Due tomorrow",
            > 1 and <= 7 => $"Due in {diff} days",
            < 0 and >= -1 => "Overdue by 1 day",
            < -1 => $"Overdue by {-diff} days",
            _    => $"Due {dueDate:MMM d, yyyy}"
        };
    }

    private static DueDateStatus GetDueDateStatus(TodoSummary todo)
    {
        if (!todo.DueDate.HasValue || todo.IsCompleted)
            return DueDateStatus.Future;

        var today = DateTime.Today;
        var dueDate = todo.DueDate.Value.Date;

        if (dueDate < today)
            return DueDateStatus.Overdue;
        if (dueDate == today)
            return DueDateStatus.DueToday;
        return DueDateStatus.Future;
    }

    private static string GetTimeEstimateLabel(TimeEstimate estimate) => estimate switch
    {
        TimeEstimate.FifteenMinutes => "15 min",
        TimeEstimate.ThirtyMinutes  => "30 min",
        TimeEstimate.OneHour        => "1 h",
        TimeEstimate.TwoHours       => "2 h",
        TimeEstimate.FourHours      => "4 h",
        TimeEstimate.OneDay         => "1 day",
        _                           => string.Empty
    };

    private static string FormatEstimatedTime(int minutes)
    {
        if (minutes < 60)
            return $"{minutes} min";
        var hours = minutes / 60;
        var remainder = minutes % 60;
        return remainder == 0 ? $"{hours} h" : $"{hours} h {remainder} min";
    }

    private static int GetHeatmapLevel(int count) => count switch
    {
        0        => 0,
        <= 2     => 1,
        <= 4     => 2,
        _        => 3
    };

    private static string GetHeatmapStyle(int count, bool isToday)
    {
        var bg = count switch
        {
            0    => "var(--mud-palette-action-disabled-background)",
            <= 2 => "#a5d6a7",
            <= 4 => "#4caf50",
            _    => "#1b5e20"
        };
        var border = isToday ? "2px solid var(--mud-palette-primary)" : "2px solid transparent";
        return $"display:inline-block;width:14px;height:14px;border-radius:3px;background:{bg};border:{border};";
    }
}
