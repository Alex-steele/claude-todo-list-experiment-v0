    private async Task HandleToggleReminders()
    {
        if (_remindersEnabled)
        {
            _remindersEnabled = false;
            await JS.InvokeVoidAsync("todoApp.saveReminderPreference", false);
            return;
        }

        var permission = await JS.InvokeAsync<string>("todoApp.requestNotificationPermission");
        if (permission == "granted")
        {
            _remindersEnabled = true;
            await JS.InvokeVoidAsync("todoApp.saveReminderPreference", true);
            Snackbar.Add("Due date reminders enabled", Severity.Success);
            await CheckAndShowReminderAsync();
        }
        else
        {
            Snackbar.Add("Notification permission denied — enable it in your browser settings to use reminders.", Severity.Warning);
        }
    }

    private async Task CheckAndShowReminderAsync()
    {
        if (!_remindersEnabled || _reminderShownThisSession || _todos is null)
            return;

        var listTodos = _todos.Where(t => t.ListId == _activeListId).ToList();
        var summary = DueSummaryHandler.Handle(listTodos);
        var message = ReminderMessageHandler.Handle(summary);
        if (message is not null)
        {
            _reminderShownThisSession = true;
            await JS.InvokeVoidAsync("todoApp.showNotification", "Todo reminder", message);
        }
    }

