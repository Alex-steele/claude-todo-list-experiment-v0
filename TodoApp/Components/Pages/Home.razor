        await LoadTodosAsync();

        if (deleted.Count > 0)
        {
            var snapshot = deleted;
            var count = snapshot.Count;
            Snackbar.Add($"{count} completed todo{(count == 1 ? "" : "s")} cleared", Severity.Normal, config =>
            {
