<PageTitle>My Todo List</PageTitle>

@if (_lists is { Count: > 0 })
{
    <MudCard Elevation="1" Class="mb-4">
        <MudCardContent Class="py-2">
            <div class="d-flex align-center gap-1 flex-wrap list-selector-row">
                @{
                    var todayCount = _todos is not null ? TodayViewHandler.CountUrgent(_todos) : 0;
                }
                <MudChip T="string"
                         Variant="@(_isTodayView ? Variant.Filled : Variant.Outlined)"
                         Color="@(todayCount > 0 ? Color.Error : Color.Secondary)"
                         OnClick="HandleSwitchToTodayView"
                         title="See all overdue and due-today todos across every list"
                         Class="today-view-chip">
                    ☀ Today@(todayCount > 0 ? $" ({todayCount})" : "")
                </MudChip>
                @{
                    var trashCount = _trashedTodos?.Count ?? 0;
                }
                <MudChip T="string"
                         Variant="@(_isTrashView ? Variant.Filled : Variant.Outlined)"
                         Color="Color.Secondary"
                         OnClick="HandleSwitchToTrashView"
                         title="View deleted todos — restore or delete permanently"
                         Class="trash-view-chip">
                    🗑 Trash@(trashCount > 0 ? $" ({trashCount})" : "")
                </MudChip>
                @foreach (var list in _lists)
                {
                    var listId = list.Id;
                    @if (_renamingListId == listId)
                    {
                        <MudTextField
                            @bind-Value="_renameListValue"
                            Variant="Variant.Outlined"
                            Margin="Margin.Dense"
                            Style="width: 130px; font-size: 0.875rem;"
                            OnKeyUp="@(async (KeyboardEventArgs e) => await HandleRenameListKeyUp(e, listId))"
                            Class="rename-list-input" />
                    }
                    else
                    {
                        var activeCount = GetActiveCountForList(listId);
                        <span draggable="true"
                              @ondragstart="@(() => _draggingListId = listId)"
                              @ondragend="@(() => { _draggingListId = null; _dragOverListId = null; })"
                              @ondragover:preventDefault
                              @ondragover="@(() => _dragOverListId = listId)"
                              @ondrop="@(async () => await HandleListDrop(listId))"
                              style="@(_dragOverListId == listId && _draggingListId != listId ? "opacity: 0.5;" : "")"
                              class="list-drag-wrapper d-inline-flex align-center">
                        <MudChip T="string"
                                 Variant="@(_activeListId == listId ? Variant.Filled : Variant.Outlined)"
                                 Color="Color.Primary"
                                 OnClick="@(() => HandleSwitchList(listId))"
                                 OnClose="@(list.Id != DeleteListHandler.DefaultListId ? EventCallback.Factory.Create<MudChip<string>>(this, async (MudChip<string> _) => await HandleDeleteList(listId)) : new EventCallback<MudChip<string>>())"
                                 Class="list-chip"
                                 Style="@(list.Color != ListColor.None ? $"border-left: 4px solid {GetListColorCss(list.Color)};" : "")"
                                 @ondblclick="@(() => HandleStartRenameList(listId, list.Name))">
                            @if (list.Color != ListColor.None)
                            {
                                <span class="list-color-dot" style="display:inline-block;width:8px;height:8px;border-radius:50%;background:@GetListColorCss(list.Color);margin-right:4px;"></span>
                            }
                            @list.Name
                            @if (activeCount > 0)
                            {
                                <span class="list-count-badge">@activeCount</span>
                            }
                        </MudChip>
                        @if (_colorPickingListId == listId)
                        {
                            <div class="d-flex gap-1 align-center list-color-picker-palette">
                                <span style="display:inline-block;width:14px;height:14px;border-radius:50%;background:#9e9e9e;cursor:pointer;border:2px solid transparent;"
                                      title="Clear color"
                                      class="list-color-picker-none"
                                      @onclick="@(async () => await HandleSetListColor(listId, ListColor.None))"></span>
                                @foreach (var lc in new[] { ListColor.Red, ListColor.Orange, ListColor.Yellow, ListColor.Green, ListColor.Blue, ListColor.Purple })
                                {
                                    var pickerColor = lc;
                                    <span style="display:inline-block;width:14px;height:14px;border-radius:50%;background:@GetListColorCss(pickerColor);cursor:pointer;border:2px solid @(list.Color == pickerColor ? "var(--mud-palette-primary)" : "transparent");"
                                          title="@pickerColor"
                                          class="list-color-picker-dot list-color-picker-@(pickerColor.ToString().ToLower())"
                                          @onclick="@(async () => await HandleSetListColor(listId, pickerColor))"></span>
                                }
                                <MudIconButton
                                    Icon="@Icons.Material.Filled.Close"
                                    Size="Size.Small"
                                    Color="Color.Default"
                                    OnClick="@(() => _colorPickingListId = null)"
                                    title="Cancel"
                                    Class="list-color-picker-cancel-btn" />
                            </div>
                        }
                        else
                        {
                            <MudIconButton
                                Icon="@Icons.Material.Filled.Palette"
                                Size="Size.Small"
                                Color="Color.Default"
                                OnClick="@(() => _colorPickingListId = listId)"
                                title="Set list color"
                                Style="margin-left: -4px; opacity: 0.5;"
                                Class="list-color-btn" />
                        }
                        @if (list.Id != ArchiveListHandler.DefaultListId)
                        {
                            <MudIconButton
                                Icon="@Icons.Material.Outlined.Inventory2"
                                Size="Size.Small"
                                Color="Color.Default"
                                OnClick="@(async () => await HandleArchiveList(listId))"
                                title="Archive list"
                                Style="margin-left: -4px; opacity: 0.5;"
                                Class="archive-list-btn" />
                        }
                        </span>
                    }
                }
                @if (_creatingList)
                {
                    <MudTextField
                        @bind-Value="_newListName"
                        Variant="Variant.Outlined"
                        Margin="Margin.Dense"
                        Placeholder="List name..."
                        Style="width: 130px; font-size: 0.875rem;"
                        OnKeyUp="HandleNewListKeyUp"
                        Class="new-list-input" />
                }
                else
                {
                    <MudIconButton
                        Icon="@Icons.Material.Filled.Add"
                        Size="Size.Small"
                        Color="Color.Primary"
                        OnClick="@(() => { _creatingList = true; _newListName = string.Empty; })"
                        title="New list"
                        Class="add-list-btn" />
                }
            </div>
            @if (_archivedLists is { Count: > 0 })
            {
                <div class="mt-2">
                    <MudButton
                        Variant="Variant.Text"
                        Color="Color.Secondary"
                        Size="Size.Small"
                        StartIcon="@(_showArchivedLists ? Icons.Material.Filled.ExpandLess : Icons.Material.Filled.Inventory2)"
                        OnClick="@(() => _showArchivedLists = !_showArchivedLists)"
                        Class="show-archived-lists-btn">
                        Archived (@_archivedLists.Count)
                    </MudButton>
                    @if (_showArchivedLists)
                    {
                        <div class="d-flex align-center gap-1 flex-wrap mt-1 archived-lists-row">
                            @foreach (var archivedList in _archivedLists)
                            {
                                var archivedId = archivedList.Id;
                                <div class="d-flex align-center gap-0 archived-list-item">
                                    <MudChip T="string"
                                             Variant="Variant.Outlined"
                                             Color="Color.Default"
                                             Disabled="true"
                                             Class="archived-list-chip">
                                        @archivedList.Name
                                    </MudChip>
                                    <MudIconButton
                                        Icon="@Icons.Material.Filled.Unarchive"
                                        Size="Size.Small"
                                        Color="Color.Secondary"
                                        OnClick="@(async () => await HandleUnarchiveList(archivedId))"
                                        title="Restore list"
                                        Class="unarchive-list-btn" />
                                    <MudIconButton
                                        Icon="@Icons.Material.Filled.Delete"
                                        Size="Size.Small"
                                        Color="Color.Error"
                                        OnClick="@(async () => await HandleDeleteArchivedList(archivedId))"
                                        title="Delete permanently"
                                        Class="delete-archived-list-btn" />
                                </div>
                            }
                        </div>
                    }
                </div>
            }
        </MudCardContent>
    </MudCard>
}

@if (!_isTodayView && !_isTrashView)
{
<MudCard Elevation="2" Class="mb-6">
    <MudCardContent>
        <div class="d-flex align-center justify-space-between mb-4">
            <MudText Typo="Typo.h6">Add a New Todo</MudText>
            <div class="d-flex align-center gap-1">
                <MudButton
                    Variant="@(_isMultiAddMode ? Variant.Filled : Variant.Outlined)"
                    Color="Color.Info"
                    Size="Size.Small"
                    StartIcon="@Icons.Material.Filled.PlaylistAdd"
                    OnClick="HandleToggleMultiAdd"
                    title="Add multiple todos at once"
                    Class="toggle-multi-add-btn">
                    Paste multiple
                </MudButton>
                <MudIconButton
                    Icon="@Icons.Material.Filled.Keyboard"
                    Size="Size.Small"
                    Color="Color.Default"
                    OnClick="ToggleShortcutsHelp"
                    title="Keyboard shortcuts"
                    Class="keyboard-shortcuts-btn" />
            </div>
        </div>
        @if (_showShortcutsHelp)
        {
            <MudPaper Elevation="0" Class="pa-3 mb-4 keyboard-shortcuts-panel" Style="background: var(--mud-palette-background-grey); border-radius: 8px;">
                <MudText Typo="Typo.subtitle2" Class="mb-2">Keyboard Shortcuts</MudText>
                <div class="d-flex flex-column gap-1">
                    <div class="d-flex align-center gap-3">
                        <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Class="shortcut-key">N</MudChip>
                        <MudText Typo="Typo.body2">Focus new todo input</MudText>
                    </div>
                    <div class="d-flex align-center gap-3">
                        <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Class="shortcut-key">/</MudChip>
                        <MudText Typo="Typo.body2">Focus search</MudText>
                    </div>
                    <div class="d-flex align-center gap-3">
                        <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Class="shortcut-key">?</MudChip>
                        <MudText Typo="Typo.body2">Toggle this panel</MudText>
                    </div>
                </div>
                <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mt-2">Shortcuts are inactive when typing in an input.</MudText>
            </MudPaper>
        }
        @if (_isMultiAddMode)
        {
            <MudTextField
                @bind-Value="_multiAddText"
                Label="One todo per line"
                Variant="Variant.Outlined"
                Lines="6"
                FullWidth="true"
                Immediate="true"
                Placeholder="Buy milk&#10;Call dentist&#10;Pay bills"
                Class="mb-3 multi-add-textarea" />
            @if (ParsedMultiAddLines.Count > 0)
            {
                <div class="d-flex align-center gap-2 mb-3 multi-add-preview">
                    <MudIcon Icon="@Icons.Material.Filled.PlaylistAdd" Size="Size.Small" Color="Color.Info" />
                    <MudText Typo="Typo.body2" Color="Color.Info">
                        @ParsedMultiAddLines.Count todo@(ParsedMultiAddLines.Count == 1 ? "" : "s") to add
                    </MudText>
                </div>
                <MudButton
                    Variant="Variant.Filled"
                    Color="Color.Primary"
                    OnClick="HandleMultiAdd"
                    Disabled="_isSubmitting"
                    FullWidth="true"
                    Size="Size.Large"
                    Class="multi-add-submit-btn">
                    @if (_isSubmitting)
                    {
                        <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                    }
                    Add @ParsedMultiAddLines.Count Todo@(ParsedMultiAddLines.Count == 1 ? "" : "s")
                </MudButton>
            }
            @if (ParsedMultiAddLines.Count == 0)
            {
                <MudText Typo="Typo.caption" Color="Color.Secondary">Type or paste one todo per line above.</MudText>
            }
        }
        @if (!_isMultiAddMode)
        {
        <MudTextField
            @bind-Value="_newTitle"
            Label="What needs to be done?"
            Variant="Variant.Outlined"
            FullWidth="true"
            Class="mb-3 new-todo-input"
            OnKeyUp="HandleEnterKey"
            Disabled="_isSubmitting" />
        @if (!string.IsNullOrWhiteSpace(_newTitle) && (NewTitleHints.Priority.HasValue || NewTitleHints.DueDate.HasValue))
        {
            <div class="d-flex align-center gap-1 mb-2 quick-add-hint-strip">
                <MudIcon Icon="@Icons.Material.Filled.AutoAwesome" Size="Size.Small" Color="Color.Tertiary" />
                <MudText Typo="Typo.caption" Color="Color.Tertiary" Class="quick-add-hint-text">
                    Quick-add:
                    @if (!string.IsNullOrWhiteSpace(NewTitleHints.CleanTitle))
                    {
                        <strong>@NewTitleHints.CleanTitle</strong>
                    }
                    @if (NewTitleHints.DueDate.HasValue)
                    {
                        <span> · Due @FormatDueDateDisplay(NewTitleHints.DueDate.Value)</span>
                    }
                    @if (NewTitleHints.Priority.HasValue)
                    {
                        <span> · @NewTitleHints.Priority.Value priority</span>
                    }
                </MudText>
            </div>
        }
        <MudSelect
            T="TodoPriority"
            @bind-Value="_newPriority"
            Label="Priority"
            Variant="Variant.Outlined"
            Class="mb-3"
            Disabled="_isSubmitting">
            <MudSelectItem Value="@TodoPriority.None">None</MudSelectItem>
            <MudSelectItem Value="@TodoPriority.Low">Low</MudSelectItem>
            <MudSelectItem Value="@TodoPriority.Medium">Medium</MudSelectItem>
            <MudSelectItem Value="@TodoPriority.High">High</MudSelectItem>
        </MudSelect>
        <MudDatePicker
            @bind-Date="_newDueDate"
            Label="Due date (optional)"
            Variant="Variant.Outlined"
            Class="mb-2"
            Disabled="_isSubmitting"
            Clearable="true" />
        <div class="d-flex gap-2 mb-3 due-date-shortcuts">
            <MudButton
                Size="Size.Small"
                Variant="@(_newDueDate?.Date == DateTime.Today ? Variant.Filled : Variant.Outlined)"
                Color="Color.Secondary"
                OnClick="@(() => SetQuickDueDate(0))"
                Disabled="_isSubmitting"
                Class="due-date-today-btn">Today</MudButton>
            <MudButton
                Size="Size.Small"
                Variant="@(_newDueDate?.Date == DateTime.Today.AddDays(1) ? Variant.Filled : Variant.Outlined)"
                Color="Color.Secondary"
                OnClick="@(() => SetQuickDueDate(1))"
                Disabled="_isSubmitting"
                Class="due-date-tomorrow-btn">Tomorrow</MudButton>
            <MudButton
                Size="Size.Small"
                Variant="@(_newDueDate?.Date == DateTime.Today.AddDays(7) ? Variant.Filled : Variant.Outlined)"
                Color="Color.Secondary"
                OnClick="@(() => SetQuickDueDate(7))"
                Disabled="_isSubmitting"
                Class="due-date-next-week-btn">Next week</MudButton>
        </div>
        <MudSelect
            T="RecurrenceRule"
            @bind-Value="_newRecurrence"
            Label="Repeats"
            Variant="Variant.Outlined"
            Class="mb-3 recurrence-select"
            Disabled="_isSubmitting">
            <MudSelectItem Value="@RecurrenceRule.None">Does not repeat</MudSelectItem>
            <MudSelectItem Value="@RecurrenceRule.Daily">Daily</MudSelectItem>
            <MudSelectItem Value="@RecurrenceRule.Weekly">Weekly</MudSelectItem>
            <MudSelectItem Value="@RecurrenceRule.Monthly">Monthly</MudSelectItem>
        </MudSelect>
        <MudSelect
            T="TimeEstimate"
            @bind-Value="_newTimeEstimate"
            Label="Time estimate"
            Variant="Variant.Outlined"
            Class="mb-3 time-estimate-select"
            Disabled="_isSubmitting">
            <MudSelectItem Value="@TimeEstimate.None">No estimate</MudSelectItem>
            <MudSelectItem Value="@TimeEstimate.FifteenMinutes">15 min</MudSelectItem>
            <MudSelectItem Value="@TimeEstimate.ThirtyMinutes">30 min</MudSelectItem>
            <MudSelectItem Value="@TimeEstimate.OneHour">1 hour</MudSelectItem>
            <MudSelectItem Value="@TimeEstimate.TwoHours">2 hours</MudSelectItem>
            <MudSelectItem Value="@TimeEstimate.FourHours">4 hours</MudSelectItem>
            <MudSelectItem Value="@TimeEstimate.OneDay">1 day</MudSelectItem>
        </MudSelect>
        @if (_templates is { Count: > 0 })
        {
            <div class="d-flex align-center gap-1 flex-wrap mb-3 template-chips-row">
                <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mr-1">Templates:</MudText>
                @foreach (var tpl in _templates)
                {
                    var t = tpl;
                    <MudChip T="string"
                             Size="Size.Small"
                             Variant="Variant.Outlined"
                             Color="Color.Tertiary"
                             OnClick="@(() => HandleApplyTemplate(t))"
                             OnClose="@(async (MudChip<string> _) => await HandleDeleteTemplate(t.Id))"
                             title="@GetTemplateTooltip(t)"
                             Class="template-chip">
                        @t.Name
                    </MudChip>
                }
            </div>
        }
        @if (HasNonDefaultFormValues && !_savingTemplate)
        {
            <div class="d-flex justify-end mb-2">
                <MudButton
                    Variant="Variant.Text"
                    Color="Color.Tertiary"
                    Size="Size.Small"
                    StartIcon="@Icons.Material.Filled.BookmarkAdd"
                    OnClick="@(() => { _savingTemplate = true; _templateNameInput = string.Empty; })"
                    Class="save-template-btn">
                    Save as template
                </MudButton>
            </div>
        }
        @if (_savingTemplate)
        {
            <div class="d-flex align-center gap-1 mb-2 save-template-input-row">
                <MudTextField
                    @bind-Value="_templateNameInput"
                    Placeholder="Template name…"
                    Variant="Variant.Outlined"
                    Margin="Margin.Dense"
                    FullWidth="true"
                    OnKeyUp="HandleTemplateNameKeyUp"
                    Class="template-name-input" />
                <MudIconButton
                    Icon="@Icons.Material.Filled.Check"
                    Color="Color.Primary"
                    Size="Size.Small"
                    OnClick="HandleSaveTemplate"
                    title="Save template"
                    Class="save-template-confirm-btn" />
                <MudIconButton
                    Icon="@Icons.Material.Filled.Close"
                    Color="Color.Default"
                    Size="Size.Small"
                    OnClick="@(() => { _savingTemplate = false; _templateNameInput = string.Empty; })"
                    title="Cancel"
                    Class="save-template-cancel-btn" />
            </div>
        }
        <MudButton
            Variant="Variant.Filled"
            Color="Color.Primary"
            OnClick="HandleAddTodo"
            Disabled="_isSubmitting"
            FullWidth="true"
            Size="Size.Large"
            Class="add-todo-btn">
            @if (_isSubmitting)
            {
                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
            }
            Add Todo
        </MudButton>
        }
        @if (!string.IsNullOrEmpty(_errorMessage))
        {
            <MudAlert Severity="Severity.Error" Class="mt-3" Dense="true">@_errorMessage</MudAlert>
        }
    </MudCardContent>
</MudCard>
}

@if (_todos is { Count: > 0 })
{
    var stats = GetTodosStatsHandler.Handle(_todos);
    <MudPaper Elevation="1" Class="pa-4 mb-4 stats-panel">
        <div class="d-flex align-center gap-2 mb-3 flex-wrap">
            <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Color="Color.Default" Class="stats-total">
                Total: @stats.Total
            </MudChip>
            <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Color="Color.Info" Class="stats-active">
                Active: @stats.Active
            </MudChip>
            <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Color="Color.Success" Class="stats-completed">
                Completed: @stats.Completed
            </MudChip>
            @if (stats.Overdue > 0)
            {
                <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Color="Color.Error" Class="stats-overdue">
                    Overdue: @stats.Overdue
                </MudChip>
            }
            @if (stats.TotalEstimatedMinutes > 0)
            {
                <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Color="Color.Tertiary" Class="stats-estimated-time">
                    ~@FormatEstimatedTime(stats.TotalEstimatedMinutes) remaining
                </MudChip>
            }
            @{
                var listTodosForCompletion = _todos!.Where(t => t.ListId == _activeListId).ToList();
                var completionTime = CompletionTimeAnalyticsHandler.Handle(listTodosForCompletion);
            }
            @if (completionTime.OverallAverageDays.HasValue)
            {
                <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Color="Color.Default"
                         Class="avg-completion-chip"
                         title="@GetCompletionTimeTooltip(completionTime)">
                    ⏱ Avg: @completionTime.OverallAverageDays.Value.ToString("0.#") days to complete
                </MudChip>
            }
        </div>
        <div class="d-flex align-center gap-3">
            <MudProgressLinear
                Value="@stats.CompletionPercentage"
                Color="Color.Success"
                Rounded="true"
                Size="Size.Small"
                Class="flex-grow-1 stats-progress" />
            <MudText Typo="Typo.caption" Color="Color.Secondary" Class="stats-percentage">@stats.CompletionPercentage%</MudText>
        </div>
        @{
            var breakdown = PriorityBreakdownHandler.Handle(_todos!.Where(t => t.ListId == _activeListId).ToList());
        }
        @if (breakdown.HasData)
        {
            <div class="d-flex align-center gap-2 mt-2 flex-wrap priority-breakdown-row">
                <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mr-1" Style="white-space:nowrap;">By priority:</MudText>
                @if (breakdown.High.Total > 0)
                {
                    <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Color="Color.Error"
                             Class="priority-breakdown-high"
                             title="@($"High priority: {breakdown.High.Active} active, {breakdown.High.Completed} completed")">
                        High @breakdown.High.Completed/@breakdown.High.Total (@breakdown.High.CompletionPercent%)
                    </MudChip>
                }
                @if (breakdown.Medium.Total > 0)
                {
                    <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Color="Color.Warning"
                             Class="priority-breakdown-medium"
                             title="@($"Medium priority: {breakdown.Medium.Active} active, {breakdown.Medium.Completed} completed")">
                        Medium @breakdown.Medium.Completed/@breakdown.Medium.Total (@breakdown.Medium.CompletionPercent%)
                    </MudChip>
                }
                @if (breakdown.Low.Total > 0)
                {
                    <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Color="Color.Info"
                             Class="priority-breakdown-low"
                             title="@($"Low priority: {breakdown.Low.Active} active, {breakdown.Low.Completed} completed")">
                        Low @breakdown.Low.Completed/@breakdown.Low.Total (@breakdown.Low.CompletionPercent%)
                    </MudChip>
                }
            </div>
        }
        @{
            var listTodosForTagStats = _todos!.Where(t => t.ListId == _activeListId).ToList();
            var tagStats = TagStatsHandler.Handle(listTodosForTagStats, _todoTags);
        }
        @if (tagStats.Count > 0)
        {
            <div class="d-flex align-center gap-2 mt-2 flex-wrap tag-stats-row">
                <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mr-1" Style="white-space:nowrap;">By tag:</MudText>
                @foreach (var ts in tagStats)
                {
                    var tagStat = ts;
                    <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Color="Color.Secondary"
                             Class="tag-stat-chip"
                             title="@($"{tagStat.TagName}: {tagStat.Active} active, {tagStat.Completed} completed")">
                        #@tagStat.TagName @tagStat.Completed/@tagStat.Total (@tagStat.CompletionPercent%)
                    </MudChip>
                }
            </div>
        }
        @if (_activityStats is not null && (_activityStats.CurrentStreak > 0 || _activityStats.CompletedToday > 0 || _activityStats.CompletedThisWeek > 0))
        {
            <div class="d-flex align-center gap-2 mt-3 flex-wrap activity-stats-row">
                @if (_activityStats.CurrentStreak > 0)
                {
                    <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Color="Color.Warning" Class="streak-chip"
                             title="@($"Longest streak: {_activityStats.LongestStreak} day{(_activityStats.LongestStreak == 1 ? "" : "s")}")">
                        🔥 @_activityStats.CurrentStreak day streak
                    </MudChip>
                }
                @if (_activityStats.LongestStreak > _activityStats.CurrentStreak && _activityStats.LongestStreak > 0)
                {
                    <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Color="Color.Default" Class="longest-streak-chip">
                        Best: @_activityStats.LongestStreak days
                    </MudChip>
                }
                @if (_activityStats.CompletedToday > 0)
                {
                    <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Color="Color.Success" Class="completed-today-chip">
                        Today: @_activityStats.CompletedToday done
                    </MudChip>
                }
                <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Color="Color.Info" Class="completed-week-chip">
                    This week: @_activityStats.CompletedThisWeek done
                </MudChip>
            </div>
        }
        @if (_activityStats is not null)
        {
            <div class="d-flex align-center gap-2 mt-3 flex-wrap daily-goal-row">
                @if (_dailyGoal.HasValue)
                {
                    var done = _activityStats.CompletedToday;
                    var target = _dailyGoal.Value;
                    var reached = done >= target;
                    @if (_editingGoal)
                    {
                        <div class="d-flex align-center gap-1 goal-edit-row">
                            <MudNumericField
                                T="int"
                                @bind-Value="_goalInput"
                                Min="1"
                                Max="100"
                                Label="Daily goal"
                                Variant="Variant.Outlined"
                                Margin="Margin.Dense"
                                Style="width: 110px; font-size: 0.8rem;"
                                Class="goal-input" />
                            <MudIconButton
                                Icon="@Icons.Material.Filled.Check"
                                Color="Color.Primary"
                                Size="Size.Small"
                                OnClick="HandleSaveGoal"
                                title="Save goal"
                                Class="goal-save-btn" />
                            <MudIconButton
                                Icon="@Icons.Material.Filled.Close"
                                Color="Color.Default"
                                Size="Size.Small"
                                OnClick="HandleCancelGoal"
                                title="Cancel"
                                Class="goal-cancel-btn" />
                            <MudButton
                                Variant="Variant.Text"
                                Color="Color.Error"
                                Size="Size.Small"
                                OnClick="HandleClearGoal"
                                Class="goal-clear-btn">Remove</MudButton>
                        </div>
                    }
                    else
                    {
                        <MudChip T="string"
                                 Size="Size.Small"
                                 Variant="Variant.Outlined"
                                 Color="@(reached ? Color.Success : Color.Primary)"
                                 OnClick="HandleStartEditGoal"
                                 title="Click to edit daily goal"
                                 Class="daily-goal-chip">
                            🎯 @done / @target today@(reached ? " ✓" : "")
                        </MudChip>
                    }
                }
                else if (!_editingGoal)
                {
                    <MudButton
                        Variant="Variant.Text"
                        Color="Color.Secondary"
                        Size="Size.Small"
                        StartIcon="@Icons.Material.Outlined.TrackChanges"
                        OnClick="HandleStartEditGoal"
                        Class="set-goal-btn">
                        Set daily goal
                    </MudButton>
                }
                else
                {
                    <div class="d-flex align-center gap-1 goal-edit-row">
                        <MudNumericField
                            T="int"
                            @bind-Value="_goalInput"
                            Min="1"
                            Max="100"
                            Label="Daily goal"
                            Variant="Variant.Outlined"
                            Margin="Margin.Dense"
                            Style="width: 110px; font-size: 0.8rem;"
                            Class="goal-input" />
                        <MudIconButton
                            Icon="@Icons.Material.Filled.Check"
                            Color="Color.Primary"
                            Size="Size.Small"
                            OnClick="HandleSaveGoal"
                            title="Save goal"
                            Class="goal-save-btn" />
                        <MudIconButton
                            Icon="@Icons.Material.Filled.Close"
                            Color="Color.Default"
                            Size="Size.Small"
                            OnClick="HandleCancelGoal"
                            title="Cancel"
                            Class="goal-cancel-btn" />
                    </div>
                }
            </div>
        }
        @if (_activityStats is not null)
        {
            <div class="d-flex align-center gap-1 mt-3 activity-heatmap-row" title="Past 14 days — daily completions">
                <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mr-1" Style="white-space:nowrap;">14 days:</MudText>
                @foreach (var day in _activityStats.DailyActivity)
                {
                    var isToday = day.Date == DateOnly.FromDateTime(DateTime.Today);
                    var tooltip = $"{day.Date:MMM d}: {day.Count} completed";
                    var cssClass = $"heatmap-day heatmap-day-{GetHeatmapLevel(day.Count)}{(isToday ? " heatmap-today" : "")}";
                    <span class="@cssClass"
                          title="@tooltip"
                          style="@GetHeatmapStyle(day.Count, isToday)"></span>
                }
            </div>
        }
        @if (_activityStats is not null && _activityStats.CompletedThisWeek > 0)
        {
            <div class="d-flex justify-end mt-2">
                <MudButton
                    Variant="Variant.Text"
                    Color="Color.Info"
                    Size="Size.Small"
                    StartIcon="@Icons.Material.Filled.ContentCopy"
                    OnClick="HandleCopyWeeklySummary"
                    Class="copy-weekly-summary-btn">
                    Copy weekly summary
                </MudButton>
            </div>
        }
        @if (stats.Completed > 0)
        {
            <div class="d-flex justify-end mt-2">
                <MudButton
                    Variant="Variant.Text"
                    Color="Color.Error"
                    Size="Size.Small"
                    OnClick="HandleClearCompleted"
                    Class="clear-completed-btn">
                    Clear completed
                </MudButton>
            </div>
        }
    </MudPaper>
}

@if (_isTrashView)
{
    <MudPaper Elevation="1" Class="pa-4 mb-4 trash-view-panel">
        <div class="d-flex align-center gap-2 mb-3">
            <MudIcon Icon="@Icons.Material.Filled.DeleteOutline" Color="Color.Secondary" />
            <MudText Typo="Typo.h6" Class="trash-view-title">Trash</MudText>
            <MudText Typo="Typo.caption" Color="Color.Secondary">Deleted todos — restore or delete permanently</MudText>
            <MudSpacer />
            @if (_trashedTodos is { Count: > 0 })
            {
                <MudButton Variant="Variant.Text" Color="Color.Error" Size="Size.Small"
                           OnClick="HandleEmptyTrash"
                           Class="empty-trash-btn">Empty trash</MudButton>
            }
            <MudButton Variant="Variant.Text" Color="Color.Secondary" Size="Size.Small"
                       OnClick="@(() => HandleSwitchList(_activeListId))"
                       Class="trash-view-exit-btn">Back to list</MudButton>
        </div>
        @if (_trashedTodos is null)
        {
            <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
        }
        else if (_trashedTodos.Count == 0)
        {
            <div class="d-flex flex-column align-center py-6 trash-view-empty">
                <MudIcon Icon="@Icons.Material.Filled.DeleteOutline" Color="Color.Secondary" Style="font-size: 2.5rem;" Class="mb-2" />
                <MudText Typo="Typo.body1" Color="Color.Secondary">Trash is empty.</MudText>
            </div>
        }
        else
        {
            <MudPaper Elevation="0" Style="border: 1px solid var(--mud-palette-divider); border-radius: 6px;">
                <MudList T="TrashedTodo" Dense="true">
                    @foreach (var trashed in _trashedTodos)
                    {
                        var trashId = trashed.TrashId;
                        var listName = _lists?.FirstOrDefault(l => l.Id == trashed.ListId)?.Name ?? "Unknown list";
                        <MudListItem>
                            <div class="d-flex align-center gap-2 flex-grow-1">
                                <div class="flex-grow-1">
                                    <MudText Typo="Typo.body2" Style="@(trashed.IsCompleted ? "text-decoration: line-through; opacity: 0.6;" : "")">@trashed.Title</MudText>
                                    <div class="d-flex align-center gap-2 mt-1">
                                        <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Color="Color.Default" Class="trash-list-chip">@listName</MudChip>
                                        @if (trashed.Priority != TodoPriority.None)
                                        {
                                            <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined"
                                                     Color="@(trashed.Priority == TodoPriority.High ? Color.Error : trashed.Priority == TodoPriority.Medium ? Color.Warning : Color.Info)"
                                                     Class="trash-priority-chip">
                                                @trashed.Priority
                                            </MudChip>
                                        }
                                        <MudText Typo="Typo.caption" Color="Color.Secondary" Class="trash-deleted-at">@FormatDeletedAt(trashed.DeletedAt)</MudText>
                                        <MudText Typo="Typo.caption" Color="@(PurgeDaysRemaining(trashed.DeletedAt) <= 3 ? Color.Error : Color.Secondary)" Class="trash-purge-countdown">@FormatPurgeCountdown(trashed.DeletedAt)</MudText>
                                    </div>
                                </div>
                                <MudIconButton Icon="@Icons.Material.Filled.RestoreFromTrash" Size="Size.Small" Color="Color.Primary"
                                               OnClick="@(async () => await HandleRestoreFromTrash(trashId))"
                                               title="Restore"
                                               Class="restore-trash-btn" />
                                <MudIconButton Icon="@Icons.Material.Filled.DeleteForever" Size="Size.Small" Color="Color.Error"
                                               OnClick="@(async () => await HandlePermanentlyDeleteTrashed(trashId))"
                                               title="Delete forever"
                                               Class="permanently-delete-trash-btn" />
                            </div>
                        </MudListItem>
                    }
                </MudList>
            </MudPaper>
        }
    </MudPaper>
}
else if (_isTodayView && _todos is not null)
{
    var todayGroups = TodayViewHandler.Handle(_todos, _lists ?? []);
    <MudPaper Elevation="1" Class="pa-4 mb-4 today-view-panel">
        <div class="d-flex align-center gap-2 mb-3">
            <MudIcon Icon="@Icons.Material.Filled.WbSunny" Color="Color.Warning" />
            <MudText Typo="Typo.h6" Class="today-view-title">Today</MudText>
            <MudText Typo="Typo.caption" Color="Color.Secondary">Overdue and due today across all lists</MudText>
            <MudSpacer />
            <MudButton Variant="Variant.Text" Color="Color.Secondary" Size="Size.Small"
                       OnClick="@(() => HandleSwitchList(_activeListId))"
                       Class="today-view-exit-btn">Back to list</MudButton>
        </div>
        @if (todayGroups.Count == 0)
        {
            <div class="d-flex flex-column align-center py-6 today-view-empty">
                <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Color="Color.Success" Style="font-size: 2.5rem;" Class="mb-2" />
                <MudText Typo="Typo.body1" Color="Color.Secondary">You're all caught up! No overdue or due-today todos.</MudText>
            </div>
        }
        else
        {
            @foreach (var group in todayGroups)
            {
                var groupListId = group.ListId;
                <div class="today-view-group mb-4">
                    <div class="d-flex align-center gap-2 mb-2 today-view-group-header">
                        <MudText Typo="Typo.overline" Color="Color.Primary" Style="font-weight:600;">@group.ListName</MudText>
                        <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Color="Color.Default"
                                 Class="today-view-group-count">@group.Todos.Count</MudChip>
                        <MudButton Variant="Variant.Text" Color="Color.Secondary" Size="Size.Small"
                                   OnClick="@(() => HandleSwitchList(groupListId))"
                                   Class="today-view-go-to-list-btn">Go to list</MudButton>
                    </div>
                    <MudPaper Elevation="0" Style="border: 1px solid var(--mud-palette-divider); border-radius: 6px;">
                        <MudList T="TodoSummary" Dense="true">
                            @foreach (var todo in group.Todos)
                            {
                                var dueDateStatus = GetDueDateStatus(todo);
                                <MudListItem>
                                    <div class="d-flex align-center gap-2 flex-grow-1">
                                        <MudCheckBox
                                            Value="@todo.IsCompleted"
                                            ValueChanged="@(async (bool _) => await HandleToggleComplete(todo.Id))"
                                            Color="Color.Primary" />
                                        <div class="flex-grow-1">
                                            <MudText Typo="Typo.body2" Style="@(todo.IsCompleted ? "text-decoration: line-through; opacity: 0.6;" : "")">@todo.Title</MudText>
                                            <div class="d-flex align-center gap-2 mt-1">
                                                @if (dueDateStatus == DueDateStatus.Overdue)
                                                {
                                                    <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Color="Color.Error"
                                                             Class="today-view-overdue-chip">
                                                        ⚠ @FormatDueDateDisplay(todo.DueDate!.Value)
                                                    </MudChip>
                                                }
                                                else
                                                {
                                                    <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Color="Color.Warning"
                                                             Class="today-view-today-chip">
                                                        Due today
                                                    </MudChip>
                                                }
                                                @if (todo.Priority != TodoPriority.None)
                                                {
                                                    <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined"
                                                             Color="@(todo.Priority == TodoPriority.High ? Color.Error : todo.Priority == TodoPriority.Medium ? Color.Warning : Color.Info)"
                                                             Class="today-view-priority-chip">
                                                        @todo.Priority
                                                    </MudChip>
                                                }
                                            </div>
                                        </div>
                                        <MudIconButton
                                            Icon="@Icons.Material.Filled.Delete"
                                            Size="Size.Small"
                                            Color="Color.Default"
                                            OnClick="@(async () => await HandleDeleteTodo(todo.Id))"
                                            title="Delete"
                                            Class="today-view-delete-btn" />
                                    </div>
                                </MudListItem>
                            }
                        </MudList>
                    </MudPaper>
                </div>
            }
        }
    </MudPaper>
}
else if (_todos is null)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
}
else if (_todos.Count == 0)
{
    <MudPaper Elevation="1" Class="pa-8 d-flex justify-center align-center">
        <MudText Typo="Typo.body1" Color="Color.Secondary">No todos yet — add one above!</MudText>
    </MudPaper>
}
else
{
    <MudCard Elevation="1" Class="mb-4">
        <MudCardContent Class="pb-3">
            <MudTextField
                @bind-Value="_searchQuery"
                Label="Search todos and notes..."
                Variant="Variant.Outlined"
                Adornment="Adornment.Start"
                AdornmentIcon="@Icons.Material.Filled.Search"
                Clearable="true"
                Immediate="true"
                Class="mb-2 todo-search-field" />
            @if (IsGlobalSearch)
            {
                <div class="d-flex align-center gap-1 mb-2 search-all-lists-hint">
                    <MudIcon Icon="@Icons.Material.Filled.Layers" Size="Size.Small" Color="Color.Info" />
                    <MudText Typo="Typo.caption" Color="Color.Info">Showing results across all lists</MudText>
                </div>
            }
            <div class="d-flex align-center gap-2 flex-wrap justify-space-between">
                <div class="d-flex align-center gap-2 flex-wrap">
                    <MudButtonGroup Variant="Variant.Outlined" Size="Size.Small">
                        <MudButton
                            Color="Color.Primary"
                            Variant="@(_statusFilter == TodoStatusFilter.All ? Variant.Filled : Variant.Outlined)"
                            OnClick="@(() => _statusFilter = TodoStatusFilter.All)">All</MudButton>
                        <MudButton
                            Color="Color.Primary"
                            Variant="@(_statusFilter == TodoStatusFilter.Active ? Variant.Filled : Variant.Outlined)"
                            OnClick="@(() => _statusFilter = TodoStatusFilter.Active)">Active</MudButton>
                        <MudButton
                            Color="Color.Primary"
                            Variant="@(_statusFilter == TodoStatusFilter.Completed ? Variant.Filled : Variant.Outlined)"
                            OnClick="@(() => _statusFilter = TodoStatusFilter.Completed)">Completed</MudButton>
                    </MudButtonGroup>
                    <MudButton
                        Variant="@(_isSelectMode ? Variant.Filled : Variant.Outlined)"
                        Color="@(_isSelectMode ? Color.Warning : Color.Default)"
                        Size="Size.Small"
                        OnClick="HandleToggleSelectMode"
                        Class="select-mode-btn">
                        @(_isSelectMode ? "Cancel" : "Select")
                    </MudButton>
                    @if (_isSelectMode)
                    {
                        @if (AreAllDisplayedSelected)
                        {
                            <MudButton
                                Variant="Variant.Text"
                                Color="Color.Warning"
                                Size="Size.Small"
                                OnClick="HandleDeselectAll"
                                Class="deselect-all-btn">
                                Deselect all
                            </MudButton>
                        }
                        else
                        {
                            <MudButton
                                Variant="Variant.Text"
                                Color="Color.Warning"
                                Size="Size.Small"
                                OnClick="HandleSelectAll"
                                Class="select-all-btn">
                                Select all
                            </MudButton>
                        }
                    }
                    <MudButton
                        Variant="@(_isFocusMode ? Variant.Filled : Variant.Outlined)"
                        Color="@(_isFocusMode ? Color.Success : Color.Default)"
                        Size="Size.Small"
                        StartIcon="@Icons.Material.Filled.FilterCenterFocus"
                        OnClick="HandleToggleFocusMode"
                        title="Focus mode — show only urgent and important todos"
                        Class="focus-mode-btn">
                        Focus
                    </MudButton>
                    @if (DisplayedTodos.Any(t => !t.IsCompleted))
                    {
                        <MudButton
                            Variant="Variant.Outlined"
                            Color="Color.Secondary"
                            Size="Size.Small"
                            StartIcon="@Icons.Material.Filled.Casino"
                            OnClick="HandlePickForMe"
                            title="Pick a random active todo to work on"
                            Class="pick-for-me-btn">
                            Pick for me
                        </MudButton>
                    }
                </div>
                <div class="d-flex align-center gap-1">
                    <MudSelect
                        T="TodoSortOrder"
                        @bind-Value="_sortOrder"
                        Label="Sort"
                        Variant="Variant.Outlined"
                        Dense="true"
                        Style="min-width: 150px;">
                        <MudSelectItem Value="@TodoSortOrder.Recommended">Recommended</MudSelectItem>
                        <MudSelectItem Value="@TodoSortOrder.Newest">Newest first</MudSelectItem>
                        <MudSelectItem Value="@TodoSortOrder.Oldest">Oldest first</MudSelectItem>
                        <MudSelectItem Value="@TodoSortOrder.DueDateAsc">Due date</MudSelectItem>
                        <MudSelectItem Value="@TodoSortOrder.PriorityDesc">Priority</MudSelectItem>
                        <MudSelectItem Value="@TodoSortOrder.TitleAsc">Title A→Z</MudSelectItem>
                        <MudSelectItem Value="@TodoSortOrder.TitleDesc">Title Z→A</MudSelectItem>
                        <MudSelectItem Value="@TodoSortOrder.TimeEstimateAsc">Shortest first</MudSelectItem>
                        <MudSelectItem Value="@TodoSortOrder.TimeEstimateDesc">Longest first</MudSelectItem>
                        <MudSelectItem Value="@TodoSortOrder.Manual">Custom order</MudSelectItem>
                    </MudSelect>
                    <MudTooltip Text="Calendar view">
                        <MudIconButton
                            Icon="@Icons.Material.Filled.CalendarMonth"
                            Size="Size.Small"
                            Color="Color.Default"
                            OnClick="HandleOpenCalendar"
                            title="Calendar view"
                            Class="calendar-view-btn" />
                    </MudTooltip>
                    <MudTooltip Text="Analytics">
                        <MudIconButton
                            Icon="@Icons.Material.Filled.BarChart"
                            Size="Size.Small"
                            Color="Color.Default"
                            OnClick="HandleOpenAnalytics"
                            title="Analytics"
                            Class="analytics-view-btn" />
                    </MudTooltip>
                    <MudTooltip Text="@(_remindersEnabled ? "Reminders enabled — click to disable" : "Enable due date reminders")">
                        <MudIconButton
                            Icon="@(_remindersEnabled ? Icons.Material.Filled.NotificationsActive : Icons.Material.Filled.NotificationsNone)"
                            Size="Size.Small"
                            Color="@(_remindersEnabled ? Color.Primary : Color.Default)"
                            OnClick="HandleToggleReminders"
                            title="@(_remindersEnabled ? "Reminders enabled" : "Enable due date reminders")"
                            Class="reminders-toggle-btn" />
                    </MudTooltip>
                    <MudTooltip Text="Export to CSV">
                        <MudIconButton
                            Icon="@Icons.Material.Filled.FileDownload"
                            Size="Size.Small"
                            Color="Color.Default"
                            OnClick="HandleExportCsv"
                            title="Export to CSV"
                            Class="export-csv-btn" />
                    </MudTooltip>
                    <MudTooltip Text="Export to Markdown">
                        <MudIconButton
                            Icon="@Icons.Material.Filled.Description"
                            Size="Size.Small"
                            Color="Color.Default"
                            OnClick="HandleExportMarkdown"
                            title="Export to Markdown"
                            Class="export-markdown-btn" />
                    </MudTooltip>
                    <MudTooltip Text="Export to JSON">
                        <MudIconButton
                            Icon="@Icons.Material.Filled.DataObject"
                            Size="Size.Small"
                            Color="Color.Default"
                            OnClick="HandleExportJson"
                            title="Export to JSON"
                            Class="export-json-btn" />
                    </MudTooltip>
                    <MudTooltip Text="Import from CSV">
                        <MudIconButton
                            Icon="@Icons.Material.Filled.FileUpload"
                            Size="Size.Small"
                            Color="Color.Default"
                            OnClick="HandleImportClick"
                            title="Import from CSV"
                            Class="import-csv-btn" />
                    </MudTooltip>
                    <MudTooltip Text="Import from Markdown">
                        <MudIconButton
                            Icon="@Icons.Material.Filled.UploadFile"
                            Size="Size.Small"
                            Color="Color.Default"
                            OnClick="HandleImportMarkdownClick"
                            title="Import from Markdown"
                            Class="import-markdown-btn" />
                    </MudTooltip>
                    <MudTooltip Text="Import from JSON">
                        <MudIconButton
                            Icon="@Icons.Material.Filled.DataArray"
                            Size="Size.Small"
                            Color="Color.Default"
                            OnClick="HandleImportJsonClick"
                            title="Import from JSON"
                            Class="import-json-btn" />
                    </MudTooltip>
                    <InputFile id="csv-import-input" OnChange="HandleFileSelected" accept=".csv" style="display:none;" />
                    <InputFile id="md-import-input" OnChange="HandleMarkdownFileSelected" accept=".md" style="display:none;" />
                    <InputFile id="json-import-input" OnChange="HandleJsonFileSelected" accept=".json" style="display:none;" />
                </div>
            </div>
            <div class="d-flex align-center gap-1 flex-wrap mt-3 priority-filter-row">
                <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mr-1">Priority:</MudText>
                <MudChip T="string" Size="Size.Small"
                         Variant="@(_priorityFilter is null ? Variant.Filled : Variant.Outlined)"
                         Color="Color.Secondary"
                         OnClick="@(() => _priorityFilter = null)"
                         Class="priority-filter-all">All</MudChip>
                @foreach (var p in new[] { TodoPriority.High, TodoPriority.Medium, TodoPriority.Low, TodoPriority.None })
                {
                    var pri = p;
                    var priCount = GetFilterCounts().ByPriority.GetValueOrDefault(pri);
                    <MudChip T="string" Size="Size.Small"
                             Variant="@(_priorityFilter == pri ? Variant.Filled : Variant.Outlined)"
                             Color="@GetPriorityColor(pri)"
                             OnClick="@(() => _priorityFilter = pri)"
                             Class="@($"priority-filter-{pri.ToString().ToLower()}")">
                        @(pri == TodoPriority.None ? "None" : pri.ToString())@(priCount > 0 ? $" ({priCount})" : "")
                    </MudChip>
                }
            </div>
            <div class="d-flex align-center gap-1 flex-wrap mt-2 date-filter-row">
                <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mr-1">Due:</MudText>
                <MudChip T="string" Size="Size.Small"
                         Variant="@(_dateFilter == TodoDateFilter.None ? Variant.Filled : Variant.Outlined)"
                         Color="Color.Secondary"
                         OnClick="@(() => _dateFilter = TodoDateFilter.None)"
                         Class="date-filter-all">Any</MudChip>
                <MudChip T="string" Size="Size.Small"
                         Variant="@(_dateFilter == TodoDateFilter.Overdue ? Variant.Filled : Variant.Outlined)"
                         Color="Color.Error"
                         OnClick="@(() => _dateFilter = TodoDateFilter.Overdue)"
                         Class="date-filter-overdue">Overdue</MudChip>
                <MudChip T="string" Size="Size.Small"
                         Variant="@(_dateFilter == TodoDateFilter.DueToday ? Variant.Filled : Variant.Outlined)"
                         Color="Color.Warning"
                         OnClick="@(() => _dateFilter = TodoDateFilter.DueToday)"
                         Class="date-filter-today">Today</MudChip>
                <MudChip T="string" Size="Size.Small"
                         Variant="@(_dateFilter == TodoDateFilter.DueThisWeek ? Variant.Filled : Variant.Outlined)"
                         Color="Color.Info"
                         OnClick="@(() => _dateFilter = TodoDateFilter.DueThisWeek)"
                         Class="date-filter-week">This week</MudChip>
                @{
                    var noDueDateCount = GetFilterCounts().NoDueDate;
                }
                <MudChip T="string" Size="Size.Small"
                         Variant="@(_dateFilter == TodoDateFilter.NoDueDate ? Variant.Filled : Variant.Outlined)"
                         Color="Color.Default"
                         OnClick="@(() => _dateFilter = TodoDateFilter.NoDueDate)"
                         Class="date-filter-no-date">No date@(noDueDateCount > 0 ? $" ({noDueDateCount})" : "")</MudChip>
            </div>
            @if (AllTagNames.Count > 0)
            {
                <div class="d-flex align-center gap-1 flex-wrap mt-2 tag-filter-row">
                    <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mr-1">Tag:</MudText>
                    <MudChip T="string"
                             Size="Size.Small"
                             Variant="@(_tagFilter is null ? Variant.Filled : Variant.Outlined)"
                             Color="Color.Secondary"
                             OnClick="@(() => _tagFilter = null)"
                             Class="tag-filter-all">All</MudChip>
                    @foreach (var name in AllTagNames)
                    {
                        var tagName = name;
                        @if (_renamingTagName == tagName)
                        {
                            var renamingTag = tagName;
                            <MudTextField
                                @bind-Value="_renameTagValue"
                                Variant="Variant.Outlined"
                                Margin="Margin.Dense"
                                Style="width: 100px; font-size: 0.75rem;"
                                OnKeyUp="@(async (KeyboardEventArgs e) => await HandleRenameTagKeyUp(e, renamingTag))"
                                Class="rename-tag-input" />
                        }
                        else
                        {
                            <MudChip T="string"
                                     Size="Size.Small"
                                     Variant="@(_tagFilter == tagName ? Variant.Filled : Variant.Outlined)"
                                     Color="Color.Secondary"
                                     OnClick="@(() => _tagFilter = tagName)"
                                     Class="tag-filter-chip"
                                     @ondblclick="@(() => HandleStartRenameTag(tagName))">@tagName@(GetFilterCounts().ByTag.GetValueOrDefault(tagName) is var tc && tc > 0 ? $" ({tc})" : "")</MudChip>
                        }
                    }
                </div>
            }
            <div class="d-flex align-center gap-1 flex-wrap mt-2 color-filter-row">
                <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mr-1">Color:</MudText>
                <span class="color-filter-dot color-filter-all @(_colorFilter is null ? "color-dot-selected" : "")"
                      style="display:inline-block;width:18px;height:18px;border-radius:50%;background:#9e9e9e;border:2px solid @(_colorFilter is null ? "var(--mud-palette-primary)" : "transparent");cursor:pointer;vertical-align:middle;"
                      title="Any color"
                      @onclick="@(() => _colorFilter = null)"></span>
                @foreach (var cl in new[] { TodoColorLabel.Red, TodoColorLabel.Orange, TodoColorLabel.Yellow, TodoColorLabel.Green, TodoColorLabel.Blue, TodoColorLabel.Purple })
                {
                    var label = cl;
                    <span class="color-filter-dot color-filter-@(label.ToString().ToLower())"
                          style="display:inline-block;width:18px;height:18px;border-radius:50%;background:@GetColorCss(label);border:2px solid @(_colorFilter == label ? "var(--mud-palette-primary)" : "transparent");cursor:pointer;vertical-align:middle;"
                          title="@label"
                          @onclick="@(() => _colorFilter = label)"></span>
                }
            </div>
            <div class="d-flex align-center gap-1 flex-wrap mt-2 time-estimate-filter-row">
                <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mr-1">Time:</MudText>
                <MudChip T="string" Size="Size.Small"
                         Variant="@(_timeEstimateFilter == TodoTimeEstimateFilter.Any ? Variant.Filled : Variant.Outlined)"
                         Color="Color.Secondary"
                         OnClick="@(() => _timeEstimateFilter = TodoTimeEstimateFilter.Any)"
                         Class="time-filter-any">Any</MudChip>
                <MudChip T="string" Size="Size.Small"
                         Variant="@(_timeEstimateFilter == TodoTimeEstimateFilter.NoEstimate ? Variant.Filled : Variant.Outlined)"
                         Color="Color.Default"
                         OnClick="@(() => _timeEstimateFilter = TodoTimeEstimateFilter.NoEstimate)"
                         Class="time-filter-none">No estimate</MudChip>
                <MudChip T="string" Size="Size.Small"
                         Variant="@(_timeEstimateFilter == TodoTimeEstimateFilter.Max15Min ? Variant.Filled : Variant.Outlined)"
                         Color="Color.Tertiary"
                         OnClick="@(() => _timeEstimateFilter = TodoTimeEstimateFilter.Max15Min)"
                         Class="time-filter-15min">≤15 min</MudChip>
                <MudChip T="string" Size="Size.Small"
                         Variant="@(_timeEstimateFilter == TodoTimeEstimateFilter.Max30Min ? Variant.Filled : Variant.Outlined)"
                         Color="Color.Tertiary"
                         OnClick="@(() => _timeEstimateFilter = TodoTimeEstimateFilter.Max30Min)"
                         Class="time-filter-30min">≤30 min</MudChip>
                <MudChip T="string" Size="Size.Small"
                         Variant="@(_timeEstimateFilter == TodoTimeEstimateFilter.Max1Hour ? Variant.Filled : Variant.Outlined)"
                         Color="Color.Tertiary"
                         OnClick="@(() => _timeEstimateFilter = TodoTimeEstimateFilter.Max1Hour)"
                         Class="time-filter-1hour">≤1 hour</MudChip>
                <MudChip T="string" Size="Size.Small"
                         Variant="@(_timeEstimateFilter == TodoTimeEstimateFilter.Max2Hours ? Variant.Filled : Variant.Outlined)"
                         Color="Color.Tertiary"
                         OnClick="@(() => _timeEstimateFilter = TodoTimeEstimateFilter.Max2Hours)"
                         Class="time-filter-2hours">≤2 hours</MudChip>
            </div>
            <div class="d-flex align-center gap-1 flex-wrap mt-2 staleness-filter-row">
                <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mr-1">Age:</MudText>
                <MudChip T="string" Size="Size.Small"
                         Variant="@(_stalenessFilter == TodoStalenessFilter.Any ? Variant.Filled : Variant.Outlined)"
                         Color="Color.Secondary"
                         OnClick="@(() => _stalenessFilter = TodoStalenessFilter.Any)"
                         Class="staleness-filter-any">Any</MudChip>
                <MudChip T="string" Size="Size.Small"
                         Variant="@(_stalenessFilter == TodoStalenessFilter.OneWeekPlus ? Variant.Filled : Variant.Outlined)"
                         Color="Color.Warning"
                         OnClick="@(() => _stalenessFilter = TodoStalenessFilter.OneWeekPlus)"
                         Class="staleness-filter-1week">1+ week old</MudChip>
                <MudChip T="string" Size="Size.Small"
                         Variant="@(_stalenessFilter == TodoStalenessFilter.TwoWeeksPlus ? Variant.Filled : Variant.Outlined)"
                         Color="Color.Warning"
                         OnClick="@(() => _stalenessFilter = TodoStalenessFilter.TwoWeeksPlus)"
                         Class="staleness-filter-2weeks">2+ weeks old</MudChip>
                <MudChip T="string" Size="Size.Small"
                         Variant="@(_stalenessFilter == TodoStalenessFilter.OneMonthPlus ? Variant.Filled : Variant.Outlined)"
                         Color="Color.Error"
                         OnClick="@(() => _stalenessFilter = TodoStalenessFilter.OneMonthPlus)"
                         Class="staleness-filter-1month">1+ month old</MudChip>
            </div>
            @{
                var blockedCount = _todos?.Count(t => t.ListId == _activeListId && t.IsBlocked && !t.IsCompleted) ?? 0;
            }
            <div class="d-flex align-center gap-1 flex-wrap mt-2 blocked-filter-row">
                <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mr-1">Blocked:</MudText>
                <MudChip T="string" Size="Size.Small"
                         Variant="@(_blockedFilter ? Variant.Filled : Variant.Outlined)"
                         Color="Color.Warning"
                         OnClick="@(() => _blockedFilter = !_blockedFilter)"
                         Class="blocked-filter-chip"
                         title="Show only blocked / waiting-for todos">
                    ⏸ Waiting for@(blockedCount > 0 ? $" ({blockedCount})" : "")
                </MudChip>
            </div>
            @if (HasActiveFilters)
            {
                <div class="d-flex justify-end mt-2 clear-filters-row">
                    <MudButton
                        Variant="Variant.Text"
                        Color="Color.Secondary"
                        Size="Size.Small"
                        StartIcon="@Icons.Material.Filled.FilterAltOff"
                        OnClick="HandleClearAllFilters"
                        Class="clear-all-filters-btn">
                        Clear all filters
                    </MudButton>
                </div>
            }
            @if (_filterPresets is { Count: > 0 } || HasActiveFilters)
            {
                <div class="d-flex align-center gap-1 flex-wrap mt-2 filter-presets-row">
                    <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mr-1">Presets:</MudText>
                    @if (_filterPresets is not null)
                    {
                        @foreach (var preset in _filterPresets)
                        {
                            var p = preset;
                            <MudChip T="string"
                                     Size="Size.Small"
                                     Variant="Variant.Outlined"
                                     Color="Color.Info"
                                     OnClick="@(() => HandleApplyPreset(p))"
                                     OnClose="@(async (MudChip<string> _) => await HandleDeletePreset(p.Id))"
                                     Class="filter-preset-chip">
                                @preset.Name
                            </MudChip>
                        }
                    }
                    @if (HasActiveFilters)
                    {
                        @if (_savingPreset)
                        {
                            <div class="d-flex align-center gap-1 save-preset-input-row">
                                <MudTextField
                                    @bind-Value="_presetNameInput"
                                    Placeholder="Preset name…"
                                    Variant="Variant.Outlined"
                                    Margin="Margin.Dense"
                                    Style="width: 130px; font-size: 0.75rem;"
                                    OnKeyUp="HandlePresetNameKeyUp"
                                    Class="preset-name-input" />
                                <MudIconButton
                                    Icon="@Icons.Material.Filled.Check"
                                    Color="Color.Primary"
                                    Size="Size.Small"
                                    OnClick="HandleSavePreset"
                                    title="Save preset"
                                    Class="save-preset-confirm-btn" />
                                <MudIconButton
                                    Icon="@Icons.Material.Filled.Close"
                                    Color="Color.Default"
                                    Size="Size.Small"
                                    OnClick="@(() => { _savingPreset = false; _presetNameInput = string.Empty; })"
                                    title="Cancel"
                                    Class="save-preset-cancel-btn" />
                            </div>
                        }
                        else
                        {
                            <MudIconButton
                                Icon="@Icons.Material.Filled.BookmarkAdd"
                                Color="Color.Info"
                                Size="Size.Small"
                                OnClick="@(() => { _savingPreset = true; _presetNameInput = string.Empty; })"
                                title="Save current filters as a preset"
                                Class="save-preset-btn" />
                        }
                    }
                </div>
            }
        </MudCardContent>
    </MudCard>

    @if (GetUrgencyBannerSummary() is { } urgency && !_dismissedUrgencyBanner && _dateFilter == TodoDateFilter.None)
    {
        <MudPaper Elevation="0" Class="pa-3 mb-3 d-flex align-center gap-2 flex-wrap urgency-banner"
                  Style="background: var(--mud-palette-error-lighten); border: 1px solid var(--mud-palette-error); border-radius: 8px;">
            <MudIcon Icon="@Icons.Material.Filled.NotificationImportant" Color="Color.Error" Size="Size.Small" />
            <div class="d-flex align-center gap-2 flex-wrap flex-grow-1 urgency-banner-content">
                @if (urgency.Overdue > 0)
                {
                    <MudText Typo="Typo.body2" Color="Color.Error" Class="urgency-overdue-text">
                        <strong>@urgency.Overdue overdue</strong>
                    </MudText>
                    <MudButton Variant="Variant.Outlined" Color="Color.Error" Size="Size.Small"
                               OnClick="@(() => { _dateFilter = TodoDateFilter.Overdue; _dismissedUrgencyBanner = true; })"
                               Class="urgency-show-overdue-btn">
                        Show overdue
                    </MudButton>
                }
                @if (urgency.Overdue > 0 && urgency.DueToday > 0)
                {
                    <MudText Typo="Typo.body2" Color="Color.Error">·</MudText>
                }
                @if (urgency.DueToday > 0)
                {
                    <MudText Typo="Typo.body2" Color="Color.Warning" Class="urgency-today-text">
                        <strong>@urgency.DueToday due today</strong>
                    </MudText>
                    <MudButton Variant="Variant.Outlined" Color="Color.Warning" Size="Size.Small"
                               OnClick="@(() => { _dateFilter = TodoDateFilter.DueToday; _dismissedUrgencyBanner = true; })"
                               Class="urgency-show-today-btn">
                        Show today's
                    </MudButton>
                }
                @if (urgency.Overdue > 0)
                {
                    <div class="w-100 d-flex align-center gap-1 flex-wrap mt-1 reschedule-overdue-row">
                        <MudText Typo="Typo.caption" Color="Color.Secondary" Style="white-space:nowrap;">Reschedule all overdue:</MudText>
                        <MudButton Variant="Variant.Text" Color="Color.Error" Size="Size.Small"
                                   OnClick="@(async () => await HandleRescheduleOverdue(DateTime.Today))"
                                   Class="reschedule-today-btn">
                            → Today
                        </MudButton>
                        <MudButton Variant="Variant.Text" Color="Color.Error" Size="Size.Small"
                                   OnClick="@(async () => await HandleRescheduleOverdue(DateTime.Today.AddDays(1)))"
                                   Class="reschedule-tomorrow-btn">
                            → Tomorrow
                        </MudButton>
                    </div>
                }
            </div>
            <MudIconButton Icon="@Icons.Material.Filled.Close" Color="Color.Error" Size="Size.Small"
                           OnClick="@(() => _dismissedUrgencyBanner = true)"
                           title="Dismiss"
                           Class="urgency-dismiss-btn" />
        </MudPaper>
    }

    @if (_activityStats is not null && StreakNudgeHandler.ShouldNudge(_activityStats.CurrentStreak, _activityStats.CompletedToday) && !_dismissedStreakNudge)
    {
        <MudPaper Elevation="0" Class="pa-3 mb-3 d-flex align-center gap-2 streak-nudge-banner"
                  Style="background: var(--mud-palette-warning-lighten); border: 1px solid var(--mud-palette-warning); border-radius: 8px;">
            <MudIcon Icon="@Icons.Material.Filled.LocalFireDepartment" Color="Color.Warning" Size="Size.Small" />
            <MudText Typo="Typo.body2" Color="Color.Warning" Class="flex-grow-1 streak-nudge-text">
                <strong>Your @_activityStats.CurrentStreak-day streak is at risk!</strong> Complete at least 1 todo today to keep it going.
            </MudText>
            <MudIconButton Icon="@Icons.Material.Filled.Close" Color="Color.Warning" Size="Size.Small"
                           OnClick="@(() => _dismissedStreakNudge = true)"
                           title="Dismiss"
                           Class="streak-nudge-dismiss-btn" />
        </MudPaper>
    }

    @if (_isFocusMode)
    {
        var focusTodos = FocusModeHandler.Handle(_todos!.Where(t => t.ListId == _activeListId).ToList());
        var focusMinutes = focusTodos
            .Where(t => t.TimeEstimate != TimeEstimate.None)
            .Sum(t => (int)t.TimeEstimate);
        <MudPaper Elevation="0" Class="pa-3 mb-3 d-flex align-center gap-2 focus-mode-banner"
                  Style="background: var(--mud-palette-success-lighten); border: 1px solid var(--mud-palette-success); border-radius: 8px;">
            <MudIcon Icon="@Icons.Material.Filled.FilterCenterFocus" Color="Color.Success" Size="Size.Small" />
            <MudText Typo="Typo.body2" Color="Color.Success">
                <strong>Focus mode</strong> — @(focusTodos.Count == 0 ? "nothing urgent right now" : $"{focusTodos.Count} todo{(focusTodos.Count == 1 ? "" : "s")} need attention")
                @if (focusMinutes > 0)
                {
                    <span> · ~@FormatEstimatedTime(focusMinutes)</span>
                }
            </MudText>
            <MudSpacer />
            <MudButton Variant="Variant.Text" Color="Color.Success" Size="Size.Small" OnClick="HandleToggleFocusMode" Class="focus-mode-exit-btn">Exit focus</MudButton>
        </MudPaper>
    }

    @if (_isSelectMode && _selectedIds.Count > 0)
    {
        <MudPaper Elevation="1" Class="pa-3 mb-3 d-flex align-center gap-3 flex-wrap bulk-action-bar">
            <MudText Typo="Typo.body2">@_selectedIds.Count selected</MudText>
            <MudSpacer />
            <MudButton
                Variant="Variant.Filled"
                Color="Color.Primary"
                Size="Size.Small"
                OnClick="HandleBulkComplete"
                Class="bulk-complete-btn">
                Mark Complete
            </MudButton>
            @if (_lists is { Count: > 1 })
            {
                <div class="d-flex align-center gap-1 bulk-move-row">
                    <MudSelect
                        T="int"
                        @bind-Value="_bulkMoveTargetListId"
                        Label="Move to list"
                        Variant="Variant.Outlined"
                        Dense="true"
                        Style="min-width: 130px; font-size: 0.8rem;"
                        Class="bulk-move-select">
                        @foreach (var list in _lists.Where(l => l.Id != _activeListId))
                        {
                            <MudSelectItem Value="@list.Id">@list.Name</MudSelectItem>
                        }
                    </MudSelect>
                    <MudButton
                        Variant="Variant.Filled"
                        Color="Color.Info"
                        Size="Size.Small"
                        Disabled="@(_bulkMoveTargetListId == 0)"
                        OnClick="HandleBulkMove"
                        Class="bulk-move-btn">
                        Move
                    </MudButton>
                </div>
            }
            <div class="d-flex align-center gap-1 bulk-tag-row">
                <MudTextField
                    @bind-Value="_bulkTagInput"
                    Placeholder="Tag name..."
                    Variant="Variant.Outlined"
                    Margin="Margin.Dense"
                    Style="min-width: 110px; font-size: 0.8rem;"
                    Class="bulk-tag-input" />
                <MudButton
                    Variant="Variant.Filled"
                    Color="Color.Secondary"
                    Size="Size.Small"
                    Disabled="@(string.IsNullOrWhiteSpace(_bulkTagInput))"
                    OnClick="HandleBulkAddTag"
                    Class="bulk-tag-btn">
                    Tag
                </MudButton>
            </div>
            <div class="d-flex align-center gap-1 bulk-priority-row">
                <MudSelect
                    T="TodoPriority?"
                    @bind-Value="_bulkPriority"
                    Label="Priority"
                    Variant="Variant.Outlined"
                    Dense="true"
                    Style="min-width: 120px; font-size: 0.8rem;"
                    Class="bulk-priority-select">
                    <MudSelectItem T="TodoPriority?" Value="@((TodoPriority?)null)">Select…</MudSelectItem>
                    <MudSelectItem T="TodoPriority?" Value="@((TodoPriority?)TodoPriority.High)">High</MudSelectItem>
                    <MudSelectItem T="TodoPriority?" Value="@((TodoPriority?)TodoPriority.Medium)">Medium</MudSelectItem>
                    <MudSelectItem T="TodoPriority?" Value="@((TodoPriority?)TodoPriority.Low)">Low</MudSelectItem>
                    <MudSelectItem T="TodoPriority?" Value="@((TodoPriority?)TodoPriority.None)">None</MudSelectItem>
                </MudSelect>
                <MudButton
                    Variant="Variant.Filled"
                    Color="Color.Primary"
                    Size="Size.Small"
                    Disabled="@(_bulkPriority is null)"
                    OnClick="HandleBulkSetPriority"
                    Class="bulk-priority-btn">
                    Set Priority
                </MudButton>
            </div>
            <div class="d-flex align-center gap-1 bulk-due-date-row">
                <MudDatePicker
                    @bind-Date="_bulkDueDate"
                    Label="Due date"
                    Variant="Variant.Outlined"
                    Clearable="true"
                    Style="min-width: 150px; font-size: 0.8rem;"
                    Class="bulk-due-date-picker" />
                <MudButton
                    Variant="Variant.Filled"
                    Color="Color.Secondary"
                    Size="Size.Small"
                    Disabled="@(_bulkDueDate is null)"
                    OnClick="HandleBulkSetDueDate"
                    Class="bulk-due-date-btn">
                    Set Date
                </MudButton>
                @if (_bulkDueDate is not null)
                {
                    <MudButton
                        Variant="Variant.Text"
                        Color="Color.Default"
                        Size="Size.Small"
                        OnClick="HandleBulkClearDueDate"
                        Class="bulk-due-date-clear-btn">
                        Clear date
                    </MudButton>
                }
            </div>
            <div class="d-flex align-center gap-1 bulk-time-estimate-row">
                <MudSelect
                    T="TimeEstimate?"
                    @bind-Value="_bulkTimeEstimate"
                    Label="Time estimate"
                    Variant="Variant.Outlined"
                    Dense="true"
                    Style="min-width: 130px; font-size: 0.8rem;"
                    Class="bulk-time-estimate-select">
                    <MudSelectItem T="TimeEstimate?" Value="@((TimeEstimate?)null)">Select…</MudSelectItem>
                    <MudSelectItem T="TimeEstimate?" Value="@((TimeEstimate?)TimeEstimate.None)">No estimate</MudSelectItem>
                    <MudSelectItem T="TimeEstimate?" Value="@((TimeEstimate?)TimeEstimate.FifteenMinutes)">15 min</MudSelectItem>
                    <MudSelectItem T="TimeEstimate?" Value="@((TimeEstimate?)TimeEstimate.ThirtyMinutes)">30 min</MudSelectItem>
                    <MudSelectItem T="TimeEstimate?" Value="@((TimeEstimate?)TimeEstimate.OneHour)">1 hour</MudSelectItem>
                    <MudSelectItem T="TimeEstimate?" Value="@((TimeEstimate?)TimeEstimate.TwoHours)">2 hours</MudSelectItem>
                    <MudSelectItem T="TimeEstimate?" Value="@((TimeEstimate?)TimeEstimate.FourHours)">4 hours</MudSelectItem>
                    <MudSelectItem T="TimeEstimate?" Value="@((TimeEstimate?)TimeEstimate.OneDay)">1 day</MudSelectItem>
                </MudSelect>
                <MudButton
                    Variant="Variant.Filled"
                    Color="Color.Tertiary"
                    Size="Size.Small"
                    Disabled="@(_bulkTimeEstimate is null)"
                    OnClick="HandleBulkSetTimeEstimate"
                    Class="bulk-time-estimate-btn">
                    Set Time
                </MudButton>
            </div>
            <div class="d-flex align-center gap-1 bulk-color-label-row">
                <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mr-1">Color:</MudText>
                <span class="bulk-color-none @(_bulkColorLabel == TodoColorLabel.None ? "bulk-color-dot-selected" : "")"
                      style="display:inline-block;width:18px;height:18px;border-radius:50%;background:#9e9e9e;border:2px solid @(_bulkColorLabel == TodoColorLabel.None ? "var(--mud-palette-primary)" : "transparent");cursor:pointer;vertical-align:middle;"
                      title="None"
                      @onclick="@(() => _bulkColorLabel = TodoColorLabel.None)"></span>
                @foreach (var cl in new[] { TodoColorLabel.Red, TodoColorLabel.Orange, TodoColorLabel.Yellow, TodoColorLabel.Green, TodoColorLabel.Blue, TodoColorLabel.Purple })
                {
                    var label = cl;
                    <span class="bulk-color-dot bulk-color-@(label.ToString().ToLower()) @(_bulkColorLabel == label ? "bulk-color-dot-selected" : "")"
                          style="display:inline-block;width:18px;height:18px;border-radius:50%;background:@GetColorCss(label);border:2px solid @(_bulkColorLabel == label ? "var(--mud-palette-primary)" : "transparent");cursor:pointer;vertical-align:middle;"
                          title="@label"
                          @onclick="@(() => _bulkColorLabel = label)"></span>
                }
                <MudButton
                    Variant="Variant.Filled"
                    Color="Color.Primary"
                    Size="Size.Small"
                    Disabled="@(_bulkColorLabel is null)"
                    OnClick="HandleBulkSetColorLabel"
                    Class="bulk-color-label-btn">
                    Set Color
                </MudButton>
            </div>
            <MudButton
                Variant="Variant.Filled"
                Color="Color.Error"
                Size="Size.Small"
                OnClick="HandleBulkDelete"
                Class="bulk-delete-btn">
                Delete
            </MudButton>
        </MudPaper>
    }

    @if (_pickedTodoId.HasValue)
    {
        var picked = DisplayedTodos.FirstOrDefault(t => t.Id == _pickedTodoId.Value);
        @if (picked is not null)
        {
            <MudPaper Elevation="0" Class="pa-3 mb-3 d-flex align-center gap-2 pick-for-me-banner"
                      Style="background: var(--mud-palette-secondary-lighten); border: 1px solid var(--mud-palette-secondary); border-radius: 8px;">
                <MudIcon Icon="@Icons.Material.Filled.Casino" Color="Color.Secondary" Size="Size.Small" />
                <MudText Typo="Typo.body2" Color="Color.Secondary" Class="pick-for-me-title">
                    <strong>You picked:</strong> @picked.Title
                </MudText>
                <MudSpacer />
                <MudButton Variant="Variant.Text" Color="Color.Secondary" Size="Size.Small"
                           OnClick="HandlePickForMe"
                           Class="pick-for-me-again-btn">Pick another</MudButton>
                <MudIconButton Icon="@Icons.Material.Filled.Close" Color="Color.Secondary" Size="Size.Small"
                               OnClick="@(() => _pickedTodoId = null)"
                               title="Dismiss"
                               Class="pick-for-me-dismiss-btn" />
            </MudPaper>
        }
    }

    @if (DisplayedTodos.Count == 0)
    {
        <MudPaper Elevation="1" Class="pa-8 d-flex justify-center align-center">
            <MudText Typo="Typo.body1" Color="Color.Secondary">No todos match your filters.</MudText>
        </MudPaper>
    }
    else
    {
        <MudPaper Elevation="2">
            <MudList T="TodoSummary" Dense="false">
                @{
                    string? _lastGroupLabel = null;
                }
                @foreach (var todo in DisplayedTodos)
                {
                    var todoId = todo.Id;
                    var groupLabel = GetGroupLabel(todo);
                    if (groupLabel != _lastGroupLabel)
                    {
                        _lastGroupLabel = groupLabel;
                        if (groupLabel is not null)
                        {
                            <div class="todo-group-header d-flex align-center gap-2 px-4 pt-3 pb-1"
                                 style="border-top: 1px solid var(--mud-palette-divider);">
                                <MudText Typo="Typo.overline" Color="Color.Secondary" Class="todo-group-label">@groupLabel</MudText>
                            </div>
                        }
                    }
                    <div draggable="@(_sortOrder == TodoSortOrder.Manual ? "true" : "false")"
                         @ondragstart="@(() => _draggingId = todoId)"
                         @ondragend="@(() => { _draggingId = null; _dragOverId = null; })"
                         @ondragover:preventDefault
                         @ondragover="@(() => _dragOverId = todoId)"
                         @ondrop="@(async () => await HandleDrop(todoId))"
                         class="@GetTodoRowClass(todo)"
                         style="@GetTodoRowStyle(todo)"
                         >
                    <MudListItem>
                        <div class="d-flex align-center gap-3 flex-grow-1">
                            @if (_sortOrder == TodoSortOrder.Manual)
                            {
                                <MudIcon Icon="@Icons.Material.Filled.DragIndicator"
                                         Size="Size.Small"
                                         Color="Color.Default"
                                         Style="cursor: grab; opacity: 0.5;"
                                         Class="drag-handle" />
                            }
                            @if (_isSelectMode)
                            {
                                <MudCheckBox
                                    Value="@_selectedIds.Contains(todo.Id)"
                                    ValueChanged="@((bool selected) => HandleToggleTodoSelection(todo.Id, selected))"
                                    Color="Color.Secondary"
                                    Class="todo-select-checkbox" />
                            }
                            <MudCheckBox
                                Value="@todo.IsCompleted"
                                ValueChanged="@(async (bool _) => await HandleToggleComplete(todo.Id))"
                                Color="Color.Primary" />
                            <div class="flex-grow-1">
                                @if (_editingTodoId == todo.Id)
                                {
                                    <div class="d-flex flex-column gap-2 todo-edit-form">
                                        <div class="d-flex align-center gap-2">
                                            <MudTextField
                                                @bind-Value="_editValue"
                                                Variant="Variant.Outlined"
                                                FullWidth="true"
                                                OnKeyUp="HandleEditKeyUp"
                                                Class="todo-edit-field" />
                                            <MudIconButton
                                                Icon="@Icons.Material.Filled.Check"
                                                Color="Color.Success"
                                                Size="Size.Small"
                                                OnClick="HandleSaveEdit"
                                                title="Save"
                                                Class="todo-edit-save-btn" />
                                            <MudIconButton
                                                Icon="@Icons.Material.Filled.Close"
                                                Color="Color.Default"
                                                Size="Size.Small"
                                                OnClick="HandleCancelEdit"
                                                title="Cancel"
                                                Class="todo-edit-cancel-btn" />
                                        </div>
                                        <div class="d-flex align-center gap-2 flex-wrap">
                                            <MudSelect
                                                T="TodoPriority"
                                                @bind-Value="_editPriority"
                                                Label="Priority"
                                                Variant="Variant.Outlined"
                                                Dense="true"
                                                Style="min-width: 130px;"
                                                Class="todo-edit-priority">
                                                <MudSelectItem Value="@TodoPriority.None">None</MudSelectItem>
                                                <MudSelectItem Value="@TodoPriority.Low">Low</MudSelectItem>
                                                <MudSelectItem Value="@TodoPriority.Medium">Medium</MudSelectItem>
                                                <MudSelectItem Value="@TodoPriority.High">High</MudSelectItem>
                                            </MudSelect>
                                            <MudDatePicker
                                                @bind-Date="_editDueDate"
                                                Label="Due date"
                                                Variant="Variant.Outlined"
                                                Clearable="true"
                                                Style="min-width: 160px;"
                                                Class="todo-edit-due-date" />
                                            <MudSelect
                                                T="TimeEstimate"
                                                @bind-Value="_editTimeEstimate"
                                                Label="Time estimate"
                                                Variant="Variant.Outlined"
                                                Dense="true"
                                                Style="min-width: 130px;"
                                                Class="todo-edit-time-estimate">
                                                <MudSelectItem Value="@TimeEstimate.None">No estimate</MudSelectItem>
                                                <MudSelectItem Value="@TimeEstimate.FifteenMinutes">15 min</MudSelectItem>
                                                <MudSelectItem Value="@TimeEstimate.ThirtyMinutes">30 min</MudSelectItem>
                                                <MudSelectItem Value="@TimeEstimate.OneHour">1 hour</MudSelectItem>
                                                <MudSelectItem Value="@TimeEstimate.TwoHours">2 hours</MudSelectItem>
                                                <MudSelectItem Value="@TimeEstimate.FourHours">4 hours</MudSelectItem>
                                                <MudSelectItem Value="@TimeEstimate.OneDay">1 day</MudSelectItem>
                                            </MudSelect>
                                        </div>
                                    </div>
                                }
                                else
                                {
                                    <div class="d-flex align-center gap-2 mb-1">
                                        <MudText Typo="Typo.body1"
                                            Style="@(todo.IsCompleted ? "text-decoration: line-through; opacity: 0.5;" : "")">
                                            @SearchHighlighter.Highlight(todo.Title, _searchQuery.Trim())
                                        </MudText>
                                        @if (todo.Priority != TodoPriority.None)
                                        {
                                            <MudChip T="string" Size="Size.Small" Color="@GetPriorityColor(todo.Priority)" Variant="Variant.Filled"
                                                     Style="cursor:pointer;"
                                                     title="@($"{todo.Priority} priority — click to change")"
                                                     @onclick="@(async () => await HandleCyclePriority(todo.Id, todo.Priority))"
                                                     Class="todo-priority-chip">
                                                @todo.Priority.ToString()
                                            </MudChip>
                                        }
                                        else if (!todo.IsCompleted)
                                        {
                                            <MudIconButton Icon="@Icons.Material.Outlined.Flag"
                                                           Size="Size.Small"
                                                           Color="Color.Default"
                                                           Style="opacity:0.25; padding:2px;"
                                                           title="Set priority"
                                                           OnClick="@(async () => await HandleCyclePriority(todo.Id, TodoPriority.None))"
                                                           Class="todo-set-priority-btn" />
                                        }
                                        @if (todo.Recurrence != RecurrenceRule.None)
                                        {
                                            <MudChip T="string" Size="Size.Small" Color="Color.Tertiary" Variant="Variant.Outlined" Class="recurrence-badge">
                                                @GetRecurrenceLabel(todo.Recurrence)
                                            </MudChip>
                                        }
                                        @if (todo.TimeEstimate != TimeEstimate.None)
                                        {
                                            <MudChip T="string" Size="Size.Small" Color="Color.Default" Variant="Variant.Outlined" Class="time-estimate-badge">
                                                ~@GetTimeEstimateLabel(todo.TimeEstimate)
                                            </MudChip>
                                        }
                                        @if (!todo.IsCompleted)
                                        {
                                            var ageDays = (DateTime.Today - todo.CreatedAt.Date).Days;
                                            @if (ageDays >= 7)
                                            {
                                                var ageLabel = ageDays >= 30 ? "1+ mo old"
                                                             : ageDays >= 14 ? "2+ wks old"
                                                             : "1 wk old";
                                                var ageColor = ageDays >= 30 ? Color.Error : Color.Warning;
                                                <MudChip T="string" Size="Size.Small" Color="@ageColor" Variant="Variant.Outlined"
                                                         Class="todo-age-badge"
                                                         title="@($"Created {ageDays} day{(ageDays == 1 ? "" : "s")} ago — consider tackling this one")">
                                                    @ageLabel
                                                </MudChip>
                                            }
                                        }
                                        @if (todo.IsBlocked)
                                        {
                                            <MudChip T="string" Size="Size.Small" Color="Color.Warning" Variant="Variant.Outlined"
                                                     Class="blocked-badge"
                                                     title="This todo is blocked / waiting for something">
                                                ⏸ Waiting for
                                            </MudChip>
                                        }
                                        @if (IsGlobalSearch && todo.ListId != _activeListId)
                                        {
                                            var listName = _lists?.FirstOrDefault(l => l.Id == todo.ListId)?.Name;
                                            @if (listName is not null)
                                            {
                                                <MudChip T="string" Size="Size.Small" Color="Color.Info" Variant="Variant.Outlined" Class="search-result-list-badge">@listName</MudChip>
                                            }
                                        }
                                        <MudIconButton
                                            Icon="@Icons.Material.Filled.Edit"
                                            Color="Color.Default"
                                            Size="Size.Small"
                                            OnClick="@(() => HandleStartEdit(todo.Id, todo.Title, todo.Priority, todo.DueDate, todo.TimeEstimate))"
                                            title="Edit"
                                            Class="todo-edit-btn" />
                                    </div>
                                }
                                <MudText Typo="Typo.caption" Color="Color.Secondary">
                                    Added @todo.CreatedAt.ToLocalTime().ToString("MMM d, yyyy h:mm tt")
                                </MudText>
                                @if (!string.IsNullOrWhiteSpace(_searchQuery)
                                     && !todo.Title.Contains(_searchQuery.Trim(), StringComparison.OrdinalIgnoreCase)
                                     && todo.Notes != null
                                     && todo.Notes.Contains(_searchQuery.Trim(), StringComparison.OrdinalIgnoreCase))
                                {
                                    <MudChip T="string" Size="Size.Small" Color="Color.Default" Variant="Variant.Outlined" Class="notes-match-badge"
                                             title="This todo was found because its notes match your search">
                                        Matched in notes
                                    </MudChip>
                                }
                                @if (todo.IsCompleted && todo.CompletedAt.HasValue)
                                {
                                    <MudText Typo="Typo.caption" Color="Color.Success" Class="completed-at-text">
                                        ✓ @FormatCompletedAt(todo.CompletedAt.Value)
                                    </MudText>
                                }
                                @{
                                    var quickDateTodoId = todo.Id;
                                }
                                @if (_settingDueDateForTodoId == todo.Id)
                                {
                                    <div class="mt-1 quick-due-date-editor">
                                        <MudDatePicker
                                            @bind-Date="_quickDueDateValue"
                                            Label="Due date"
                                            Variant="Variant.Outlined"
                                            Clearable="true"
                                            Style="max-width: 200px;"
                                            Class="quick-due-date-picker" />
                                        <div class="d-flex gap-1 mt-1 align-center">
                                            <MudButton
                                                Size="Size.Small"
                                                Variant="Variant.Filled"
                                                Color="Color.Primary"
                                                OnClick="@(async () => await HandleSaveQuickDueDate(quickDateTodoId))"
                                                Class="quick-date-save-btn">Save</MudButton>
                                            @if (todo.DueDate.HasValue)
                                            {
                                                <MudButton
                                                    Size="Size.Small"
                                                    Variant="Variant.Outlined"
                                                    Color="Color.Error"
                                                    OnClick="@(async () => await HandleClearQuickDueDate(quickDateTodoId))"
                                                    Class="quick-date-clear-btn">Remove date</MudButton>
                                            }
                                            <MudButton
                                                Size="Size.Small"
                                                Variant="Variant.Text"
                                                Color="Color.Default"
                                                OnClick="@(() => _settingDueDateForTodoId = null)"
                                                Class="quick-date-cancel-btn">Cancel</MudButton>
                                        </div>
                                    </div>
                                }
                                else if (todo.DueDate.HasValue)
                                {
                                    var dueDateStatus = GetDueDateStatus(todo);
                                    <div class="d-flex align-center gap-1 mt-1 due-date-display"
                                         style="cursor:pointer;"
                                         title="Click to change due date"
                                         @onclick="@(() => HandleStartQuickDueDate(todo.Id, todo.DueDate))">
                                        @if (dueDateStatus == DueDateStatus.Overdue)
                                        {
                                            <MudIcon Icon="@Icons.Material.Filled.Warning" Size="Size.Small" Color="Color.Error" />
                                            <MudText Typo="Typo.caption" Color="Color.Error" Class="due-date-text">
                                                @FormatDueDateDisplay(todo.DueDate.Value)
                                            </MudText>
                                        }
                                        else if (dueDateStatus == DueDateStatus.DueToday)
                                        {
                                            <MudIcon Icon="@Icons.Material.Filled.Schedule" Size="Size.Small" Color="Color.Warning" />
                                            <MudText Typo="Typo.caption" Color="Color.Warning" Class="due-date-text">
                                                @FormatDueDateDisplay(todo.DueDate.Value)
                                            </MudText>
                                        }
                                        else
                                        {
                                            <MudText Typo="Typo.caption" Color="Color.Secondary" Class="due-date-text">
                                                @FormatDueDateDisplay(todo.DueDate.Value)
                                            </MudText>
                                        }
                                    </div>
                                }
                                else if (!todo.IsCompleted)
                                {
                                    <MudButton
                                        Size="Size.Small"
                                        Variant="Variant.Text"
                                        Color="Color.Secondary"
                                        StartIcon="@Icons.Material.Outlined.CalendarToday"
                                        OnClick="@(() => HandleStartQuickDueDate(todo.Id, null))"
                                        Class="quick-date-set-btn">Set date</MudButton>
                                }
                                @if (_editingNotesForTodoId == todo.Id)
                                {
                                    var currentTodoId = todo.Id;
                                    <div class="mt-2 todo-notes-editor">
                                        <MudTextField
                                            @bind-Value="_notesValue"
                                            Label="Notes"
                                            Variant="Variant.Outlined"
                                            Lines="3"
                                            FullWidth="true"
                                            Class="todo-notes-input" />
                                        <div class="d-flex align-center gap-2 mt-1">
                                            <MudButton
                                                Variant="Variant.Filled"
                                                Color="Color.Primary"
                                                Size="Size.Small"
                                                OnClick="@(async () => await HandleSaveNotes(currentTodoId))"
                                                Class="todo-notes-save-btn">Save</MudButton>
                                            <MudButton
                                                Variant="Variant.Text"
                                                Color="Color.Default"
                                                Size="Size.Small"
                                                OnClick="HandleCancelNotes"
                                                Class="todo-notes-cancel-btn">Cancel</MudButton>
                                            <MudText Typo="Typo.caption" Color="Color.Tertiary" Class="notes-markdown-hint">Markdown supported</MudText>
                                        </div>
                                    </div>
                                }
                                else if (!string.IsNullOrEmpty(todo.Notes))
                                {
                                    <div class="mt-1 todo-notes-display mud-typography mud-typography-caption"
                                         style="cursor:pointer; color: var(--mud-palette-text-secondary);"
                                         @onclick="@(() => HandleStartEditNotes(todo.Id, todo.Notes!))">
                                        @((MarkupString)MarkdownRenderer.Render(todo.Notes))
                                    </div>
                                }
                                <div class="d-flex align-center gap-1 mt-1 flex-wrap todo-tags-row">
                                    @foreach (var tag in _todoTags.GetValueOrDefault(todo.Id, []))
                                    {
                                        var tagId = tag.Id;
                                        var tagName = tag.Name;
                                        <MudChip T="string"
                                                 Size="Size.Small"
                                                 Color="@(_tagFilter == tagName ? Color.Primary : Color.Secondary)"
                                                 Variant="@(_tagFilter == tagName ? Variant.Filled : Variant.Outlined)"
                                                 OnClick="@(() => HandleFilterByTag(tagName))"
                                                 OnClose="@(async (MudChip<string> _) => await HandleRemoveTag(tagId))"
                                                 Class="todo-tag-chip"
                                                 title="@(_tagFilter == tagName ? "Clear tag filter" : $"Filter by \"{tagName}\"")">
                                            @tag.Name
                                        </MudChip>
                                    }
                                    @if (_addingTagForTodoId == todo.Id)
                                    {
                                        var currentTodoId = todo.Id;
                                        <div style="position:relative;">
                                            <MudTextField
                                                @bind-Value="_newTagInput"
                                                Variant="Variant.Outlined"
                                                Margin="Margin.Dense"
                                                Style="width: 110px; font-size: 0.75rem;"
                                                Immediate="true"
                                                OnKeyUp="@(async (KeyboardEventArgs e) => await HandleTagInputKeyUp(e, currentTodoId))"
                                                Class="todo-tag-input" />
                                            @{
                                                var suggestions = GetTagSuggestions(currentTodoId);
                                            }
                                            @if (suggestions.Count > 0)
                                            {
                                                <div class="tag-autocomplete-dropdown"
                                                     style="position:absolute;top:100%;left:0;min-width:110px;background:var(--mud-palette-surface);border:1px solid var(--mud-palette-divider);border-radius:4px;z-index:1000;box-shadow:0 2px 6px rgba(0,0,0,0.15);">
                                                    @foreach (var s in suggestions)
                                                    {
                                                        var suggestion = s;
                                                        <div class="tag-suggestion-item"
                                                             style="padding:4px 10px;cursor:pointer;font-size:0.75rem;white-space:nowrap;"
                                                             @onclick="@(async () => await HandleSelectTagSuggestion(currentTodoId, suggestion))">
                                                            @suggestion
                                                        </div>
                                                    }
                                                </div>
                                            }
                                        </div>
                                    }
                                    else
                                    {
                                        var currentTodoId = todo.Id;
                                        <MudIconButton
                                            Icon="@Icons.Material.Filled.LocalOffer"
                                            Size="Size.Small"
                                            Color="Color.Secondary"
                                            OnClick="@(() => HandleStartAddTag(currentTodoId))"
                                            title="Add tag"
                                            Class="add-tag-btn" />
                                    }
                                </div>
                                @{
                                    var todoSubtasks = _subtasks.GetValueOrDefault(todo.Id, []);
                                    var completedSubtasks = todoSubtasks.Count(s => s.IsCompleted);
                                    var isExpanded = _expandedSubtasksForTodoId == todo.Id;
                                }
                                <div class="mt-1 subtasks-section">
                                    <MudButton
                                        Size="Size.Small"
                                        Variant="Variant.Text"
                                        Color="@(todoSubtasks.Count > 0 ? Color.Primary : Color.Secondary)"
                                        StartIcon="@(isExpanded ? Icons.Material.Filled.ExpandLess : Icons.Material.Filled.ChevronRight)"
                                        OnClick="@(() => ToggleSubtasksExpanded(todo.Id))"
                                        Class="subtasks-toggle-btn">
                                        @if (todoSubtasks.Count > 0)
                                        {
                                            @($"{completedSubtasks}/{todoSubtasks.Count} subtask{(todoSubtasks.Count == 1 ? "" : "s")}")
                                        }
                                        else
                                        {
                                            @("Subtasks")
                                        }
                                    </MudButton>
                                    @if (isExpanded)
                                    {
                                        <div class="ps-3 subtasks-list">
                                            @foreach (var subtask in todoSubtasks)
                                            {
                                                var stId = subtask.Id;
                                                <div class="d-flex align-center gap-1 subtask-row @(_dragOverSubtaskId == stId ? "subtask-drag-over" : "")"
                                                     draggable="@(todoSubtasks.Count > 1 ? "true" : "false")"
                                                     @ondragstart="@(() => _draggingSubtaskId = stId)"
                                                     @ondragover:preventDefault
                                                     @ondragover="@(() => _dragOverSubtaskId = stId)"
                                                     @ondrop="@(async () => await HandleSubtaskDrop(todo.Id, stId))">
                                                    @if (todoSubtasks.Count > 1)
                                                    {
                                                        <MudIcon Icon="@Icons.Material.Filled.DragIndicator"
                                                                 Size="Size.Small"
                                                                 Class="subtask-drag-handle" />
                                                    }
                                                    <MudCheckBox
                                                        Value="@subtask.IsCompleted"
                                                        ValueChanged="@(async (bool _) => await HandleToggleSubtask(stId))"
                                                        Color="Color.Primary"
                                                        Size="Size.Small"
                                                        Class="subtask-checkbox" />
                                                    @if (_editingSubtaskId == subtask.Id)
                                                    {
                                                        var editStId = subtask.Id;
                                                        <MudTextField
                                                            @bind-Value="_editSubtaskTitle"
                                                            Variant="Variant.Outlined"
                                                            Margin="Margin.Dense"
                                                            FullWidth="true"
                                                            OnKeyUp="@(async (KeyboardEventArgs e) => await HandleSubtaskEditKeyUp(e, editStId))"
                                                            Class="subtask-edit-input" />
                                                        <MudIconButton
                                                            Icon="@Icons.Material.Filled.Check"
                                                            Color="Color.Success"
                                                            Size="Size.Small"
                                                            OnClick="@(async () => await HandleSaveSubtaskEdit(editStId))"
                                                            title="Save"
                                                            Class="subtask-edit-save-btn" />
                                                        <MudIconButton
                                                            Icon="@Icons.Material.Filled.Close"
                                                            Color="Color.Default"
                                                            Size="Size.Small"
                                                            OnClick="@(() => _editingSubtaskId = null)"
                                                            title="Cancel"
                                                            Class="subtask-edit-cancel-btn" />
                                                    }
                                                    else
                                                    {
                                                        var editStId = subtask.Id;
                                                        <MudText Typo="Typo.body2" Class="flex-grow-1"
                                                            Style="@(subtask.IsCompleted ? "text-decoration: line-through; opacity: 0.5;" : "")"
                                                            @ondblclick="@(() => HandleStartEditSubtask(editStId, subtask.Title))">
                                                            @subtask.Title
                                                        </MudText>
                                                        <MudIconButton
                                                            Icon="@Icons.Material.Filled.Edit"
                                                            Color="Color.Default"
                                                            Size="Size.Small"
                                                            OnClick="@(() => HandleStartEditSubtask(editStId, subtask.Title))"
                                                            title="Edit subtask"
                                                            Class="subtask-edit-btn" />
                                                        <MudIconButton
                                                            Icon="@Icons.Material.Filled.Close"
                                                            Size="Size.Small"
                                                            Color="Color.Default"
                                                            OnClick="@(async () => await HandleDeleteSubtask(stId))"
                                                            Class="subtask-delete-btn" />
                                                    }
                                                </div>
                                            }
                                            @if (_addingSubtaskForTodoId == todo.Id)
                                            {
                                                var currentTodoId = todo.Id;
                                                <MudTextField
                                                    @bind-Value="_newSubtaskTitle"
                                                    Variant="Variant.Outlined"
                                                    Margin="Margin.Dense"
                                                    Placeholder="New subtask..."
                                                    OnKeyUp="@(async (KeyboardEventArgs e) => await HandleSubtaskInputKeyUp(e, currentTodoId))"
                                                    Class="subtask-input" />
                                            }
                                            else
                                            {
                                                var currentTodoId = todo.Id;
                                                <MudButton
                                                    Size="Size.Small"
                                                    Variant="Variant.Text"
                                                    Color="Color.Secondary"
                                                    StartIcon="@Icons.Material.Filled.Add"
                                                    OnClick="@(() => HandleStartAddSubtask(currentTodoId))"
                                                    Class="add-subtask-btn">
                                                    Add subtask
                                                </MudButton>
                                            }
                                        </div>
                                    }
                                </div>
                                @{
                                    var urlTodoId = todo.Id;
                                }
                                @if (_settingUrlForTodoId == todo.Id)
                                {
                                    <div class="mt-2 todo-url-editor">
                                        <MudTextField
                                            @bind-Value="_urlInputValue"
                                            Label="Link URL"
                                            Variant="Variant.Outlined"
                                            FullWidth="true"
                                            Placeholder="https://..."
                                            Class="todo-url-input" />
                                        <div class="d-flex align-center gap-2 mt-1">
                                            <MudButton
                                                Variant="Variant.Filled"
                                                Color="Color.Primary"
                                                Size="Size.Small"
                                                OnClick="@(async () => await HandleSaveUrl(urlTodoId))"
                                                Class="todo-url-save-btn">Save</MudButton>
                                            @if (!string.IsNullOrEmpty(todo.Url))
                                            {
                                                <MudButton
                                                    Variant="Variant.Outlined"
                                                    Color="Color.Error"
                                                    Size="Size.Small"
                                                    OnClick="@(async () => await HandleClearUrl(urlTodoId))"
                                                    Class="todo-url-clear-btn">Remove link</MudButton>
                                            }
                                            <MudButton
                                                Variant="Variant.Text"
                                                Color="Color.Default"
                                                Size="Size.Small"
                                                OnClick="@(() => _settingUrlForTodoId = null)"
                                                Class="todo-url-cancel-btn">Cancel</MudButton>
                                        </div>
                                    </div>
                                }
                                else if (!string.IsNullOrEmpty(todo.Url))
                                {
                                    <div class="mt-1 todo-url-display">
                                        <a href="@todo.Url" target="_blank" rel="noopener noreferrer"
                                           class="todo-url-link"
                                           style="font-size:0.75rem;color:var(--mud-palette-info);text-decoration:none;display:inline-flex;align-items:center;gap:4px;">
                                            <MudIcon Icon="@Icons.Material.Filled.Link" Size="Size.Small" />
                                            @GetDisplayUrl(todo.Url)
                                        </a>
                                    </div>
                                }
                            </div>
                            <MudIconButton
                                Icon="@(string.IsNullOrEmpty(todo.Url) ? Icons.Material.Outlined.Link : Icons.Material.Filled.Link)"
                                Color="@(string.IsNullOrEmpty(todo.Url) ? Color.Default : Color.Info)"
                                Size="Size.Small"
                                OnClick="@(() => HandleStartEditUrl(todo.Id, todo.Url ?? string.Empty))"
                                title="@(string.IsNullOrEmpty(todo.Url) ? "Add link" : "Edit link")"
                                Class="todo-url-btn" />
                            <MudIconButton
                                Icon="@(string.IsNullOrEmpty(todo.Notes) ? Icons.Material.Outlined.StickyNote2 : Icons.Material.Filled.StickyNote2)"
                                Color="@(string.IsNullOrEmpty(todo.Notes) ? Color.Default : Color.Info)"
                                Size="Size.Small"
                                OnClick="@(() => HandleStartEditNotes(todo.Id, todo.Notes ?? string.Empty))"
                                title="@(string.IsNullOrEmpty(todo.Notes) ? "Add notes" : "Edit notes")"
                                Class="todo-notes-btn" />
                            <MudIconButton
                                Icon="@(todo.IsPinned ? Icons.Material.Filled.Star : Icons.Material.Outlined.StarBorder)"
                                Color="@(todo.IsPinned ? Color.Warning : Color.Default)"
                                Size="Size.Small"
                                OnClick="@(async () => await HandleTogglePin(todo.Id))"
                                title="@(todo.IsPinned ? "Unpin" : "Pin to top")"
                                Class="todo-pin-btn" />
                            @{
                                var snoozeTodoId = todo.Id;
                            }
                            @if (_snoozingTodoId == todo.Id)
                            {
                                <div class="d-flex gap-1 align-center snooze-options">
                                    <MudButton Size="Size.Small" Variant="Variant.Outlined" Color="Color.Info"
                                               OnClick="@(async () => await HandleSnooze(snoozeTodoId, 1))"
                                               Class="snooze-tomorrow-btn">Tomorrow</MudButton>
                                    <MudButton Size="Size.Small" Variant="Variant.Outlined" Color="Color.Info"
                                               OnClick="@(async () => await HandleSnooze(snoozeTodoId, 7))"
                                               Class="snooze-week-btn">+1 week</MudButton>
                                    <MudButton Size="Size.Small" Variant="Variant.Outlined" Color="Color.Info"
                                               OnClick="@(async () => await HandleSnooze(snoozeTodoId, 14))"
                                               Class="snooze-two-weeks-btn">+2 weeks</MudButton>
                                    <MudIconButton
                                        Icon="@Icons.Material.Filled.Close"
                                        Color="Color.Default"
                                        Size="Size.Small"
                                        OnClick="@(() => _snoozingTodoId = null)"
                                        title="Cancel snooze"
                                        Class="snooze-cancel-btn" />
                                </div>
                            }
                            else
                            {
                                <MudIconButton
                                    Icon="@Icons.Material.Filled.Snooze"
                                    Color="Color.Default"
                                    Size="Size.Small"
                                    OnClick="@(() => _snoozingTodoId = snoozeTodoId)"
                                    title="Snooze"
                                    Class="todo-snooze-btn" />
                            }
                            @if (_lists is { Count: > 1 })
                            {
                                var currentTodoId = todo.Id;
                                @if (_movingTodoId == todo.Id)
                                {
                                    <MudSelect
                                        T="int"
                                        Value="0"
                                        ValueChanged="@(async (int targetListId) => await HandleMoveTodo(currentTodoId, targetListId))"
                                        Dense="true"
                                        Variant="Variant.Outlined"
                                        Style="width: 110px; font-size: 0.75rem;"
                                        Label="Move to"
                                        Class="todo-move-select">
                                        @foreach (var list in _lists.Where(l => l.Id != todo.ListId))
                                        {
                                            <MudSelectItem Value="@list.Id">@list.Name</MudSelectItem>
                                        }
                                    </MudSelect>
                                    <MudIconButton
                                        Icon="@Icons.Material.Filled.Close"
                                        Color="Color.Default"
                                        Size="Size.Small"
                                        OnClick="@(() => _movingTodoId = null)"
                                        title="Cancel move"
                                        Class="todo-move-cancel-btn" />
                                }
                                else
                                {
                                    <MudIconButton
                                        Icon="@Icons.Material.Filled.DriveFileMove"
                                        Color="Color.Default"
                                        Size="Size.Small"
                                        OnClick="@(() => _movingTodoId = currentTodoId)"
                                        title="Move to list"
                                        Class="todo-move-btn" />
                                }
                            }
                            <MudIconButton
                                Icon="@Icons.Material.Filled.Delete"
                                Color="Color.Error"
                                Size="Size.Small"
                                OnClick="@(async () => await HandleDeleteTodo(todo.Id))"
                                Class="todo-delete-btn" />
                            <MudIconButton
                                Icon="@Icons.Material.Filled.ContentCopy"
                                Color="Color.Default"
                                Size="Size.Small"
                                OnClick="@(async () => await HandleDuplicateTodo(todo.Id))"
                                title="Duplicate"
                                Class="todo-duplicate-btn" />
                            @if (!todo.IsCompleted)
                            {
                                <MudIconButton
                                    Icon="@(todo.IsBlocked ? Icons.Material.Filled.PauseCircle : Icons.Material.Outlined.PauseCircle)"
                                    Color="@(todo.IsBlocked ? Color.Warning : Color.Default)"
                                    Size="Size.Small"
                                    OnClick="@(async () => await HandleToggleBlocked(todo.Id))"
                                    title="@(todo.IsBlocked ? "Mark as unblocked" : "Mark as blocked / waiting for")"
                                    Class="todo-block-btn" />
                            }
                            @{
                                var colorTodoId = todo.Id;
                            }
                            @if (_colorPickingTodoId == todo.Id)
                            {
                                <div class="d-flex gap-1 align-center color-picker-palette">
                                    <span style="display:inline-block;width:16px;height:16px;border-radius:50%;background:#9e9e9e;cursor:pointer;border:2px solid transparent;"
                                          title="Clear color"
                                          class="color-picker-none"
                                          @onclick="@(async () => await HandleSetColor(colorTodoId, TodoColorLabel.None))"></span>
                                    @foreach (var cl in new[] { TodoColorLabel.Red, TodoColorLabel.Orange, TodoColorLabel.Yellow, TodoColorLabel.Green, TodoColorLabel.Blue, TodoColorLabel.Purple })
                                    {
                                        var pickerLabel = cl;
                                        <span style="display:inline-block;width:16px;height:16px;border-radius:50%;background:@GetColorCss(pickerLabel);cursor:pointer;border:2px solid @(todo.ColorLabel == pickerLabel ? "var(--mud-palette-primary)" : "transparent");"
                                              title="@pickerLabel"
                                              class="color-picker-dot color-picker-@(pickerLabel.ToString().ToLower())"
                                              @onclick="@(async () => await HandleSetColor(colorTodoId, pickerLabel))"></span>
                                    }
                                    <MudIconButton
                                        Icon="@Icons.Material.Filled.Close"
                                        Color="Color.Default"
                                        Size="Size.Small"
                                        OnClick="@(() => _colorPickingTodoId = null)"
                                        title="Cancel"
                                        Class="color-picker-cancel-btn" />
                                </div>
                            }
                            else
                            {
                                <MudIconButton
                                    Icon="@Icons.Material.Filled.Palette"
                                    Color="@(todo.ColorLabel != TodoColorLabel.None ? Color.Primary : Color.Default)"
                                    Size="Size.Small"
                                    OnClick="@(() => _colorPickingTodoId = colorTodoId)"
                                    title="Set color label"
                                    Style="@(todo.ColorLabel != TodoColorLabel.None ? $"color:{GetColorCss(todo.ColorLabel)}!important;" : "")"
                                    Class="todo-color-btn" />
                            }
                        </div>
                    </MudListItem>
                    </div>
                    <MudDivider />
                }
            </MudList>
        </MudPaper>
    }
}

@code {
    private string _newTitle = string.Empty;
    private TodoPriority _newPriority = TodoPriority.None;
    private DateTime? _newDueDate;
    private RecurrenceRule _newRecurrence = RecurrenceRule.None;
    private TimeEstimate _newTimeEstimate = TimeEstimate.None;

    private IReadOnlyList<TodoList>? _lists;
    private IReadOnlyList<TodoList>? _archivedLists;
    private bool _showArchivedLists;
    private int _activeListId = 1;
    private bool _creatingList;
    private string _newListName = string.Empty;
    private int? _renamingListId;
    private string _renameListValue = string.Empty;
    private int? _draggingListId;
    private int? _dragOverListId;
    private int? _colorPickingListId;

    private int? _draggingId;
    private int? _dragOverId;
    private IReadOnlyList<TodoSummary>? _todos;
    private bool _isSubmitting;
    private string? _errorMessage;

    private int? _movingTodoId;
    private int? _snoozingTodoId;
    private int? _settingDueDateForTodoId;
    private DateTime? _quickDueDateValue;

    private TodoStatusFilter _statusFilter = TodoStatusFilter.All;
    private TodoSortOrder _sortOrder = TodoSortOrder.Newest;
    private string _searchQuery = string.Empty;
    private TodoDateFilter _dateFilter = TodoDateFilter.None;
    private TodoTimeEstimateFilter _timeEstimateFilter = TodoTimeEstimateFilter.Any;

    private int? _editingTodoId;
    private string _editValue = string.Empty;
    private TodoPriority _editPriority = TodoPriority.None;
    private DateTime? _editDueDate;
    private TimeEstimate _editTimeEstimate = TimeEstimate.None;

    private bool _isSelectMode;
    private HashSet<int> _selectedIds = new();
    private int _bulkMoveTargetListId;
    private string _bulkTagInput = string.Empty;
    private TodoPriority? _bulkPriority;
    private DateTime? _bulkDueDate;
    private TimeEstimate? _bulkTimeEstimate;
    private TodoColorLabel? _bulkColorLabel;

    private bool _isFocusMode;

    private TodoColorLabel? _colorFilter;
    private int? _colorPickingTodoId;
    private TodoStalenessFilter _stalenessFilter = TodoStalenessFilter.Any;

    private ActivityStats? _activityStats;

    private bool _showShortcutsHelp;
    private DotNetObjectReference<Home>? _dotNetRef;
    private bool _shortcutsRegistered;

    private Dictionary<int, List<Tag>> _todoTags = new();
    private IReadOnlyList<string> _allTagNames = [];
    private int? _addingTagForTodoId;
    private string _newTagInput = string.Empty;
    private string? _tagFilter;
    private TodoPriority? _priorityFilter;

    private int? _editingNotesForTodoId;
    private string _notesValue = string.Empty;

    private int? _settingUrlForTodoId;
    private string _urlInputValue = string.Empty;

    private string? _renamingTagName;
    private string _renameTagValue = string.Empty;

    private IReadOnlyList<FilterPreset>? _filterPresets;
    private bool _savingPreset;
    private string _presetNameInput = string.Empty;

    private bool _isMultiAddMode;
    private string _multiAddText = string.Empty;

    private IReadOnlyList<TodoTemplate>? _templates;
    private bool _savingTemplate;
    private string _templateNameInput = string.Empty;

    private int? _dailyGoal;
    private bool _editingGoal;
    private int _goalInput = 5;

    private int? _pickedTodoId;

    private bool _dismissedUrgencyBanner;
    private bool _dismissedStreakNudge;
    private bool _blockedFilter;
    private bool _isTodayView;
    private bool _isTrashView;
    private IReadOnlyList<TrashedTodo>? _trashedTodos;

    private FilterCountsResult? _filterCountsCache;

    private bool _remindersEnabled;
    private bool _reminderShownThisSession;

    private bool HasNonDefaultFormValues =>
        _newPriority != TodoPriority.None ||
        _newTimeEstimate != TimeEstimate.None ||
        _newRecurrence != RecurrenceRule.None;

    private IReadOnlyList<string> ParsedMultiAddLines =>
        _multiAddText
            .Split('\n', StringSplitOptions.None)
            .Select(l => l.Trim())
            .Where(l => l.Length > 0)
            .ToList();

    private TodoApp.Features.Todos.QuickAdd.ParseResult NewTitleHints => NaturalLanguageParser.Parse(_newTitle);

    private Dictionary<int, List<Subtask>> _subtasks = new();
    private int? _expandedSubtasksForTodoId;
    private int? _addingSubtaskForTodoId;
    private string _newSubtaskTitle = string.Empty;
    private int? _editingSubtaskId;
    private string _editSubtaskTitle = string.Empty;
    private int? _draggingSubtaskId;
    private int? _dragOverSubtaskId;

    private IReadOnlyList<string> AllTagNames =>
        _todoTags.Values.SelectMany(tags => tags.Select(t => t.Name))
            .Distinct().OrderBy(n => n).ToList();

    private bool AreAllDisplayedSelected =>
        DisplayedTodos.Count > 0 && DisplayedTodos.All(t => _selectedIds.Contains(t.Id));

    private bool HasActiveFilters =>
        _statusFilter != TodoStatusFilter.All ||
        _priorityFilter is not null ||
        _dateFilter != TodoDateFilter.None ||
        _tagFilter is not null ||
        _colorFilter is not null ||
        _timeEstimateFilter != TodoTimeEstimateFilter.Any ||
        _stalenessFilter != TodoStalenessFilter.Any ||
        _blockedFilter ||
        !string.IsNullOrWhiteSpace(_searchQuery);

    private int GetActiveCountForList(int listId) =>
        _todos?.Count(t => t.ListId == listId && !t.IsCompleted) ?? 0;

    // Cross-list mode: active when searching or date-filtering with multiple lists.
    private bool IsGlobalSearch =>
        (!string.IsNullOrWhiteSpace(_searchQuery) || _dateFilter != TodoDateFilter.None)
        && _lists is { Count: > 1 };

    private IReadOnlyList<TodoSummary> DisplayedTodos
    {
        get
        {
            if (_todos is null) return [];
            if (_isFocusMode)
            {
                // Blocked todos are excluded from Focus mode — you can't act on them
                var listSource = _todos.Where(t => t.ListId == _activeListId && !t.IsBlocked).ToList();
                return FocusModeHandler.Handle(listSource);
            }
            var source = IsGlobalSearch
                ? _todos.ToList()
                : _todos.Where(t => t.ListId == _activeListId).ToList();
            var filtered = FilterSortTodosHandler.Handle(source, _statusFilter, _sortOrder, _searchQuery, _priorityFilter, _dateFilter, _timeEstimateFilter, _stalenessFilter);
            var tagFiltered = _tagFilter is null
                ? filtered
                : filtered.Where(t => _todoTags.TryGetValue(t.Id, out var tags) && tags.Any(tag => tag.Name == _tagFilter)).ToList();
            var colorFiltered = _colorFilter is null
                ? tagFiltered
                : tagFiltered.Where(t => t.ColorLabel == _colorFilter.Value).ToList();
            if (!_blockedFilter) return colorFiltered;
            return colorFiltered.Where(t => t.IsBlocked).ToList();
        }
    }

    private enum DueDateStatus { Future, DueToday, Overdue }

    protected override async Task OnInitializedAsync()
    {
        var purgedCount = await PurgeExpiredTrashHandler.HandleAsync();
        await LoadTodosAsync();
        if (purgedCount > 0)
            Snackbar.Add($"{purgedCount} trash item{(purgedCount == 1 ? "" : "s")} older than {PurgeExpiredTrashHandler.RetentionDays} days were automatically purged", Severity.Info);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _dotNetRef = DotNetObjectReference.Create(this);
            await JS.InvokeVoidAsync("todoApp.registerKeyboardShortcuts", _dotNetRef);
            _shortcutsRegistered = true;

            _remindersEnabled = await JS.InvokeAsync<bool>("todoApp.getReminderPreference");
            if (_remindersEnabled)
            {
                StateHasChanged();
                await CheckAndShowReminderAsync();
            }
        }
    }

    public async ValueTask DisposeAsync()
    {
        if (_shortcutsRegistered)
        {
            try { await JS.InvokeVoidAsync("todoApp.unregisterKeyboardShortcuts"); }
            catch { /* ignore disposal errors */ }
        }
        _dotNetRef?.Dispose();
    }

    [JSInvokable]
    public async Task FocusNewTodoInput()
    {
        await JS.InvokeVoidAsync("todoApp.focusElement", ".new-todo-input input");
    }

    [JSInvokable]
    public async Task FocusSearchInput()
    {
        await JS.InvokeVoidAsync("todoApp.focusElement", ".todo-search-field input");
    }

    [JSInvokable]
    public void ToggleShortcutsHelp()
    {
        _showShortcutsHelp = !_showShortcutsHelp;
        StateHasChanged();
    }

    private async Task LoadTodosAsync()
    {
        _filterCountsCache = null;
        _lists = await GetListsHandler.HandleAsync();
        _archivedLists = await GetArchivedListsHandler.HandleAsync();
        _todos = await GetTodosHandler.HandleAsync();
        _activityStats = await ActivityStatsHandler.HandleAsync();
        _allTagNames = await GetAllTagNamesHandler.HandleAsync();
        _filterPresets = await GetFilterPresetsHandler.HandleAsync();
        _templates = await GetTemplatesHandler.HandleAsync();
        _dailyGoal = await GetDailyGoalHandler.HandleAsync();
        _trashedTodos = await GetTrashedTodosHandler.HandleAsync();
        if (_todos.Count > 0)
        {
            var ids = _todos.Select(t => t.Id).ToList();
            _todoTags = await GetTodoTagsHandler.HandleAsync(ids);
            _subtasks = await GetSubtasksHandler.HandleAsync(ids);
        }
        else
        {
            _todoTags = [];
            _subtasks = [];
        }
    }

    private async Task HandleAddTodo()
    {
        if (string.IsNullOrWhiteSpace(_newTitle))
        {
            _errorMessage = "Please enter a title.";
            return;
        }

        _errorMessage = null;
        _isSubmitting = true;

        try
        {
            var parsed = NaturalLanguageParser.Parse(_newTitle);
            var effectiveTitle    = parsed.CleanTitle.Length > 0 ? parsed.CleanTitle : _newTitle;
            var effectivePriority = _newPriority != TodoPriority.None ? _newPriority : (parsed.Priority ?? TodoPriority.None);
            var effectiveDueDate  = _newDueDate ?? parsed.DueDate;

            await AddTodoHandler.HandleAsync(effectiveTitle, effectivePriority, effectiveDueDate, _newRecurrence, _activeListId, _newTimeEstimate);
            _newTitle = string.Empty;
            _newPriority = TodoPriority.None;
            _newDueDate = null;
            _newRecurrence = RecurrenceRule.None;
            _newTimeEstimate = TimeEstimate.None;
            await LoadTodosAsync();
        }
        catch (ArgumentException ex)
        {
            _errorMessage = ex.Message;
        }
        finally
        {
            _isSubmitting = false;
        }
    }

    private void HandleToggleMultiAdd()
    {
        _isMultiAddMode = !_isMultiAddMode;
        _multiAddText = string.Empty;
    }

    private async Task HandleMultiAdd()
    {
        var lines = ParsedMultiAddLines;
        if (lines.Count == 0) return;

        _isSubmitting = true;
        try
        {
            var count = await AddMultipleTodosHandler.HandleAsync(lines, _activeListId);
            _multiAddText = string.Empty;
            _isMultiAddMode = false;
            await LoadTodosAsync();
            Snackbar.Add($"Added {count} todo{(count == 1 ? "" : "s")}", Severity.Success);
        }
        finally
        {
            _isSubmitting = false;
        }
    }

    private void HandleApplyTemplate(TodoTemplate template)
    {
        _newPriority = template.Priority;
        _newTimeEstimate = template.TimeEstimate;
        _newRecurrence = template.Recurrence;
    }

    private async Task HandleSaveTemplate()
    {
        if (string.IsNullOrWhiteSpace(_templateNameInput)) return;

        try
        {
            await SaveTemplateHandler.HandleAsync(_templateNameInput, _newPriority, _newTimeEstimate, _newRecurrence);
            _savingTemplate = false;
            _templateNameInput = string.Empty;
            _templates = await GetTemplatesHandler.HandleAsync();
            Snackbar.Add("Template saved", Severity.Normal);
        }
        catch (ArgumentException) { }
    }

    private async Task HandleTemplateNameKeyUp(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
            await HandleSaveTemplate();
        else if (e.Key == "Escape")
        {
            _savingTemplate = false;
            _templateNameInput = string.Empty;
        }
    }

    private async Task HandleDeleteTemplate(int templateId)
    {
        await DeleteTemplateHandler.HandleAsync(templateId);
        _templates = await GetTemplatesHandler.HandleAsync();
    }

    private void HandleStartEditGoal()
    {
        _goalInput = _dailyGoal ?? 5;
        _editingGoal = true;
    }

    private async Task HandleSaveGoal()
    {
        if (_goalInput < 1) _goalInput = 1;
        await SetDailyGoalHandler.HandleAsync(_goalInput);
        _dailyGoal = _goalInput;
        _editingGoal = false;
    }

    private void HandleCancelGoal()
    {
        _editingGoal = false;
    }

    private async Task HandleClearGoal()
    {
        await SetDailyGoalHandler.HandleAsync(0);
        _dailyGoal = null;
        _editingGoal = false;
    }

    private static string GetTemplateTooltip(TodoTemplate t)
    {
        var parts = new List<string>();
        if (t.Priority != TodoPriority.None) parts.Add($"Priority: {t.Priority}");
        if (t.TimeEstimate != TimeEstimate.None) parts.Add($"Time: {GetTimeEstimateLabelStatic(t.TimeEstimate)}");
        if (t.Recurrence != RecurrenceRule.None) parts.Add($"Repeats: {t.Recurrence}");
        return parts.Count > 0 ? string.Join(" · ", parts) : t.Name;
    }

    private static string GetTimeEstimateLabelStatic(TimeEstimate estimate) => estimate switch
    {
        TimeEstimate.FifteenMinutes => "15 min",
        TimeEstimate.ThirtyMinutes  => "30 min",
        TimeEstimate.OneHour        => "1 h",
        TimeEstimate.TwoHours       => "2 h",
        TimeEstimate.FourHours      => "4 h",
        TimeEstimate.OneDay         => "1 day",
        _                           => string.Empty
    };

    private async Task HandleEnterKey(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
            await HandleAddTodo();
    }

    private async Task HandleToggleComplete(int id)
    {
        var todo = _todos?.FirstOrDefault(t => t.Id == id);
        await CompleteTodoHandler.HandleAsync(id);

        // If completing a recurring todo, spawn the next instance
        if (todo is { Recurrence: not RecurrenceRule.None, IsCompleted: false })
        {
            await CreateRecurringInstanceHandler.HandleAsync(todo);
            Snackbar.Add($"Next \"{todo.Title}\" scheduled ({todo.Recurrence.ToString().ToLower()})", Severity.Info);
        }

        await LoadTodosAsync();
    }

