    private async Task HandleDrop(int targetId)
    {
        if (_draggingId is null || _draggingId == targetId)
        {
            _draggingId = null;
            _dragOverId = null;
            return;
        }

        // Build a new order by moving the dragged item to the target's position
        var listTodos = _todos!.Where(t => t.ListId == _activeListId).ToList();
        var dragged = listTodos.FirstOrDefault(t => t.Id == _draggingId.Value);
        var target  = listTodos.FirstOrDefault(t => t.Id == targetId);
        if (dragged is null || target is null) { _draggingId = null; _dragOverId = null; return; }

        var reordered = listTodos.Where(t => t.Id != _draggingId.Value).ToList();
        var insertAt  = reordered.IndexOf(target);
        reordered.Insert(insertAt, dragged);

        _draggingId = null;
        _dragOverId = null;

        await ReorderTodosHandler.HandleAsync(reordered.Select(t => t.Id).ToList());
        await LoadTodosAsync();
    }

