    private async Task HandleSubtaskDrop(int todoId, int targetSubtaskId)
    {
        if (_draggingSubtaskId is null || _draggingSubtaskId == targetSubtaskId)
        {
            _draggingSubtaskId = null;
            _dragOverSubtaskId = null;
            return;
        }

        var subtasks = _subtasks.GetValueOrDefault(todoId, []);
        var dragged = subtasks.FirstOrDefault(s => s.Id == _draggingSubtaskId.Value);
        var target  = subtasks.FirstOrDefault(s => s.Id == targetSubtaskId);
        if (dragged is null || target is null) { _draggingSubtaskId = null; _dragOverSubtaskId = null; return; }

        var reordered = subtasks.Where(s => s.Id != _draggingSubtaskId.Value).ToList();
        var insertAt  = reordered.IndexOf(target);
        reordered.Insert(insertAt, dragged);

        _draggingSubtaskId = null;
        _dragOverSubtaskId = null;

        await ReorderSubtasksHandler.HandleAsync(reordered.Select(s => s.Id).ToList());
        await LoadTodosAsync();
    }

