    private string? GetGroupLabel(TodoSummary todo)
    {
        if (_sortOrder != TodoSortOrder.PriorityDesc && _sortOrder != TodoSortOrder.DueDateAsc && _sortOrder != TodoSortOrder.Recommended) return null;
        if (todo.IsPinned) return "Pinned";
        return _sortOrder switch
        {
            TodoSortOrder.PriorityDesc  => GetPriorityGroupLabel(todo.Priority),
            TodoSortOrder.DueDateAsc    => GetDueDateGroupLabel(todo),
            TodoSortOrder.Recommended   => GetRecommendedGroupLabel(todo),
            _                           => null
        };
    }

    private static string? GetRecommendedGroupLabel(TodoSummary todo)
    {
        if (!todo.DueDate.HasValue || todo.IsCompleted) return null;
        var today = DateTime.Today;
        var due = todo.DueDate.Value.Date;
        if (due < today)            return "Overdue";
        if (due == today)           return "Due today";
        if (due < today.AddDays(7)) return "Due this week";
        return null;
    }

    private static string GetPriorityGroupLabel(TodoPriority priority) => priority switch
    {
        TodoPriority.High   => "High priority",
        TodoPriority.Medium => "Medium priority",
        TodoPriority.Low    => "Low priority",
        _                   => "No priority"
    };

    private static string GetDueDateGroupLabel(TodoSummary todo)
    {
        if (!todo.DueDate.HasValue) return "No date";
        var date = todo.DueDate.Value.Date;
        var today = DateTime.Today;
        if (date < today)              return "Overdue";
        if (date == today)             return "Today";
        if (date == today.AddDays(1))  return "Tomorrow";
        if (date < today.AddDays(7))   return "This week";
        return "Later";
    }

