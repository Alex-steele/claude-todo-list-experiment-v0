    private IReadOnlyList<string> GetTagSuggestions(int todoId)
    {
        if (string.IsNullOrWhiteSpace(_newTagInput)) return [];
        var input = _newTagInput.Trim().ToLowerInvariant();
        var existing = _todoTags.GetValueOrDefault(todoId, []).Select(t => t.Name).ToHashSet();
        return _allTagNames
            .Where(n => n.StartsWith(input, StringComparison.OrdinalIgnoreCase)
                        && !existing.Contains(n)
                        && n != input)
            .Take(5)
            .ToList();
    }

